---
import '../styles/home.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import FeaturedSection from '../components/sections/FeaturedSection.astro';
import ToolboxSection from '../components/sections/ToolboxSection.astro';
import PlatformsSection from '../components/sections/PlatformsSection.astro';
import TestimonialsSection from '../components/sections/TestimonialsSection.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import SectionDivider from '../components/decorations/SectionDivider.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh');

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://matthewhemhgz-dev.github.io';

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '祈研所 Qi-Lab',
  url: siteUrl,
  description: '探索技术、设计与创意的交汇之处',
  inLanguage: 'zh-CN',
  publisher: {
    '@type': 'Organization',
    name: '祈研所',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/logo.svg`,
    },
  },
};

const toolboxCategories = [
  { label: '知识管理', icon: 'book', tools: [{ name: 'Notion', desc: 'All-in-one 工作空间' }, { name: 'Obsidian', desc: '本地优先知识图谱' }, { name: 'Logseq', desc: '大纲笔记与双向链接' }] },
  { label: '开发工具', icon: 'cog', tools: [{ name: 'VS Code', desc: '主力代码编辑器' }, { name: 'Git', desc: '版本控制与协作' }, { name: 'Docker', desc: '容器化部署' }, { name: 'Astro', desc: '静态站点生成' }] },
  { label: 'AI 工具', icon: 'robot', tools: [{ name: 'ChatGPT', desc: '对话式 AI 助手' }, { name: 'Claude', desc: '深度推理与写作' }, { name: 'Midjourney', desc: 'AI 图像生成' }] },
  { label: '设计工具', icon: 'palette', tools: [{ name: 'Figma', desc: '协作界面设计' }, { name: 'Excalidraw', desc: '手绘风格白板' }] },
];

const platforms = [
  { name: 'GitHub', handle: '@qi-lab', url: 'https://github.com/qi-lab', icon: 'laptop', desc: '开源项目与代码' },
  { name: '微信公众号', handle: '祈研所', url: '#', icon: 'smartphone', desc: '长文与技术分享' },
  { name: '知乎', handle: '祈研所', url: '#', icon: 'book', desc: '技术问答与专栏' },
  { name: '即刻', handle: '@qilab', url: '#', icon: 'zap', desc: '碎片思考与动态' },
  { name: 'Twitter/X', handle: '@qilab_dev', url: '#', icon: 'bird', desc: '英文技术动态' },
  { name: 'Bilibili', handle: '祈研所', url: '#', icon: 'film', desc: '视频教程与演示' },
];

const testimonials = [
  { quote: '设计令牌系统那篇文章让我重新审视了整个项目的 CSS 架构，照着实践后代码可维护性提升了一个量级。', author: '林小明', role: '前端工程师' },
  { quote: 'Notion + Obsidian 双轨系统的思路非常实用，我已经按文章的方法搭建了自己的知识管理体系，效果显著。', author: '张文博', role: '产品经理' },
  { quote: '难得看到一个既有技术深度又有设计审美的个人站点，暗色模式的配色和动效细节都很用心。', author: '陈思远', role: 'UI 设计师' },
];
---

<BaseLayout title="祈研所 | Qi-Lab" description="祈研所（Qi-Lab）— 探索技术、设计与创意的交汇之处。" jsonLd={websiteJsonLd}>

  <HeroSection
    titleLines={['探索技术', '设计与创意', '的交汇之处']}
    accentIndex={1}
    subtitle="前端开发 · 系统设计 · 创意实验"
    watermark="祈"
    stats={[
      { value: String(allPosts.length), label: '原创文章', dataCount: allPosts.length },
      { value: '6', label: '内容平台', dataCount: 6 },
      { value: '持续', label: '更新中', isText: true },
    ]}
    primaryBtn={{ text: '了解更多', href: '/about' }}
    secondaryBtn={{ text: '浏览博客', href: '/blog' }}
  />

  <SectionDivider variant="dots" />

  <AboutSection
    label="// ABOUT"
    title="关于祈研所"
    text="祈研所诞生于对技术与美学交汇点的持续探索。我们相信，优秀的代码应当如同精心雕琢的艺术品，而好的设计则源于对细节的执着追求。这里记录着关于前端开发、系统设计、开源贡献以及创意实验的思考与实践。"
    decoNumber="01"
    decoSlogan="探索 · 创造 · 分享"
    dashItems={[
      { label: '前端开发', value: '5+', percentage: 92, color: 'emerald' },
      { label: '系统设计', value: '3+', percentage: 78, color: 'amber' },
      { label: '开源贡献', value: '20+', percentage: 85, color: 'emerald' },
      { label: '创意实验', value: '10+', percentage: 70, color: 'gray' },
    ]}
  />

  <SectionDivider variant="line" />

  <FeaturedSection
    label="// FEATURED"
    title="精选内容"
    posts={recentPosts}
    emptyText="暂无文章，敬请期待..."
    emptyIcon="svg"
    readMoreText="阅读全文"
    browseBlogHref="/blog"
    browseBlogText="浏览博客"
    largeCardLayout={true}
  />

  <SectionDivider variant="diamond" />

  <ToolboxSection
    label="// TOOLBOX"
    title="工具箱"
    categories={toolboxCategories}
  />

  <PlatformsSection
    label="// PLATFORMS"
    title="平台矩阵"
    platforms={platforms}
  />

  <TestimonialsSection
    label="// VOICES"
    title="读者评价"
    testimonials={testimonials}
  />

  <SectionDivider variant="arcs" />

  <CtaSection
    label="// LET'S CONNECT"
    title="一起探索技术的可能性"
    description="无论是技术交流、项目合作还是创意碰撞，欢迎随时联系。"
    primaryBtn={{ text: '发送邮件', href: 'mailto:hello@qi-lab.dev' }}
    secondaryBtn={{ text: 'GitHub', href: 'https://github.com/qi-lab', external: true }}
  />

</BaseLayout>

<style>
  /* === Chinese homepage: language-specific overrides === */

  /* Hero stagger animation */
  .hero-stagger {
    opacity: 0;
    animation: heroSlideIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-stagger--1 { animation-delay: 0.1s; }
  .hero-stagger--2 { animation-delay: 0.2s; }
  .hero-stagger--3 { animation-delay: 0.35s; }
  .hero-stagger--4 { animation-delay: 0.5s; }

  @keyframes heroSlideIn {
    from {
      opacity: 0;
      transform: translateX(-24px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Hero fade-in for subtitle and below */
  .hero-fade-in {
    opacity: 0;
    animation: fadeIn 0.8s ease 0.8s both;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Reduced motion: show all hero content immediately */
  @media (prefers-reduced-motion: reduce) {
    .hero-stagger,
    .hero-fade-in {
      opacity: 1;
      animation: none;
      transform: none;
    }
  }

  /* Hero stat: transition for counter animation */
  .hero-stat-value {
    transition: color 0.3s ease;
  }

  .hero-stat-text {
    animation: none;
    opacity: 1;
  }

  /* 4B: Large bento card - magazine style with image overlay */
  .bento-card--large {
    min-height: 380px;
    padding: 0;
  }

  .bento-card--large__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .bento-card--large__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .bento-card:hover .bento-card--large__bg img {
    transform: scale(1.05);
  }

  .bento-card--large__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--qi-text-primary) 88%, transparent) 0%,
      color-mix(in srgb, var(--qi-text-primary) 60%, transparent) 50%,
      color-mix(in srgb, var(--qi-text-primary) 45%, transparent) 100%
    );
    z-index: 1;
  }

  .bento-card--large__bg--gradient {
    background: linear-gradient(
      135deg,
      var(--qi-text-primary) 0%,
      var(--qi-brand-emerald) 60%,
      var(--qi-brand-amber) 100%
    );
  }

  .bento-card--large__bg--gradient .bento-card--large__overlay {
    opacity: 0;
    pointer-events: none;
  }

  .bento-card__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: var(--qi-space-sm);
    padding: var(--qi-space-xl);
    height: 100%;
    justify-content: flex-end;
  }

  .bento-card--large .bento-card__content {
    justify-content: flex-end;
    padding: var(--qi-space-2xl);
  }

  .bento-card--large .bento-meta {
    position: absolute;
    top: var(--qi-space-xl);
    left: var(--qi-space-xl);
  }

  .bento-card--large .bento-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--qi-text-inverse);
  }

  .bento-card--large .bento-desc {
    color: color-mix(in srgb, var(--qi-text-inverse) 75%, transparent);
  }

  .bento-card--large .bento-tag {
    background: color-mix(in srgb, var(--qi-text-inverse) 15%, transparent);
    color: var(--qi-text-inverse);
  }

  .bento-card--large .bento-date {
    color: color-mix(in srgb, var(--qi-text-inverse) 60%, transparent);
  }

  .bento-card--large .bento-link {
    color: var(--qi-brand-amber);
  }

  .bento-card--large:hover .bento-link {
    color: var(--qi-text-inverse);
  }

  /* Empty state icon (SVG version) */
  .empty-icon :global(svg) {
    width: 40px;
    height: 40px;
  }

  /* --- Responsive overrides --- */
  @media (max-width: 768px) {
    .bento-card--large {
      min-height: 280px;
    }

    .bento-card--large .bento-meta {
      position: static;
    }
  }
</style>

<script>
  // Animate hero stat numbers on page load (compatible with View Transitions)
  function animateStats() {
    const statValues = document.querySelectorAll('.hero-stat-value[data-count]');
    statValues.forEach((el) => {
      // 重置为 0 以便重新触发动画
      el.textContent = '0';
      const target = parseInt(el.getAttribute('data-count') || '0', 10);
      if (isNaN(target) || target === 0) return;
      let current = 0;
      const duration = 1200;
      const step = Math.max(1, Math.ceil(target / (duration / 30)));
      const timer = setInterval(() => {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = String(current);
      }, 30);
    });
  }
  document.addEventListener('astro:page-load', animateStats);
</script>
