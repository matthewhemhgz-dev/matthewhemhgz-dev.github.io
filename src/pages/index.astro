---
import BaseLayout from '../layouts/BaseLayout.astro';
import Divider from '../components/global/Divider.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import FeaturedSection from '../components/sections/FeaturedSection.astro';
import SkillsSection from '../components/sections/SkillsSection.astro';
import CategoriesSection from '../components/sections/CategoriesSection.astro';
import ToolboxSection from '../components/sections/ToolboxSection.astro';
import PlatformsSection from '../components/sections/PlatformsSection.astro';
import TimelineSection from '../components/sections/TimelineSection.astro';
import TestimonialsSection from '../components/sections/TestimonialsSection.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh');
const countByCategory = (cat) => allPosts.filter(p => p.data.category === cat).length;

const contentCategories = [
  { icon: 'chart-bar', title: '深度研析', desc: '长文深度分析，挖掘技术本质与底层原理', color: 'emerald', count: countByCategory('深度研析'), countLabel: '篇' },
  { icon: 'wrench', title: '实用干货', desc: '可落地的技巧、工具和工作流分享', color: 'amber', count: countByCategory('实用干货'), countLabel: '篇' },
  { icon: 'magnifier', title: '趋势洞察', desc: '前沿技术趋势与行业观察思考', color: 'emerald', count: countByCategory('趋势洞察'), countLabel: '篇' },
  { icon: 'thought-bubble', title: '随思随想', desc: '灵感记录、思考碎片与生活感悟', color: 'amber', count: countByCategory('随思随想'), countLabel: '篇' },
];

const toolboxCategories = [
  { label: '知识管理', icon: 'book', tools: [{ name: 'Notion', desc: 'All-in-one 工作空间' }, { name: 'Obsidian', desc: '本地优先知识图谱' }, { name: 'Logseq', desc: '大纲笔记与双向链接' }] },
  { label: '开发工具', icon: 'cog', tools: [{ name: 'VS Code', desc: '主力代码编辑器' }, { name: 'Git', desc: '版本控制与协作' }, { name: 'Docker', desc: '容器化部署' }, { name: 'Astro', desc: '静态站点生成' }] },
  { label: 'AI 工具', icon: 'robot', tools: [{ name: 'ChatGPT', desc: '对话式 AI 助手' }, { name: 'Claude', desc: '深度推理与写作' }, { name: 'Midjourney', desc: 'AI 图像生成' }] },
  { label: '设计工具', icon: 'palette', tools: [{ name: 'Figma', desc: '协作界面设计' }, { name: 'Excalidraw', desc: '手绘风格白板' }] },
];

const platforms = [
  { name: 'GitHub', handle: '@qi-lab', url: 'https://github.com/qi-lab', icon: 'laptop', desc: '开源项目与代码', comingSoonText: '即将上线' },
  { name: '微信公众号', handle: '祈研所', url: '#', icon: 'smartphone', desc: '长文与技术分享', comingSoonText: '即将上线' },
  { name: '知乎', handle: '祈研所', url: '#', icon: 'book', desc: '技术问答与专栏', comingSoonText: '即将上线' },
  { name: '即刻', handle: '@qilab', url: '#', icon: 'zap', desc: '碎片思考与动态', comingSoonText: '即将上线' },
  { name: 'Twitter/X', handle: '@qilab_dev', url: '#', icon: 'bird', desc: '英文技术动态', comingSoonText: '即将上线' },
  { name: 'Bilibili', handle: '祈研所', url: '#', icon: 'film', desc: '视频教程与演示', comingSoonText: '即将上线' },
];

const timelineItems = [
  { date: '2025.04', title: '祈研所网站 v4.0 上线', desc: 'Astro 重构，全新设计系统与多语言支持', tag: '里程碑' },
  { date: '2025.03', title: '启动知识管理双轨系统', desc: 'Obsidian + Notion 协同工作流', tag: '系统' },
  { date: '2025.02', title: '开始 AI 工具深度评测系列', desc: '系统化测评主流 AI 工具', tag: '内容' },
  { date: '2025.01', title: '祈研所品牌正式创立', desc: '技术探索与创意实验的起点', tag: '起点' },
  { date: '2024.11', title: '开源首个前端工具库', desc: '发布实用工具集，获得社区关注', tag: '开源' },
  { date: '2024.09', title: '开始系统化技术写作', desc: '建立内容体系，深耕前端与效率领域', tag: '起点' },
];

const testimonials = [
  { quote: '祈研所的技术文章总能把复杂的概念讲得清晰透彻，尤其是前端性能优化那篇，让我受益匪浅。', author: '一位前端开发者', role: '读者反馈' },
  { quote: '工具箱推荐非常实用，省去了我大量筛选工具的时间。知识管理系列更是直接改变了我整理笔记的方式。', author: '一位产品经理', role: '长期读者' },
  { quote: '难得看到一个既有技术深度又有设计审美的个人博客，每次访问都是一种享受。', author: '一位设计师', role: '订阅读者' },
];
---

<BaseLayout title="祈研所 | Qi-Lab" description="祈研所（Qi-Lab）— 探索技术、设计与创意的交汇之处。">

  <HeroSection
    titleLines={['探索技术', '设计与创意', '的交汇之处']}
    accentIndex={1}
    subtitle="前端开发 · 系统设计 · 创意实验 — 一个用代码构建、用设计表达的创意实验室。"
    watermark="祈"
    stats={[
      { value: String(allPosts.length), label: '原创文章', dataCount: allPosts.length },
      { value: '6', label: '内容平台', dataCount: 6 },
      { value: '持续', label: '更新中', isText: true },
    ]}
    primaryBtn={{ text: '了解更多', href: '/about' }}
    secondaryBtn={{ text: '浏览博客', href: '/blog' }}
  />

  <AboutSection
    label="// ABOUT"
    title="关于祈研所"
    text="祈研所诞生于对技术与美学交汇点的持续探索。我们相信，优秀的代码应当如同精心雕琢的艺术品，而好的设计则源于对细节的执着追求。这里记录着关于前端开发、系统设计、开源贡献以及创意实验的思考与实践。"
    decoNumber="01"
    decoSlogan="探索 · 创造 · 分享"
    dashItems={[
      { label: '前端开发', value: '5+', percentage: 92, color: 'emerald' },
      { label: '系统设计', value: '3+', percentage: 78, color: 'amber' },
      { label: '开源贡献', value: '20+', percentage: 85, color: 'emerald' },
      { label: '创意实验', value: '10+', percentage: 70, color: 'gray' },
    ]}
  />

  <Divider />

  <FeaturedSection
    label="// FEATURED"
    title="精选内容"
    posts={recentPosts}
    locale="zh"
    emptyText="暂无文章，敬请期待..."
    emptyIcon="svg"
    readMoreText="阅读全文"
    browseBlogHref="/blog"
    browseBlogText="浏览博客"
    largeCardLayout={true}
  />

  <Divider variant="gradient" />

  <SkillsSection
    label="// SKILLS"
    title="技术栈"
    intro="用技术栈构建创意的可能"
    tags={[
      { text: 'TypeScript', size: 'lg', href: '/tags/typescript' },
      { text: 'React', size: 'lg', href: '/tags/react' },
      { text: 'Astro', size: 'lg', href: '/tags/astro' },
      { text: 'Node.js', size: 'md', href: '/tags/nodejs' },
      { text: 'Vue', size: 'md', href: '/tags/vue' },
      { text: 'CSS', size: 'md', href: '/tags/css' },
      { text: 'Rust', size: 'md' },
      { text: 'Go', size: 'sm' },
      { text: 'PostgreSQL', size: 'sm' },
      { text: 'Docker', size: 'sm' },
      { text: 'Figma', size: 'sm' },
      { text: 'Git', size: 'sm' },
      { text: 'Linux', size: 'sm' },
      { text: 'WebGL', size: 'sm' },
    ]}
  />

  <CategoriesSection
    label="// CATEGORIES"
    title="内容分类"
    categories={contentCategories}
  />

  <ToolboxSection
    label="// TOOLBOX"
    title="工具箱"
    categories={toolboxCategories}
  />

  <Divider variant="dash" />

  <PlatformsSection
    label="// PLATFORMS"
    title="平台矩阵"
    platforms={platforms}
  />

  <TimelineSection
    label="// TIMELINE"
    title="更新日志"
    items={timelineItems}
  />

  <Divider variant="minimal" />

  <TestimonialsSection
    label="// VOICES"
    title="读者评价"
    testimonials={testimonials}
  />

  <CtaSection
    label="// LET'S CONNECT"
    title="一起探索技术的可能性"
    description="无论是技术交流、项目合作还是创意碰撞，欢迎随时联系。"
    primaryBtn={{ text: '发送邮件', href: 'mailto:hello@qi-lab.dev' }}
    secondaryBtn={{ text: 'GitHub', href: 'https://github.com/qi-lab', external: true }}
  />

</BaseLayout>

<style>
  /* === Chinese homepage: language-specific overrides === */

  /* Hero stagger animation */
  .hero-stagger {
    opacity: 0;
    animation: heroSlideIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-stagger--1 { animation-delay: 0.1s; }
  .hero-stagger--2 { animation-delay: 0.2s; }
  .hero-stagger--3 { animation-delay: 0.35s; }
  .hero-stagger--4 { animation-delay: 0.5s; }

  @keyframes heroSlideIn {
    from {
      opacity: 0;
      transform: translateX(-24px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Hero fade-in for subtitle and below */
  .hero-fade-in {
    opacity: 0;
    animation: fadeIn 0.8s ease 0.6s both;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Hero badge: position:relative for glow pseudo-element */
  .hero-badge {
    position: relative;
  }

  .hero-badge-glow {
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--qi-brand-emerald), var(--qi-brand-amber));
    opacity: 0;
    z-index: -1;
    filter: blur(8px);
    transition: opacity 0.6s ease;
  }

  .hero-badge:hover .hero-badge-glow {
    opacity: 0.3;
  }

  /* Button active states */
  .btn-primary:active {
    transform: scale(0.97);
  }

  .btn-secondary:active {
    transform: scale(0.97);
  }

  /* Hero stat: transition for counter animation */
  .hero-stat-value {
    transition: color 0.3s ease;
  }

  .hero-stat-text {
    animation: none;
    opacity: 1;
  }

  /* Category icon color variants */
  .category-card--emerald .category-icon-wrap {
    color: var(--qi-brand-emerald);
  }

  .category-card--amber .category-icon-wrap {
    color: var(--qi-amber);
  }

  /* 4B: Large bento card - magazine style with image overlay */
  .bento-card--large {
    min-height: 320px;
    padding: 0;
  }

  .bento-card--large__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .bento-card--large__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .bento-card:hover .bento-card--large__bg img {
    transform: scale(1.05);
  }

  .bento-card--large__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(28, 25, 23, 0.85) 0%,
      rgba(28, 25, 23, 0.5) 50%,
      rgba(28, 25, 23, 0.3) 100%
    );
    z-index: 1;
  }

  .bento-card--large__bg--gradient {
    background: linear-gradient(
      135deg,
      var(--qi-text-primary) 0%,
      var(--qi-brand-emerald) 60%,
      var(--qi-amber) 100%
    );
  }

  .bento-card--large__bg--gradient .bento-card--large__overlay {
    display: none;
  }

  .bento-card__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: var(--qi-space-sm);
    padding: var(--qi-space-xl);
    height: 100%;
    justify-content: flex-end;
  }

  .bento-card--large .bento-card__content {
    justify-content: flex-end;
    padding: var(--qi-space-2xl);
  }

  .bento-card--large .bento-meta {
    position: absolute;
    top: var(--qi-space-xl);
    left: var(--qi-space-xl);
  }

  .bento-card--large .bento-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: #fff;
  }

  .bento-card--large .bento-desc {
    color: rgba(255, 255, 255, 0.75);
  }

  .bento-card--large .bento-tag {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  .bento-card--large .bento-date {
    color: rgba(255, 255, 255, 0.6);
  }

  .bento-card--large .bento-link {
    color: var(--qi-amber);
  }

  .bento-card--large:hover .bento-link {
    color: #fff;
  }

  /* Empty state icon (SVG version) */
  .empty-icon :global(svg) {
    width: 40px;
    height: 40px;
  }

  /* Chinese timeline tag color variants */
  .timeline-tag--里程碑 {
    background: rgba(46, 125, 92, 0.1);
    color: var(--qi-brand-emerald);
  }

  .timeline-tag--起点 {
    background: rgba(229, 169, 60, 0.1);
    color: var(--qi-amber-dark);
  }

  .timeline-tag--系统 {
    background: rgba(42, 42, 42, 0.06);
    color: var(--qi-text-secondary);
  }

  .timeline-tag--内容 {
    background: rgba(42, 42, 42, 0.06);
    color: var(--qi-text-secondary);
  }

  .timeline-tag--开源 {
    background: rgba(229, 169, 60, 0.08);
    color: var(--qi-amber-dark);
  }

  /* --- Responsive overrides --- */
  @media (max-width: 768px) {
    .bento-card--large {
      min-height: 280px;
    }

    .bento-card--large .bento-meta {
      position: static;
    }
  }
</style>

<script>
  // Animate hero stat numbers on load
  document.addEventListener('DOMContentLoaded', () => {
    const statValues = document.querySelectorAll('.hero-stat-value[data-count]');
    statValues.forEach((el) => {
      const target = parseInt(el.getAttribute('data-count') || '0', 10);
      if (isNaN(target) || target === 0) return;
      let current = 0;
      const duration = 1200;
      const step = Math.max(1, Math.ceil(target / (duration / 30)));
      const timer = setInterval(() => {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = String(current);
      }, 30);
    });
  });
</script>
