---
import '../styles/home.css';
import '../styles/page-home.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import FeaturedSection from '../components/sections/FeaturedSection.astro';
import ToolboxSection from '../components/sections/ToolboxSection.astro';
import PlatformsSection from '../components/sections/PlatformsSection.astro';
import ResearchSection from '../components/sections/ResearchSection.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import SectionDivider from '../components/decorations/SectionDivider.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh');

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://matthewhemhgz-dev.github.io';

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '祈研所 QiLab',
  url: siteUrl,
  description: '致力于知识管理、项目管理、IT/AI 技术与前沿趋势的系统化研究与分享平台',
  inLanguage: 'zh-CN',
  publisher: {
    '@type': 'Organization',
    name: '祈研所',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/logo.svg`,
    },
  },
};

const toolboxCategories = [
  {
    label: '知识管理',
    icon: 'book',
    tools: [
      { name: 'Obsidian', desc: '本地优先知识图谱与双向链接系统' },
      { name: 'Graphify', desc: 'LLM 驱动的智能知识库自动构建工具' },
      { name: 'Markdown', desc: '单点真理的标准化文档格式' },
    ],
  },
  {
    label: '开发工具',
    icon: 'cog',
    tools: [
      { name: 'Trae', desc: 'AI 增强型智能代码编辑器' },
      { name: 'Git + GitHub', desc: '版本控制与开源协作平台' },
      { name: 'Docker', desc: '容器化部署与编排解决方案' },
      { name: 'Astro', desc: '零 JS 静态站点生成框架' },
    ],
  },
  {
    label: 'AI 工具',
    icon: 'robot',
    tools: [
      { name: 'OpenClaw', desc: '专属数字孪生外脑与模型路由系统' },
      { name: 'Trae SOLO', desc: 'AI 编程代理与 Subagent 编排平台' },
      { name: 'Superpowers', desc: 'TDD 驱动的系统化 AI 工作流' },
    ],
  },
  {
    label: '数据与运维',
    icon: 'database',
    tools: [
      { name: 'n8n', desc: '低代码自动化工作流引擎' },
      { name: 'Metabase', desc: '企业级数据可视化分析平台' },
      { name: 'PostgreSQL', desc: '高性能结构化数据存储系统' },
    ],
  },
];

const platforms = [
  {
    name: 'GitHub',
    handle: '@matthewhemhgz-dev',
    url: 'https://github.com/matthewhemhgz-dev',
    icon: 'laptop',
    desc: '开源项目与技术知识库',
  },
  {
    name: '微信公众号',
    handle: '祈研所',
    url: '#',
    icon: 'smartphone',
    desc: '深度长文与系统化知识分享',
    qrImage: '/images/social/wechat-oa-qr.jpg',
  },
  {
    name: '视频号',
    handle: '祈研所',
    url: '#',
    icon: 'film',
    desc: '知识分享短视频',
    qrImage: '/images/social/wechat-oa-qr.jpg',
  },
  {
    name: '小红书',
    handle: '祈研所（Qi_Lab）',
    url: '#',
    icon: 'book',
    desc: '实用技巧与干货图文',
    qrImage: '/images/social/xhs-qr.jpg',
  },
  {
    name: '抖音',
    handle: '祈研所（QiLab）',
    url: '#',
    icon: 'zap',
    desc: '技术知识短视频',
    qrImage: '/images/social/douyin-qr.jpg',
  },
  {
    name: 'GitHub Pages',
    handle: 'QiLab',
    url: 'https://matthewhemhgz-dev.github.io',
    icon: 'globe',
    desc: '官方博客与项目展示',
