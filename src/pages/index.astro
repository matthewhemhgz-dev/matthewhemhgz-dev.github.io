---

<BaseLayout
  title="祈研所 | QiLab"
  description="致力于知识管理、项目管理、IT/AI 技术与前沿趋势的系统化研究与分享平台"
  jsonLd={websiteJsonLd}
>
  <HeroSection
    titleLines={['在信息过载的时代', '系统化的知识管理', '是应对复杂挑战的核心能力']}
    accentIndex={1}
    subtitle="祈研所：连接理论与实践的知识工程实验室，构建从碎片到系统的完整知识体系。我们通过严谨的研究方法和实践验证，为知识工作者提供系统化的解决方案。"
    watermark="祈"
    stats={[
      { value: String(allPosts.length), label: '原创研究文章', dataCount: allPosts.length },
      { value: '5', label: '内容分发平台', dataCount: 5 },
      { value: '7+', label: '专业认证', dataCount: 7 },
      { value: '持续', label: '知识更新', isText: true },
    ]}
    primaryBtn={{ text: '了解我们', href: '/about' }}
    secondaryBtn={{ text: '探索博客', href: '/blog' }}
    lang="zh"
  />

  <SectionDivider variant="dots" />

  <div class="home-layout-grid">
    <div class="home-layout-main">
      <AboutSection
        classList="qi-anim-scroll-reveal"
        label="// ABOUT"
        title="关于祈研所"
        text='祈研所（QiLab）是一个专注于知识工程的研究与实践平台，致力于通过系统化方法整合知识管理、项目管理、IT/AI 技术与前沿趋势。我们以"整理 · 验证 · 分享"为核心价值，通过实际体验与深度思考，探索技术如何真正服务于人类需求。\n\n作为拥有 PMP、ITIL、CCNP 等 7 项专业认证的高级信息系统项目管理师，我们深刻理解"囤积不是管理，选择慢下来本身就是一种抵抗"。从 SystemPM 的零新功能重构，到 StockAAssist 的数据管道重建，再到祈研所知识库的从零搭建——每一次实践都是对"系统化根治而非打补丁"这一工程哲学的践行。\n\n每一篇内容、每一个工具推荐，都经过严格的实际使用验证，坚持长期主义与人类本体价值。在 AI 可以生成一切的时代，我们更加强调人类的思考、判断和创造力的价值。' 
        decoNumber="01"
        decoSlogan="整理 · 验证 · 分享"
        dashItems={[
          { label: '知识管理体系', value: '75+', percentage: 92, color: 'emerald' },
          { label: '项目管理认证', value: '7证', percentage: 88, color: 'amber' },
          { label: 'IT/AI 技术实践', value: '5+', percentage: 85, color: 'emerald' },
          { label: '前沿趋势研究', value: '10+', percentage: 70, color: 'gray' },
        ]}
      />

      <SectionDivider variant="line" />

      <FeaturedSection
        classList="qi-anim-scroll-reveal qi-anim-delay-200"
        label="// FEATURED"
        title="精选内容"
        posts={recentPosts}
        emptyText="暂无文章，敬请期待..."
        emptyIcon="svg"
        readMoreText="阅读全文"
        browseBlogHref="/blog"
        browseBlogText="浏览博客"
        largeCardLayout={true}
      />

      <SectionDivider variant="diamond" />

      <ResearchSection
        classList="qi-anim-scroll-reveal qi-anim-delay-500"
        label="// METHODOLOGY"
        title="研究方法论"
      />
    </div>
    <div class="home-layout-sidebar">
      <ToolboxSection
        classList="qi-anim-scroll-reveal qi-anim-delay-300"
        label="// TOOLBOX"
        title="工具箱"
        categories={toolboxCategories}
      />

      <PlatformsSection
        classList="qi-anim-scroll-reveal qi-anim-delay-400"
        label="// PLATFORMS"
        title="平台矩阵"
        platforms={platforms}
      />
    </div>
  </div>

  <SectionDivider variant="arcs" />

  <CtaSection
    class="qi-anim-scroll-reveal qi-anim-delay-600"
    label="// LET'S CONNECT"
    title="与我们共建知识生态"
    description="无论您是寻求知识管理解决方案、AI 工作流优化建议，还是希望开展项目合作，我们都期待与您深入交流。"
    primaryBtn={{ text: '发送邮件', href: 'mailto:matthewhemhgz@gmail.com' }}
    secondaryBtn={{
      text: '访问 GitHub',
      href: 'https://github.com/matthewhemhgz-dev',
      external: true,
    }}
  />
</BaseLayout>

<script>
  // Animate hero stat numbers on page load (compatible with View Transitions)
  function animateStats() {
    const statValues = document.querySelectorAll('.hero-stat-value[data-count]');
    statValues.forEach((el) => {
      // 重置为 0 以便重新触发动画
      el.textContent = '0';
      const target = parseInt(el.getAttribute('data-count') || '0', 10);
      if (isNaN(target) || target === 0) return;
      let current = 0;
      const duration = 1200;
      const step = Math.max(1, Math.ceil(target / (duration / 30)));
      const timer = setInterval(() => {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = String(current);
      }, 30);
    });
  }
  document.addEventListener('astro:page-load', animateStats);
</script>
