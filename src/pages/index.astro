---
import '../styles/home.css';
import '../styles/page-home.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import FeaturedSection from '../components/sections/FeaturedSection.astro';
import ToolboxSection from '../components/sections/ToolboxSection.astro';
import PlatformsSection from '../components/sections/PlatformsSection.astro';
import ResearchSection from '../components/sections/ResearchSection.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import SectionDivider from '../components/decorations/SectionDivider.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh');

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://matthewhemhgz-dev.github.io';

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '祈研所 QiLab',
  url: siteUrl,
  description: '一个系统化整理知识管理、项目管理、IT/AI技巧和八卦前沿的地方',
  inLanguage: 'zh-CN',
  publisher: {
    '@type': 'Organization',
    name: '祈研所',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/logo.svg`,
    },
  },
};

const toolboxCategories = [
  { label: '知识管理', icon: 'book', tools: [{ name: 'Obsidian', desc: '本地优先知识图谱与双向链接' }, { name: 'Graphify', desc: 'LLM 驱动的知识库自动构建器' }, { name: 'Markdown', desc: '单点真理的文档格式标准' }] },
  { label: '开发工具', icon: 'cog', tools: [{ name: 'Trae', desc: 'AI 增强代码编辑器' }, { name: 'Git + GitHub', desc: '版本控制与开源协作' }, { name: 'Docker', desc: '容器化部署与编排' }, { name: 'Astro', desc: '零 JS 静态站点生成' }] },
  { label: 'AI 工具', icon: 'robot', tools: [{ name: 'OpenClaw', desc: '专属数字孪生外脑（模型路由）' }, { name: 'Trae SOLO', desc: 'AI 编程代理与 Subagent 编排' }, { name: 'Superpowers', desc: 'TDD + 系统化调试的 AI 工作流' }] },
  { label: '数据与运维', icon: 'database', tools: [{ name: 'n8n', desc: '自动化工作流引擎' }, { name: 'Metabase', desc: '运营数据可视化看板' }, { name: 'PostgreSQL', desc: '结构化数据持久化存储' }] },
];

const platforms = [
  { name: 'GitHub', handle: '@matthewhemhgz-dev', url: 'https://github.com/matthewhemhgz-dev', icon: 'laptop', desc: '开源项目与知识库' },
  { name: '微信公众号', handle: '祈研所', url: '#', icon: 'smartphone', desc: '深度长文与系统化分享', qrImage: '/images/social/wechat-oa-qr.jpg' },
  { name: '视频号', handle: '祈研所', url: '#', icon: 'film', desc: '短视频', qrImage: '/images/social/wechat-oa-qr.jpg' },
  { name: '小红书', handle: '祈研所（Qi_Lab）', url: '#', icon: 'book', desc: '干货图文与实用技巧', qrImage: '/images/social/xhs-qr.jpg' },
  { name: '抖音', handle: '祈研所（QiLab）', url: '#', icon: 'zap', desc: '短视频', qrImage: '/images/social/douyin-qr.jpg' },
  { name: 'GitHub Pages', handle: 'QiLab', url: 'https://matthewhemhgz-dev.github.io', icon: 'globe', desc: '博客与项目展示' },
];


---

<BaseLayout title="祈研所 | QiLab" description="一个系统化整理知识管理、项目管理、IT/AI技巧和八卦前沿的地方" jsonLd={websiteJsonLd}>

  <HeroSection
    titleLines={['在信息过载的时代', '结构化的知识', '才是真正的力量']}
    accentIndex={1}
    subtitle="致力于思维架构与知识工程的个人品牌，探索从碎片到系统的闭环。"
    watermark="祈"
    stats={[
      { value: String(allPosts.length), label: '原创文章', dataCount: allPosts.length },
      { value: '5', label: '内容平台', dataCount: 5 },
      { value: '持续', label: '更新中', isText: true },
    ]}
    primaryBtn={{ text: '了解更多', href: '/about' }}
    secondaryBtn={{ text: '浏览博客', href: '/blog' }}
  />

  <SectionDivider variant="dots" />

  <AboutSection
    label="// ABOUT"
    title="关于祈研所"
    text="祈研所是我的数字档案室——一个系统化整理知识管理、项目管理、IT/AI技巧和八卦前沿的地方。通过个人体验、实践思考和系统化笔记，我探索如何让技术真正服务于人的需求。每一篇文章、每一个工具推荐，都经过实际使用验证。坚持人类本体价值，长期主义。"
    decoNumber="01"
    decoSlogan="整理 · 验证 · 分享"
    dashItems={[
      { label: '知识管理', value: '75+', percentage: 92, color: 'emerald' },
      { label: '项目管理', value: '7证', percentage: 88, color: 'amber' },
      { label: 'IT/AI 技巧', value: '5+', percentage: 85, color: 'emerald' },
      { label: '八卦前沿', value: '10+', percentage: 70, color: 'gray' },
    ]}
  />

  <SectionDivider variant="line" />

  <FeaturedSection
    label="// FEATURED"
    title="精选内容"
    posts={recentPosts}
    emptyText="暂无文章，敬请期待..."
    emptyIcon="svg"
    readMoreText="阅读全文"
    browseBlogHref="/blog"
    browseBlogText="浏览博客"
    largeCardLayout={true}
  />

  <SectionDivider variant="diamond" />

  <ToolboxSection
    label="// TOOLBOX"
    title="工具箱"
    categories={toolboxCategories}
  />

  <PlatformsSection
    label="// PLATFORMS"
    title="平台矩阵"
    platforms={platforms}
  />

  <ResearchSection
    label="// METHODOLOGY"
    title="研究方法论"
  />

  <SectionDivider variant="arcs" />

  <CtaSection
    label="// LET'S CONNECT"
    title="一起让知识真正有用"
    description="无论是知识管理交流、AI 工作流探讨还是项目合作，欢迎随时联系。"
    primaryBtn={{ text: '发送邮件', href: 'mailto:matthewhemhgz@gmail.com' }}
    secondaryBtn={{ text: 'GitHub', href: 'https://github.com/matthewhemhgz-dev', external: true }}
  />

</BaseLayout>

<script>
  // Animate hero stat numbers on page load (compatible with View Transitions)
  function animateStats() {
    const statValues = document.querySelectorAll('.hero-stat-value[data-count]');
    statValues.forEach((el) => {
      // 重置为 0 以便重新触发动画
      el.textContent = '0';
      const target = parseInt(el.getAttribute('data-count') || '0', 10);
      if (isNaN(target) || target === 0) return;
      let current = 0;
      const duration = 1200;
      const step = Math.max(1, Math.ceil(target / (duration / 30)));
      const timer = setInterval(() => {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = String(current);
      }, 30);
    });
  }
  document.addEventListener('astro:page-load', animateStats);
</script>
