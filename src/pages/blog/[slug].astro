---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';
import OptimizedImage from '../../components/ui/OptimizedImage.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh');
  return posts.map((post, index) => ({
    params: { slug: post.id.replace('zh/', '') },
    props: {
      post,
      prevPost: index > 0 ? posts[index - 1] : null,
      nextPost: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body || '');

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://matthewhemhgz-dev.github.io';
const articleUrl = `${siteUrl}/blog/${post.id.replace('zh/', '')}/`;
const ogImage = post.data.heroImage
  ? `${siteUrl}${post.data.heroImage}`
  : '/og-default.png';

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  url: articleUrl,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate || post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author || 'Qi-Lab',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: '祈研所',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/logo.svg`,
    },
  },
  inLanguage: 'zh-CN',
  ...(post.data.tags?.length > 0 && {
    keywords: post.data.tags.join(', '),
  }),
};
---

<BaseLayout
  title={`${post.data.title} — 祈研所 Qi-Lab`}
  description={post.data.description}
  ogImage={ogImage}
  ogType="article"
  jsonLd={articleJsonLd}
>
  <article class="article-container">
    <a href="/blog" class="article-back">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>返回列表</span>
    </a>

    <header class="article-header">
      {post.data.heroImage && (
        <div class="article-hero-image">
          <OptimizedImage src={post.data.heroImage} alt={post.data.title} width={1200} height={675} loading="eager" />
        </div>
      )}
      <div class="article-meta-top">
        <span class="article-category">{post.data.category}</span>
        <time class="article-date">{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span class="article-reading-time">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 1a7 7 0 100 14A7 7 0 008 1zm0 1.5a5.5 5.5 0 110 11 5.5 5.5 0 010-11zM8.25 4.5v3.75l2.5 1.5-.75 1.25-3.25-1.95V4.5h1.5z" fill="currentColor"/></svg>
          {readingTime}
        </span>
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      {post.data.description && (
        <p class="article-description">{post.data.description}</p>
      )}
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="article-tags">
          {post.data.tags.map(tag => (
            <a href={`/tags/${tag}/`} class="article-tag" key={tag}>#{tag}</a>
          ))}
        </div>
      )}
      <div class="article-divider"></div>
    </header>

    {headings.length > 0 && (
      <nav class="toc">
        <div class="toc-header">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 2h8M4 8h8M4 14h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span>目录</span>
        </div>
        <ul class="toc-list">
          {headings.filter(h => h.depth <= 3).map(h => (
            <li key={h.slug} class={`toc-item toc-item--depth-${h.depth}`}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <div class="prose">
      <Content />
    </div>

    <footer class="article-footer">
      <div class="article-divider"></div>
      <div class="article-footer-content">
        <span class="article-footer-label">— 祈研所 Qi-Lab —</span>
        <p class="article-footer-hint">如果这篇文章对你有帮助，欢迎分享给更多人。</p>
        <div class="article-share">
          <span class="article-share-label">分享到：</span>
          <div class="article-share-buttons">
            <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(articleUrl)}&text=${encodeURIComponent(post.data.title)}&via=qilab_dev`} class="article-share-btn" target="_blank" rel="noopener noreferrer" aria-label="分享到 Twitter">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>Twitter</span>
            </a>
            <a href={`https://service.weibo.com/share/share.php?url=${encodeURIComponent(articleUrl)}&title=${encodeURIComponent(post.data.title)}&pic=${encodeURIComponent(ogImage || '')}`} class="article-share-btn" target="_blank" rel="noopener noreferrer" aria-label="分享到微博">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>微博</span>
            </a>
            <button class="article-share-btn article-share-wechat" aria-label="分享到微信">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M15 11.5a3.5 3.5 0 1 1-7 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>微信</span>
              <div class="article-share-wechat-qr">
                <div class="article-share-wechat-qr-code">
                  <img src={`https://api.qrserver.com/v1/create-qr-code/?size=128x128&data=${encodeURIComponent(articleUrl)}`} alt="微信分享二维码" />
                </div>
                <span>扫码分享</span>
              </div>
            </button>
            <button class="article-share-btn article-share-copy" aria-label="复制链接">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>复制链接</span>
            </button>
          </div>
        </div>
      </div>
      <nav class="article-nav">
        {prevPost && (
          <a href={`/blog/${prevPost.id.replace('zh/', '')}/`} class="article-nav-link article-nav-link--prev">
            <span class="article-nav-direction">← 上一篇</span>
            <span class="article-nav-title">{prevPost.data.title}</span>
          </a>
        )}
        {nextPost && (
          <a href={`/blog/${nextPost.id.replace('zh/', '')}/`} class="article-nav-link article-nav-link--next">
            <span class="article-nav-direction">下一篇 →</span>
            <span class="article-nav-title">{nextPost.data.title}</span>
          </a>
        )}
      </nav>
    </footer>
  </article>
  <script>
    import '../../scripts/copy-code.ts';
    
    // 分享功能脚本
    document.addEventListener('astro:page-load', () => {
      // 微信分享二维码显示/隐藏
      const wechatBtn = document.querySelector('.article-share-wechat');
      if (wechatBtn) {
        wechatBtn.addEventListener('mouseenter', () => {
          const qrCode = wechatBtn.querySelector('.article-share-wechat-qr');
          if (qrCode) {
            qrCode.style.display = 'block';
          }
        });
        wechatBtn.addEventListener('mouseleave', () => {
          const qrCode = wechatBtn.querySelector('.article-share-wechat-qr');
          if (qrCode) {
            qrCode.style.display = 'none';
          }
        });
      }
      
      // 复制链接功能
      const copyBtn = document.querySelector('.article-share-copy');
      if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
          try {
            const articleUrl = window.location.href;
            await navigator.clipboard.writeText(articleUrl);
            const originalText = copyBtn.querySelector('span').textContent;
            copyBtn.querySelector('span').textContent = '已复制';
            setTimeout(() => {
              copyBtn.querySelector('span').textContent = originalText;
            }, 2000);
          } catch (err) {
            console.error('复制失败:', err);
          }
        });
      }
    });
  </script>
</BaseLayout>

<style>
  .article-share {
    margin-top: var(--qi-space-lg);
    margin-bottom: var(--qi-space-lg);
  }
  
  .article-share-label {
    display: block;
    margin-bottom: var(--qi-space-sm);
    font-size: var(--qi-text-sm);
    color: var(--qi-on-surface-secondary);
  }
  
  .article-share-buttons {
    display: flex;
    gap: var(--qi-space-sm);
    flex-wrap: wrap;
  }
  
  .article-share-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border: 1px solid var(--qi-border-subtle);
    border-radius: var(--qi-radius-md);
    background: var(--qi-surface-main);
    color: var(--qi-on-surface);
    text-decoration: none;
    font-size: var(--qi-text-xs);
    transition: all var(--qi-transition);
    cursor: pointer;
    position: relative;
  }
  
  .article-share-btn:hover {
    background: var(--qi-surface-hover);
    border-color: var(--qi-brand-emerald);
    transform: translateY(-2px);
  }
  
  .article-share-btn svg {
    width: 16px;
    height: 16px;
  }
  
  .article-share-wechat {
    position: relative;
  }
  
  .article-share-wechat-qr {
    position: absolute;
    bottom: 100%;
    right: 0;
    margin-bottom: 8px;
    background: var(--qi-surface-main);
    border: 1px solid var(--qi-border-subtle);
    border-radius: var(--qi-radius-md);
    padding: var(--qi-space-sm);
    box-shadow: var(--qi-shadow-hover-warm);
    display: none;
    z-index: 100;
  }
  
  .article-share-wechat-qr-code {
    margin-bottom: var(--qi-space-xs);
  }
  
  .article-share-wechat-qr-code img {
    width: 128px;
    height: 128px;
  }
  
  .article-share-wechat-qr span {
    display: block;
    text-align: center;
    font-size: var(--qi-text-xs);
    color: var(--qi-on-surface-secondary);
  }
  
  @media (max-width: 768px) {
    .article-share-buttons {
      flex-direction: column;
    }
    
    .article-share-btn {
      justify-content: center;
    }
    
    .article-share-wechat-qr {
      right: 50%;
      transform: translateX(50%);
    }
  }
</style>
