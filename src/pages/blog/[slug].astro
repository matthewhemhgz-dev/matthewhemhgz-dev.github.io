---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';
import OptimizedImage from '../../components/ui/OptimizedImage.astro';
import MermaidInit from '../../components/global/MermaidInit.astro';
import ArticleViewCount from '../../components/global/ArticleViewCount.astro';
import Skeleton from '../../components/ui/Skeleton.astro';
import RelatedArticles from '../../components/sections/RelatedArticles.astro';
import ReadingProgress from '../../components/global/ReadingProgress.astro';
import TableOfContents from '../../components/global/TableOfContents.astro';
import Comments from '../../components/global/Comments.astro';
import ShareButtons from '../../components/global/ShareButtons.astro';
import '../../styles/sections/article.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh');
  return posts.map((post, index) => ({
    params: { slug: post.id.replace('zh/', '') },
    props: {
      post,
      prevPost: index > 0 ? posts[index - 1] : null,
      nextPost: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body || '');

// Get all posts for related articles
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh');

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://matthewhemhgz-dev.github.io';
const articleUrl = `${siteUrl}/blog/${post.id.replace('zh/', '')}/`;
const ogImage = post.data.heroImage ? `${siteUrl}${post.data.heroImage}` : '/og-default.png';

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  url: articleUrl,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate || post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author || 'Qi-Lab',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: '祈研所',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/logo.svg`,
    },
  },
  inLanguage: 'zh-CN',
  ...(post.data.tags?.length > 0 && {
    keywords: post.data.tags.join(', '),
  }),
};
---

<BaseLayout
  title={`${post.data.title} — 祈研所 Qi-Lab`}
  description={post.data.description}
  ogImage={ogImage}
  ogImageWidth={1200}
  ogImageHeight={675}
  ogType="article"
  pubDate={post.data.pubDate.toISOString()}
  modDate={(post.data.updatedDate || post.data.pubDate).toISOString()}
  articleSection={post.data.category}
  articleTags={post.data.tags}
  jsonLd={articleJsonLd}
>
  <ReadingProgress label="阅读进度" />
  <TableOfContents headings={headings} label="目录" />
  <article class="article-container">
    <a href="/blog" class="article-back">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"
        ><path
          d="M10 3L5 8l5 5"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path></svg
      >
      <span>返回列表</span>
    </a>

    <header class="article-header">
      {
        post.data.heroImage && (
          <div class="article-hero-image">
            <OptimizedImage
              src={post.data.heroImage}
              alt={post.data.title}
              width={1200}
              height={675}
              loading="eager"
              sizes="(max-width: 1200px) 100vw, 1200px"
            />
          </div>
        )
      }
      <div class="article-meta-top">
        <span class="article-category">{post.data.category}</span>
        <time class="article-date"
          >{
            post.data.pubDate.toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }</time
        >
        <span class="article-reading-time">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"
            ><path
              d="M8 1a7 7 0 100 14A7 7 0 008 1zm0 1.5a5.5 5.5 0 110 11 5.5 5.5 0 010-11zM8.25 4.5v3.75l2.5 1.5-.75 1.25-3.25-1.95V4.5h1.5z"
              fill="currentColor"></path></svg
          >
          {readingTime}
        </span>
        <ArticleViewCount articleId={post.id} />
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      {post.data.description && <p class="article-description">{post.data.description}</p>}
      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="article-tags">
            {post.data.tags.map((tag) => (
              <a href={`/tags/${tag}/`} class="article-tag" key={tag}>
                #{tag}
              </a>
            ))}
          </div>
        )
      }
      <div class="article-divider"></div>
    </header>

    {
      headings.length > 0 && (
        <nav class="toc">
          <div class="toc-header">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M4 2h8M4 8h8M4 14h5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
              />
            </svg>
            <span>目录</span>
          </div>
          <ul class="toc-list">
            {headings
              .filter((h) => h.depth <= 3)
              .map((h) => (
                <li key={h.slug} class={`toc-item toc-item--depth-${h.depth}`}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
          </ul>
        </nav>
      )
    }

    <div class="prose">
      <div id="article-content">
        <Content />
      </div>
      <div id="article-skeleton" class="hidden">
        <Skeleton type="heading" width="80%" height="32px" />
        <Skeleton type="paragraph" count="5" />
        <Skeleton type="image" width="100%" />
        <Skeleton type="paragraph" count="3" />
      </div>
    </div>

    <footer class="article-footer">
      <div class="article-divider"></div>
      <div class="article-footer-content">
        <span class="article-footer-label">— 祈研所 Qi-Lab —</span>
        <p class="article-footer-hint">如果这篇文章对你有帮助，欢迎分享给更多人。</p>
        <ShareButtons url={articleUrl} title={post.data.title} description={post.data.description} image={ogImage} lang="zh" />
      </div>
      
      <RelatedArticles currentPost={post} allPosts={allPosts} limit={3} lang="zh" />
      
      <Comments lang="zh" />
      
      <nav class="article-nav">
        {
          prevPost && (
            <a
              href={`/blog/${prevPost.id.replace('zh/', '')}/`}
              class="article-nav-link article-nav-link--prev"
            >
              <span class="article-nav-direction">← 上一篇</span>
              <span class="article-nav-title">{prevPost.data.title}</span>
            </a>
          )
        }
        {
          nextPost && (
            <a
              href={`/blog/${nextPost.id.replace('zh/', '')}/`}
              class="article-nav-link article-nav-link--next"
            >
              <span class="article-nav-direction">下一篇 →</span>
              <span class="article-nav-title">{nextPost.data.title}</span>
            </a>
          )
        }
      </nav>
    </footer>
  </article>
  <MermaidInit />
  <script>
    import('../../scripts/copy-code.ts');

    document.addEventListener('DOMContentLoaded', () => {
      const content = document.getElementById('article-content');
      const skeleton = document.getElementById('article-skeleton');

      if (content && skeleton) {
        content.classList.add('hidden');
        skeleton.classList.remove('hidden');

        setTimeout(() => {
          skeleton.classList.add('hidden');
          content.classList.remove('hidden');
        }, 500);
      }
    });
  </script>
</BaseLayout>
