---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';
import OptimizedImage from '../../components/ui/OptimizedImage.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Divider from '../../components/global/Divider.astro';
import '../../styles/pages/blog.css';

const allPosts = (
  await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh')
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get all categories
const categories = [...new Set(allPosts.map(post => post.data.category))];

// Get all tags
const allTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];

// Get current filter from URL
const url = new URL(Astro.request.url);
const selectedCategory = url.searchParams.get('category') || '';
const selectedTag = url.searchParams.get('tag') || '';

// Filter posts
const filteredPosts = allPosts.filter(post => {
  const matchesCategory = !selectedCategory || post.data.category === selectedCategory;
  const matchesTag = !selectedTag || (post.data.tags && post.data.tags.includes(selectedTag));
  return matchesCategory && matchesTag;
});
---

<BaseLayout title="博客 — 祈研所 Qi-Lab" description="知识管理 × 项目管理 × IT/AI 技巧 × 八卦前沿">
  <div class="container blog-list-page">
    <!-- Page Hero -->
    <section class="page-hero" data-reveal>
      <span class="page-label">// BLOG</span>
      <h1 class="page-title">博客</h1>
      <p class="page-subtitle">知识管理 × 项目管理 × IT/AI 技巧 × 八卦前沿</p>
    </section>

    <Divider />

    <!-- Filter Section -->
    <section class="filter-section" data-reveal>
      <div class="filter-container">
        <!-- Category Filter -->
        <div class="filter-group">
          <h3 class="filter-title">分类</h3>
          <div class="filter-buttons">
            <a href="/blog/" class={`filter-btn ${!selectedCategory ? 'active' : ''}`}>全部</a>
            {categories.map(category => (
              <a 
                key={category} 
                href={`/blog/?category=${encodeURIComponent(category)}${selectedTag ? `&tag=${encodeURIComponent(selectedTag)}` : ''}`} 
                class={`filter-btn ${selectedCategory === category ? 'active' : ''}`}
              >
                {category}
              </a>
            ))}
          </div>
        </div>
        
        <!-- Tag Filter -->
        <div class="filter-group">
          <h3 class="filter-title">标签</h3>
          <div class="filter-buttons">
            <a href="/blog/" class={`filter-btn ${!selectedTag ? 'active' : ''}`}>全部</a>
            {allTags.map(tag => (
              <a 
                key={tag} 
                href={`/blog/?tag=${encodeURIComponent(tag)}${selectedCategory ? `&category=${encodeURIComponent(selectedCategory)}` : ''}`} 
                class={`filter-btn ${selectedTag === tag ? 'active' : ''}`}
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Blog List -->
    <section class="about-section" data-reveal>
      <SectionHeader label="// ARTICLES" title={selectedCategory || selectedTag ? `筛选结果` : `所有文章`} />
      <section class="blog-grid" aria-labelledby="blog-title">
        {
          filteredPosts.map((post) => (
            <a href={`/blog/${post.id.replace('zh/', '')}/`} class="blog-card" data-reveal>
              {post.data.heroImage && (
                <div class="blog-card-image">
                  <OptimizedImage
                    src={post.data.heroImage}
                    alt={post.data.title}
                    width={800}
                    height={450}
                    loading="lazy"
                    sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 400px"
                  />
                </div>
              )}
              <div class="blog-card-body">
                <span class="blog-card-category">{post.data.category}</span>
                <h2 class="blog-card-title">{post.data.title}</h2>
                <p class="blog-card-desc">{post.data.description}</p>
                <div class="blog-card-meta">
                  <time>
                    {post.data.pubDate.toLocaleDateString('zh-CN', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  <span class="blog-card-reading-time">{getReadingTime(post.body || '')}</span>
                </div>
              </div>
            </a>
          ))
        }
      </section>
    </section>
  </div>
</BaseLayout>
