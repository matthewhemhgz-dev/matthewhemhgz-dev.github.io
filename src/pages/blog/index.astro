---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="博客 — 祈研所 Qi-Lab" description="知识管理 × 项目管理 × IT/AI 技巧 × 八卦前沿">
  <main class="container blog-list-page" style="padding-top: 120px; padding-bottom: 80px;">
    <h1 style="font-family: var(--qi-font-serif); font-size: 2.5rem; margin-bottom: 2rem;">博客</h1>
    <div class="blog-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--qi-gap-bento);">
      {allPosts.map(post => (
        <a href={`/blog/${post.id.replace('zh/', '')}/`} class="blog-card" data-reveal style="
          display: block;
          background: var(--qi-surface-main);
          color: var(--qi-text-inverse);
          border-radius: var(--qi-radius-card);
          padding: 1.5rem;
          transition: transform var(--qi-transition), box-shadow var(--qi-transition);
          text-decoration: none;
        ">
          <span style="display: inline-block; background: var(--qi-brand-emerald); color: #fff; padding: 2px 10px; border-radius: var(--qi-radius-sm); font-size: 0.75rem; margin-bottom: 0.75rem;">
            {post.data.category}
          </span>
          <h2 style="font-family: var(--qi-font-serif); font-size: 1.25rem; margin-bottom: 0.5rem; line-height: 1.4;">
            {post.data.title}
          </h2>
          <p style="color: var(--qi-text-inverse); opacity: 0.7; font-size: 0.9rem; margin-bottom: 1rem; line-height: 1.6;">
            {post.data.description}
          </p>
          <div style="display: flex; justify-content: space-between; font-size: 0.8rem; opacity: 0.6;">
            <time>{post.data.pubDate.toDateString()}</time>
            <span>{post.data.tags.slice(0, 3).join(' · ')}</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--qi-shadow-hover-warm);
  }
</style>
