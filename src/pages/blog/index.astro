---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';
import OptimizedImage from '../../components/ui/OptimizedImage.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Divider from '../../components/global/Divider.astro';
import '../../styles/pages/blog.css';

const allPosts = (
  await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh')
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="博客 — 祈研所 Qi-Lab" description="知识管理 × 项目管理 × IT/AI 技巧 × 八卦前沿">
  <div class="container blog-list-page">
    <!-- Page Hero -->
    <section class="page-hero" data-reveal>
      <span class="page-label">// BLOG</span>
      <h1 class="page-title">博客</h1>
      <p class="page-subtitle">知识管理 × 项目管理 × IT/AI 技巧 × 八卦前沿</p>
    </section>

    <Divider />

    <!-- Blog List -->
    <section class="about-section" data-reveal>
      <SectionHeader label="// ARTICLES" title="所有文章" />
      <section class="blog-grid" aria-labelledby="blog-title">
        {
          allPosts.map((post) => (
            <a href={`/blog/${post.id.replace('zh/', '')}/`} class="blog-card" data-reveal>
              {post.data.heroImage && (
                <div class="blog-card-image">
                  <OptimizedImage
                    src={post.data.heroImage}
                    alt={post.data.title}
                    width={800}
                    height={450}
                    loading="lazy"
                    sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 400px"
                  />
                </div>
              )}
              <div class="blog-card-body">
                <span class="blog-card-category">{post.data.category}</span>
                <h2 class="blog-card-title">{post.data.title}</h2>
                <p class="blog-card-desc">{post.data.description}</p>
                <div class="blog-card-meta">
                  <time>
                    {post.data.pubDate.toLocaleDateString('zh-CN', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  <span class="blog-card-reading-time">{getReadingTime(post.body || '')}</span>
                </div>
              </div>
            </a>
          ))
        }
      </section>
    </section>
  </div>
</BaseLayout>
