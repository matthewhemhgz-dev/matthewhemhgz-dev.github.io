---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="博客 — 祈研所 Qi-Lab" description="知识管理 × 项目管理 × IT/AI 技巧 × 八卦前沿">
  <main class="container blog-list-page">
    <h1 class="blog-list-title">博客</h1>
    <div class="blog-grid">
      {allPosts.map(post => (
        <a href={`/blog/${post.id.replace('zh/', '')}/`} class="blog-card" data-reveal>
          <span class="blog-card-category">
            {post.data.category}
          </span>
          <h2 class="blog-card-title">
            {post.data.title}
          </h2>
          <p class="blog-card-desc">
            {post.data.description}
          </p>
          <div class="blog-card-meta">
            <time>{post.data.pubDate.toDateString()}</time>
            <span>{(post.data.tags || []).slice(0, 3).join(' · ')}</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .blog-list-page {
    padding-top: var(--qi-space-5xl);
    padding-bottom: var(--qi-space-xl);
  }

  .blog-list-title {
    font-family: var(--qi-font-serif);
    font-size: var(--qi-text-xl);
    margin-bottom: var(--qi-space-xl);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--qi-gap-bento);
  }

  .blog-card {
    display: block;
    background: var(--qi-surface-main);
    color: var(--qi-text-inverse);
    border-radius: var(--qi-radius-card);
    padding: var(--qi-container-padding);
    transition: transform var(--qi-transition), box-shadow var(--qi-transition);
    text-decoration: none;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--qi-shadow-hover-warm);
  }

  .blog-card-category {
    display: inline-block;
    background: var(--qi-brand-emerald);
    color: var(--qi-text-inverse);
    padding: 2px 10px;
    border-radius: var(--qi-radius-sm);
    font-size: var(--qi-text-xs);
    margin-bottom: 0.75rem;
  }

  .blog-card-title {
    font-family: var(--qi-font-serif);
    font-size: var(--qi-text-sm);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .blog-card-desc {
    color: var(--qi-text-inverse);
    opacity: 0.7;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .blog-card-meta {
    display: flex;
    justify-content: space-between;
    font-size: var(--qi-text-xs);
    opacity: 0.6;
  }

  /* === Responsive === */
  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }

    .blog-list-page {
      padding-top: var(--qi-space-3xl);
    }
  }

  /* === Large screen === */
  @media (min-width: 1440px) {
    .blog-list-title { font-size: var(--qi-text-2xl); }
    .blog-grid { gap: 32px; }
  }

  @media (min-width: 2560px) {
    .blog-list-title { font-size: var(--qi-text-3xl); }
    .blog-grid { gap: 40px; max-width: 1600px; margin-inline: auto; }
    .blog-card { padding: var(--qi-space-2xl); }
    .blog-card-title { font-size: var(--qi-text-xl); }
    .blog-card-desc { font-size: var(--qi-text-base); }
  }

  @media (min-width: 3440px) {
    .blog-grid { gap: 48px; max-width: 1920px; }
    .blog-card { padding: var(--qi-space-3xl); }
    .blog-card-title { font-size: var(--qi-text-2xl); }
    .blog-card-desc { font-size: var(--qi-text-lg); }
  }
</style>
