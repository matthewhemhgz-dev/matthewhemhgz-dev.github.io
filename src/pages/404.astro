---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/error.css';
---

<BaseLayout title="404 - 页面未找到 | 祈研所" description="您访问的页面不存在。">
  <div class="error-page">
    <div class="error-bg" aria-hidden="true">
      <div class="error-orb error-orb--1"></div>
      <div class="error-orb error-orb--2"></div>
    </div>
    <div class="error-content">
      <div class="error-badge">// 404</div>
      <span class="error-code">404</span>
      <h1 class="error-title">页面未找到</h1>
      <p class="error-message">
        抱歉，您访问的页面不存在或已被移除。<br />
        请检查 URL 是否正确，或返回首页探索更多内容。
      </p>
      <div class="error-actions">
        <a href="/" class="error-btn error-btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5" />
            <polyline points="12 19 5 12 12 5" />
          </svg>
          返回首页
        </a>
        <a href="/blog" class="error-btn error-btn--secondary">浏览博客</a>
      </div>
      <p class="error-hint">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px; margin-right: 6px;">
          <circle cx="12" cy="12" r="10" />
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
          <line x1="12" y1="17" x2="12.01" y2="17" />
        </svg>
        提示：试试从导航栏选择一个页面
      </p>
    </div>
  </div>
</BaseLayout>
