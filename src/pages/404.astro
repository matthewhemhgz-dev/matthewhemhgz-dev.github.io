---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面未找到 | 祈研所" description="您访问的页面不存在。">
  <div class="error-page">
    <div class="error-bg" aria-hidden="true">
      <div class="error-orb error-orb--1"></div>
      <div class="error-orb error-orb--2"></div>
    </div>
    <div class="error-content">
      <div class="error-badge">// 404</div>
      <span class="error-code">404</span>
      <h1 class="error-title">页面未找到</h1>
      <p class="error-message">
        抱歉，您访问的页面不存在或已被移除。<br />
        请检查 URL 是否正确，或返回首页探索更多内容。
      </p>
      <div class="error-actions">
        <a href="/" class="error-btn error-btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5" />
            <polyline points="12 19 5 12 12 5" />
          </svg>
          返回首页
        </a>
        <a href="/blog" class="error-btn error-btn--secondary">浏览博客</a>
      </div>
      <p class="error-hint">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px; margin-right: 6px;">
          <circle cx="12" cy="12" r="10" />
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
          <line x1="12" y1="17" x2="12.01" y2="17" />
        </svg>
        提示：试试从导航栏选择一个页面
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--qi-nav-height));
    padding: var(--qi-space-2xl);
    position: relative;
    overflow: hidden;
  }

  .error-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .error-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.3;
  }

  .error-orb--1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, var(--qi-brand-emerald-12), transparent 70%);
    top: -100px;
    right: -100px;
  }

  .error-orb--2 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, var(--qi-brand-amber-10), transparent 70%);
    bottom: -50px;
    left: -50px;
  }

  .error-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--qi-space-lg);
    position: relative;
    z-index: 1;
  }

  .error-badge {
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-xs);
    font-weight: 600;
    color: var(--qi-brand-emerald);
    letter-spacing: 0.12em;
    padding: var(--qi-space-xs) var(--qi-space-md);
    border: 1px solid var(--qi-brand-emerald-15);
    border-radius: var(--qi-radius-full);
    background: rgba(46, 125, 92, 0.04);
  }

  .error-code {
    font-family: var(--qi-font-serif);
    font-size: clamp(6rem, 15vw, 10rem);
    font-weight: 700;
    line-height: 1;
    color: var(--qi-text-primary);
    opacity: 0.06;
    position: relative;
    margin: var(--qi-space-sm) 0;
  }

  .error-code::after {
    content: '404';
    position: absolute;
    inset: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    background: linear-gradient(135deg, var(--qi-brand-emerald), var(--qi-brand-amber));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    opacity: 0.5;
  }

  .error-title {
    font-family: var(--qi-font-serif);
    font-size: var(--qi-text-3xl);
    font-weight: 600;
    color: var(--qi-text-primary);
    margin: 0;
  }

  .error-message {
    font-size: var(--qi-text-base);
    color: var(--qi-text-muted);
    line-height: 1.8;
    max-width: 420px;
    margin: 0;
  }

  .error-actions {
    display: flex;
    gap: var(--qi-space-md);
    margin-top: var(--qi-space-md);
  }

  .error-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--qi-space-sm);
    padding: 12px 28px;
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: var(--qi-radius-button);
    text-decoration: none;
    transition: all var(--qi-transition-base);
  }

  .error-btn--primary {
    background: var(--qi-text-primary);
    color: var(--qi-bg-base);
    box-shadow: var(--qi-shadow-md);
  }

  .error-btn--primary:hover {
    background: var(--qi-brand-emerald);
    transform: translateY(-2px);
    box-shadow: var(--qi-shadow-lg);
    color: var(--qi-bg-base);
  }

  .error-btn--primary:active {
    transform: scale(0.97);
  }

  .error-btn--secondary {
    background: transparent;
    color: var(--qi-text-primary);
    border: 1px solid var(--qi-base-15);
  }

  .error-btn--secondary:hover {
    border-color: var(--qi-brand-emerald);
    color: var(--qi-brand-emerald);
    transform: translateY(-2px);
  }

  .error-btn--secondary:active {
    transform: scale(0.97);
  }

  .error-hint {
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-xs);
    color: var(--qi-text-muted);
    margin-top: var(--qi-space-xl);
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .error-actions {
      flex-direction: column;
      width: 100%;
      max-width: 280px;
    }

    .error-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
