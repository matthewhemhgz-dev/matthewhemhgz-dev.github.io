---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeader from '../../../components/ui/SectionHeader.astro';
import { getCollection } from 'astro:content';
import '../../../styles/pages/tags.css';

const allPosts = (
  await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en')
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Calculate tag counts
const tagCounts = allPosts.flatMap(post => post.data.tags).reduce((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {});

// Sort tags by count (descending) and then alphabetically
const sortedTags = Object.entries(tagCounts)
  .sort(([tagA, countA], [tagB, countB]) => {
    if (countB !== countA) return countB - countA;
    return tagA.localeCompare(tagB);
  })
  .map(([tag, count]) => ({ tag, count }));

// Calculate min/max counts for size scaling
const counts = sortedTags.map(item => item.count);
const minCount = Math.min(...counts);
const maxCount = Math.max(...counts);

// Function to calculate font size based on count
function getFontSize(count) {
  if (maxCount === minCount) return 1;
  return 0.8 + (count - minCount) / (maxCount - minCount) * 0.6; // Range from 0.8 to 1.4
}
---

<BaseLayout
  title="Tags — Qi-Lab"
  description="Archive of all tags — Explore topics on AI, Knowledge Management, Frontend Development, and more."
>
  <div class="container tags-page">
    <h1 class="sr-only">Tags</h1>
    <!-- Tag Cloud Section -->
    <section class="tags-cloud-section" data-reveal>
      <SectionHeader label="// TAGS" title="Tags" />
      {
        sortedTags.length > 0 ? (
          <div class="tags-cloud">
            {sortedTags.map(({ tag, count }) => (
              <a 
                href={`/en/tags/${tag}/`} 
                class="tag-link"
                style={`font-size: ${getFontSize(count)}em;`}
                title={`${count} articles`}
              >
                #{tag} <span class="tag-count">({count})</span>
              </a>
            ))}
          </div>
        ) : (
          <p class="empty-text">No tags yet, coming soon...</p>
        )
      }
    </section>

    <!-- Recent Posts Section -->
    {
      allPosts.length > 0 && (
        <section class="tags-posts-section" data-reveal>
          <SectionHeader label="// RECENT" title="Recent Articles" />
          <div class="tags-posts-grid">
            {allPosts.map((post) => (
              <a href={`/en/blog/${post.id.replace('en/', '')}/`} class="tags-post-card">
                <div class="tags-post-meta">
                  <span class="tags-post-category">{post.data.category}</span>
                  <time class="tags-post-date">
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </time>
                </div>
                <h3 class="tags-post-title">{post.data.title}</h3>
                {post.data.description && <p class="tags-post-desc">{post.data.description}</p>}
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
