---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects, projectCategoriesEn } from '../../data/projects';
import ProjectCard from '../../components/ui/ProjectCard.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';

const allTags = [...new Set(projects.flatMap(p => p.tags))];
---

<BaseLayout title="Projects | Qi-Lab" description="Explore my technical practices and creative works">
  <div class="projects-page">
    <div class="container">
      <SectionHeader 
        title="Projects" 
        subtitle="Explore my technical practices and creative works" 
      />

      <div class="filter-container">
        <div class="filter-section">
          <span class="filter-label">Category</span>
          <div class="filter-group">
            {projectCategoriesEn.map((category) => (
              <button
                key={category}
                class="filter-btn"
                data-filter-type="category"
                data-filter-value={category}
              >
                {category}
              </button>
            ))}
          </div>
        </div>

        <div class="filter-section">
          <span class="filter-label">Tech Stack</span>
          <div class="filter-group tag-filters">
            <button
              class="filter-btn tag-btn active"
              data-filter-type="tag"
              data-filter-value="all"
            >
              All
            </button>
            {allTags.map((tag) => (
              <button
                key={tag}
                class="filter-btn tag-btn"
                data-filter-type="tag"
                data-filter-value={tag}
              >
                {tag}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div class="projects-grid">
        {projects.map((project) => (
          <ProjectCard project={project} lang="en" />
        ))}
      </div>

      <div class="empty-state" id="emptyState" style="display: none;">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <circle cx="12" cy="12" r="10" />
          <path d="M9.05 9a1 1 0 0 0 1.95-.15V4a1 1 0 0 0-1.95-.15C7.35 4.68 6 6.69 6 9c0 2.31 1.35 4.32 3.05 4.85A1 1 0 0 0 11 13V9a1 1 0 0 0-.95-.85Z" />
          <path d="M15 9a1 1 0 0 0-1.95.15V13a1 1 0 0 0 1.95.15C16.65 13.32 18 11.31 18 9c0-2.31-1.35-4.32-3.05-4.85A1 1 0 0 0 13 5V9a1 1 0 0 0 .95.85Z" />
        </svg>
        <p>No matching projects</p>
        <button class="reset-filter-btn">Reset Filters</button>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="projectModal">
    <div class="modal-content">
      <button class="modal-close" id="modalClose">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
      
      <div class="modal-body" id="modalBody">
      </div>
    </div>
  </div>

  <div class="image-overlay" id="imageOverlay">
    <button class="image-close" id="imageClose">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6 6 18" />
        <path d="m6 6 12 12" />
      </svg>
    </button>
    <div class="image-preview-container">
      <img id="previewImage" src="" alt="Project preview" />
    </div>
  </div>
</BaseLayout>

<style>
.projects-page {
  padding: var(--qi-space-5xl) 0 var(--qi-space-4xl);
  min-height: 60vh;
  background: linear-gradient(180deg, var(--qi-bg-base) 0%, var(--qi-bg-surface) 100%);
}

.container {
  max-width: var(--qi-container-max);
  margin: 0 auto;
  padding: 0 var(--qi-container-padding);
}

.filter-container {
  margin-bottom: var(--qi-space-3xl);
}

.filter-section {
  margin-bottom: var(--qi-space-lg);
}

.filter-label {
  display: inline-block;
  font-size: var(--qi-text-sm);
  font-weight: var(--qi-weight-semibold);
  color: var(--qi-text-secondary);
  margin-bottom: var(--qi-space-sm);
}

.filter-group {
  display: flex;
  flex-wrap: wrap;
  gap: var(--qi-space-sm);
}

.tag-filters {
  gap: var(--qi-space-xs);
}

.filter-btn {
  padding: var(--qi-space-sm) var(--qi-space-lg);
  background: transparent;
  border: 1px solid var(--qi-border-default);
  border-radius: var(--qi-radius-full);
  font-size: var(--qi-text-sm);
  color: var(--qi-text-secondary);
  cursor: pointer;
  transition: all var(--qi-transition);
}

.filter-btn:hover {
  background: var(--qi-brand-emerald-04);
  border-color: var(--qi-brand-emerald);
  color: var(--qi-brand-emerald);
}

.filter-btn.active {
  background: var(--qi-brand-emerald);
  border-color: var(--qi-brand-emerald);
  color: var(--qi-text-inverse);
}

.tag-btn {
  padding: var(--qi-space-xs) var(--qi-space-md);
  font-size: var(--qi-text-xs);
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: var(--qi-space-xl);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--qi-space-4xl) 0;
  color: var(--qi-text-muted);
}

.empty-state svg {
  margin-bottom: var(--qi-space-lg);
}

.empty-state p {
  margin-bottom: var(--qi-space-md);
}

.reset-filter-btn {
  padding: var(--qi-space-sm) var(--qi-space-lg);
  background: var(--qi-brand-emerald);
  border: none;
  border-radius: var(--qi-radius-full);
  font-size: var(--qi-text-sm);
  color: var(--qi-text-inverse);
  cursor: pointer;
  transition: all var(--qi-transition);
}

.reset-filter-btn:hover {
  opacity: 0.9;
  transform: translateY(-2px);
}

.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(8px);
  z-index: 1000;
  align-items: center;
  justify-content: center;
  padding: var(--qi-space-xl);
}

.modal-overlay.active {
  display: flex;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  position: relative;
  background: var(--qi-bg-surface);
  border-radius: var(--qi-radius-card);
  max-width: 600px;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { 
    opacity: 0;
    transform: translateY(20px);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-close {
  position: absolute;
  top: var(--qi-space-md);
  right: var(--qi-space-md);
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--qi-surface-sub);
  border: none;
  border-radius: 50%;
  color: var(--qi-text-secondary);
  cursor: pointer;
  z-index: 10;
  transition: all var(--qi-transition);
}

.modal-close:hover {
  background: var(--qi-border-default);
  color: var(--qi-text-primary);
}

.modal-body {
  padding: var(--qi-space-xl);
}

.modal-body .project-image-wrapper {
  cursor: pointer;
}

.modal-body .project-content {
  padding: 0;
}

.modal-body .project-title {
  font-size: var(--qi-text-xl);
  margin-bottom: var(--qi-space-md);
}

.modal-body .project-description {
  font-size: var(--qi-text-base);
  line-height: 1.8;
  margin-bottom: var(--qi-space-xl);
}

.modal-body .project-tags {
  margin-bottom: var(--qi-space-xl);
}

.modal-links {
  display: flex;
  gap: var(--qi-space-md);
  flex-wrap: wrap;
}

.modal-link {
  display: inline-flex;
  align-items: center;
  gap: var(--qi-space-xs);
  padding: var(--qi-space-sm) var(--qi-space-lg);
  background: var(--qi-brand-emerald);
  border-radius: var(--qi-radius-full);
  color: var(--qi-text-inverse);
  text-decoration: none;
  font-size: var(--qi-text-sm);
  font-weight: var(--qi-weight-semibold);
  transition: all var(--qi-transition);
}

.modal-link:hover {
  opacity: 0.9;
  transform: translateY(-2px);
}

.modal-link.secondary {
  background: var(--qi-surface-sub);
  color: var(--qi-text-primary);
}

.modal-link.secondary:hover {
  background: var(--qi-border-default);
}

.image-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.9);
  backdrop-filter: blur(8px);
  z-index: 1100;
  align-items: center;
  justify-content: center;
  padding: var(--qi-space-xl);
}

.image-overlay.active {
  display: flex;
}

.image-close {
  position: absolute;
  top: var(--qi-space-xl);
  right: var(--qi-space-xl);
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border: none;
  border-radius: 50%;
  color: white;
  cursor: pointer;
  transition: all var(--qi-transition);
}

.image-close:hover {
  background: rgba(255, 255, 255, 0.2);
}

.image-preview-container {
  max-width: 90vw;
  max-height: 90vh;
}

.image-preview-container img {
  max-width: 100%;
  max-height: 90vh;
  object-fit: contain;
  border-radius: var(--qi-radius-lg);
  box-shadow: var(--qi-shadow-xl);
}

@media (max-width: 768px) {
  .projects-page {
    padding: var(--qi-space-3xl) 0 var(--qi-space-2xl);
  }

  .projects-grid {
    grid-template-columns: 1fr;
    gap: var(--qi-space-lg);
  }

  .filter-btn {
    padding: var(--qi-space-xs) var(--qi-space-md);
    font-size: var(--qi-text-xs);
  }

  .filter-group {
    gap: var(--qi-space-xs);
  }

  .modal-content {
    margin: var(--qi-space-md);
    padding: var(--qi-space-lg);
    max-height: 90vh;
  }

  .modal-body {
    padding: var(--qi-space-lg);
  }

  .image-close {
    top: var(--qi-space-lg);
    right: var(--qi-space-lg);
    width: 40px;
    height: 40px;
  }
}

@media (min-width: 1440px) {
  .projects-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: var(--qi-space-2xl);
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const filterBtns = document.querySelectorAll('.filter-btn');
  const projectCards = document.querySelectorAll('.project-card');
  const emptyState = document.getElementById('emptyState');
  const resetBtn = document.querySelector('.reset-filter-btn');
  
  let currentCategory = 'All';
  let currentTag = 'all';

  const categoryAllBtn = document.querySelector('[data-filter-type="category"][data-filter-value="All"]');
  const tagAllBtn = document.querySelector('[data-filter-type="tag"][data-filter-value="all"]');
  if (categoryAllBtn) categoryAllBtn.classList.add('active');

  const filterProjects = () => {
    let visibleCount = 0;
    
    projectCards.forEach((card) => {
      const cardCategory = card.dataset.category;
      const cardTags = card.dataset.tags.split(',');
      
      const categoryMatch = currentCategory === 'All' || cardCategory === currentCategory;
      const tagMatch = currentTag === 'all' || cardTags.includes(currentTag);
      
      if (categoryMatch && tagMatch) {
        card.style.display = 'block';
        setTimeout(() => {
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
        }, 50);
        visibleCount++;
      } else {
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        setTimeout(() => {
          card.style.display = 'none';
        }, 300);
      }
    });
    
    emptyState.style.display = visibleCount === 0 ? 'flex' : 'none';
  };

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filterType = btn.dataset.filterType;
      const filterValue = btn.dataset.filterValue;
      
      filterBtns.forEach((b) => {
        if (b.dataset.filterType === filterType) {
          b.classList.remove('active');
        }
      });
      
      btn.classList.add('active');
      
      if (filterType === 'category') {
        currentCategory = filterValue;
      } else {
        currentTag = filterValue;
      }
      
      filterProjects();
    });
  });

  resetBtn.addEventListener('click', () => {
    currentCategory = 'All';
    currentTag = 'all';
    
    filterBtns.forEach((btn) => btn.classList.remove('active'));
    if (categoryAllBtn) categoryAllBtn.classList.add('active');
    if (tagAllBtn) tagAllBtn.classList.add('active');
    
    filterProjects();
  });

  const modalOverlay = document.getElementById('projectModal');
  const modalBody = document.getElementById('modalBody');
  const modalClose = document.getElementById('modalClose');
  const detailBtns = document.querySelectorAll('.detail-btn');

  const projectsData = [
    { id: 'qi-lab', title: 'Qi-Lab', description: 'A personal knowledge lab exploring the intersection of technology, design, and creativity', category: 'Personal Projects', tags: ['Astro', 'TypeScript', 'CSS', 'PWA'], image: '/images/projects/qi-lab.png', url: '/', github: 'https://github.com/matthewhemhgz-dev/matthewhemhgz-dev.github.io', year: 2024 },
    { id: 'knowledge-graph', title: 'Knowledge Graph', description: 'Personal knowledge graph system based on Neo4j with visualization and relationship analysis', category: 'Data Visualization', tags: ['Neo4j', 'D3.js', 'GraphQL'], image: '/images/projects/knowledge-graph.png', url: '/blog/knowledge-graph-visualization', year: 2024 },
    { id: 'design-system', title: 'Design System', description: 'Design system built from scratch with design tokens, component library, and style guidelines', category: 'Design System', tags: ['Design Tokens', 'CSS', 'Component Library'], image: '/images/projects/design-system.png', url: '/blog/design-system-from-scratch', year: 2024 },
    { id: 'ai-assistant', title: 'AI Assistant', description: 'AI assistant based on Claude API with multimodal interaction and knowledge retrieval', category: 'AI Applications', tags: ['AI', 'Claude', 'API', 'RAG'], image: '/images/projects/ai-assistant.png', url: '/blog/ai-era-knowledge-worker', year: 2025 },
    { id: 'zettelkasten', title: 'Zettelkasten System', description: 'Personal knowledge management system based on bidirectional links implementing Zettelkasten method', category: 'Knowledge Management', tags: ['Obsidian', 'Notion', 'Second Brain'], image: '/images/projects/zettelkasten.png', url: '/blog/zettelkasten-practical-guide', year: 2024 },
    { id: 'performance', title: 'Performance Optimization', description: 'Frontend performance optimization project with resource compression, lazy loading, code splitting', category: 'Performance Engineering', tags: ['Performance', 'Optimization', 'Lighthouse'], image: '/images/projects/performance.png', url: '/blog/how-to-optimize-frontend-performance', year: 2024 }
  ];

  const openModal = (projectId) => {
    const project = projectsData.find(p => p.id === projectId);
    if (!project) return;
    
    const tagsHtml = project.tags.map(tag => `<span class="project-tag">${tag}</span>`).join('');
    
    modalBody.innerHTML = `
      <div class="project-image-wrapper">
        <img src="${project.image}" alt="${project.title}" class="project-image" style="width: 100%; height: auto; aspect-ratio: 16/10; object-fit: cover; border-radius: var(--qi-radius-lg);" />
      </div>
      <div class="project-content">
        <div class="project-category">
          <span class="project-category-tag">${project.category}</span>
        </div>
        <h3 class="project-title">${project.title}</h3>
        <p class="project-description">${project.description}</p>
        <div class="project-tags">${tagsHtml}</div>
        <div class="project-meta">
          <span class="project-year">${project.year}</span>
        </div>
        <div class="modal-links">
          ${project.url ? '<a href="' + project.url + '" class="modal-link" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 6H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg> Demo</a>' : ''}
          ${project.github ? '<a href="' + project.github + '" class="modal-link secondary" target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /><path d="M21 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg> GitHub</a>' : ''}
        </div>
      </div>
    `;
    
    modalOverlay.classList.add('active');
    document.body.style.overflow = 'hidden';
    
    const modalImage = modalBody.querySelector('.project-image-wrapper');
    if (modalImage) {
      modalImage.addEventListener('click', () => {
        openImagePreview(project.image);
      });
    }
  };

  const closeModal = () => {
    modalOverlay.classList.remove('active');
    document.body.style.overflow = '';
  };

  detailBtns.forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const projectId = btn.dataset.projectId;
      openModal(projectId);
    });
  });

  modalClose.addEventListener('click', closeModal);
  modalOverlay.addEventListener('click', (e) => {
    if (e.target === modalOverlay) {
      closeModal();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modalOverlay.classList.contains('active')) {
      closeModal();
    }
  });

  const imageOverlay = document.getElementById('imageOverlay');
  const imageClose = document.getElementById('imageClose');
  const previewImage = document.getElementById('previewImage');
  
  const openImagePreview = (src) => {
    previewImage.src = src;
    imageOverlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  };

  const closeImagePreview = () => {
    imageOverlay.classList.remove('active');
    document.body.style.overflow = '';
  };

  const projectImages = document.querySelectorAll('.project-image-wrapper');
  projectImages.forEach((wrapper) => {
    wrapper.addEventListener('click', (e) => {
      if (!e.target.closest('.overlay-link')) {
        const img = wrapper.querySelector('img');
        if (img) {
          openImagePreview(img.src);
        }
      }
    });
  });

  imageClose.addEventListener('click', closeImagePreview);
  imageOverlay.addEventListener('click', (e) => {
    if (e.target === imageOverlay) {
      closeImagePreview();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && imageOverlay.classList.contains('active')) {
      closeImagePreview();
    }
  });
});
</script>