---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Divider from '../../components/global/Divider.astro';
---

<BaseLayout title="About | Qi-Lab" description="Learn about Qi-Lab's brand story, philosophy, and how to get in touch." lang="en">
  <div class="about-page">
    <div class="container">

      <!-- Page Hero -->
      <section class="page-hero" data-reveal>
        <span class="page-label">// ABOUT</span>
        <h1 class="page-title">About Qi-Lab</h1>
        <p class="page-subtitle">
          A personal brand at the intersection of technology, design, and creativity
        </p>
      </section>

      <Divider />

      <!-- Brand Story -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// STORY" title="Brand Story" />
        <div class="prose">
          <p>
            The name Qi-Lab comes from the meaning behind two Chinese characters &mdash; "Qi" (&#31169;)
            represents a yearning for all things beautiful, while "Yan" (&#30740;) stands for a relentless
            exploration of technical depth. Together, they form a creative laboratory devoted to finding
            balance between code and aesthetics.
          </p>
          <p>
            Here, we are never satisfied with code that merely runs. Every line carries a pursuit of elegance,
            and every design decision is carefully considered. From pixel-level visual polish to system-level
            architectural thinking, Qi-Lab consistently upholds a craftsman spirit of continuous refinement.
          </p>
          <p>
            We believe that technology is not a cold tool, but a medium for expressing creativity.
            A great engineer is also a great artist &mdash; they draw blueprints with code and weave dreams
            with logic. Qi-Lab is a practitioner of this very philosophy.
          </p>
        </div>
      </section>

      <Divider />

      <!-- Philosophy -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// PHILOSOPHY" title="Design Philosophy" />
        <div class="philosophy-grid">
          <div class="philosophy-card">
            <span class="philosophy-number">01</span>
            <h3 class="philosophy-title">Warm Physicality</h3>
            <p class="philosophy-desc">
              The heart of the Amber Geek design system. An oat-gray base evokes the warmth of paper,
              and every interaction carries the texture and warmth of the physical world.
            </p>
          </div>
          <div class="philosophy-card">
            <span class="philosophy-number">02</span>
            <h3 class="philosophy-title">Restrained Aesthetics</h3>
            <p class="philosophy-desc">
              Code is more than functional implementation &mdash; it is a form of creative expression.
              We pursue the unity of readability, maintainability, and beauty.
            </p>
          </div>
          <div class="philosophy-card">
            <span class="philosophy-number">03</span>
            <h3 class="philosophy-title">Lasting Value</h3>
            <p class="philosophy-desc">
              Technology evolves constantly, and learning never ends. Stay curious,
              embrace new technologies, and grow continuously through practice.
            </p>
          </div>
        </div>
      </section>

      <Divider />

      <!-- Contact CTA -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// CONTACT" title="Get in Touch" />
        <div class="contact-cta">
          <p class="cta-text">
            Whether it's technical collaboration, project consulting, or simply a conversation about
            technology and design, feel free to reach out to Qi-Lab through the channels below.
          </p>
          <div class="cta-links">
            <a href="mailto:hello@qi-lab.dev" class="cta-link">
              <span class="cta-label">Email</span>
              <span class="cta-value">hello@qi-lab.dev</span>
            </a>
            <div class="cta-link">
              <span class="cta-label">WeChat</span>
              <span class="cta-value">QiLab_Studio</span>
            </div>
          </div>
          <a href="/en/#contact" class="cta-btn">View Full Contact Info</a>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    padding-top: var(--qi-nav-height);
  }

  /* --- Page Hero --- */
  .page-hero {
    padding: var(--qi-space-5xl) 0 var(--qi-space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--qi-space-md);
  }

  .page-label {
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-sm);
    color: var(--qi-brand-emerald);
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  .page-title {
    font-family: var(--qi-font-serif);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--qi-text-primary);
    line-height: 1.2;
  }

  .page-subtitle {
    font-size: var(--qi-text-lg);
    color: var(--qi-text-muted);
    line-height: 1.7;
  }

  /* --- About Sections --- */
  .about-section {
    padding: var(--qi-space-3xl) 0;
  }

  /* --- Prose --- */
  .prose {
    display: flex;
    flex-direction: column;
    gap: var(--qi-space-lg);
    max-width: var(--qi-content-width);
  }

  .prose p {
    font-size: var(--qi-text-lg);
    color: var(--qi-text-secondary);
    line-height: 1.9;
  }

  /* --- Philosophy --- */
  .philosophy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--qi-space-xl);
  }

  .philosophy-card {
    padding: var(--qi-space-2xl);
    background: rgba(42, 42, 42, 0.02);
    border: 1px solid rgba(42, 42, 42, 0.06);
    border-radius: var(--qi-radius-lg);
    transition: all var(--qi-transition-base);
  }

  .philosophy-card:hover {
    background: rgba(42, 42, 42, 0.03);
    box-shadow: var(--qi-shadow-md);
    transform: translateY(-4px);
  }

  .philosophy-number {
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-xs);
    color: var(--qi-amber);
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .philosophy-title {
    font-family: var(--qi-font-serif);
    font-size: var(--qi-text-xl);
    font-weight: 600;
    color: var(--qi-text-primary);
    margin-top: var(--qi-space-md);
    margin-bottom: var(--qi-space-sm);
  }

  .philosophy-desc {
    font-size: var(--qi-text-sm);
    color: var(--qi-text-muted);
    line-height: 1.8;
  }

  /* --- Contact CTA --- */
  .contact-cta {
    display: flex;
    flex-direction: column;
    gap: var(--qi-space-xl);
    max-width: var(--qi-content-width);
  }

  .cta-text {
    font-size: var(--qi-text-lg);
    color: var(--qi-text-secondary);
    line-height: 1.8;
  }

  .cta-links {
    display: flex;
    gap: var(--qi-space-xl);
    flex-wrap: wrap;
  }

  .cta-link {
    display: flex;
    flex-direction: column;
    gap: var(--qi-space-xs);
  }

  .cta-label {
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-xs);
    color: var(--qi-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .cta-value {
    font-size: var(--qi-text-lg);
    color: var(--qi-text-primary);
    font-weight: 500;
  }

  a.cta-link .cta-value {
    color: var(--qi-brand-emerald);
    transition: color var(--qi-transition-fast);
  }

  a.cta-link:hover .cta-value {
    color: var(--qi-emerald-dark);
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 12px 28px;
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--qi-bg-base);
    background: var(--qi-text-primary);
    border-radius: var(--qi-radius-md);
    text-decoration: none;
    box-shadow: var(--qi-shadow-md);
    transition: all var(--qi-transition-base);
  }

  .cta-btn:hover {
    background: var(--qi-brand-emerald);
    transform: translateY(-2px);
    box-shadow: var(--qi-shadow-lg);
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .philosophy-grid {
      grid-template-columns: 1fr;
    }

    .cta-links {
      flex-direction: column;
      gap: var(--qi-space-lg);
    }
  }
</style>
