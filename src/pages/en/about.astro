---
import '../../styles/sections/about.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Divider from '../../components/global/Divider.astro';
---

<BaseLayout
  title="About | Qi-Lab"
  description="Learn about Qi-Lab's brand story, philosophy, and contact information."
>
  <div class="about-page">
    <div class="container">
      <!-- Page Hero -->
      <section class="page-hero" data-reveal>
        <span class="page-label">// ABOUT</span>
        <h1 class="page-title">About Qi-Lab</h1>
        <p class="page-subtitle">A personal brand focused on technology, design, and creativity</p>
      </section>

      <Divider />

      <!-- Brand Story -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// STORY" title="Brand Story" />
        <div class="about-prose">
          <p>
            Qi-Lab is my digital archive. The name "Qi" (祈) represents a persistent pursuit of
            systematic organization, while "Yan" (研) — from our original Chinese name — signifies
            the rigorous exploration of technical depth. In an era of information overload, I
            believe that structured knowledge is the true source of power. Here, we don't trade in
            anxiety or quick fixes, but instead document real pitfalls and battle-tested
            experiences.
          </p>
          <p>
            I focus on four intersecting areas: knowledge management, project management, IT/AI
            skills, and cutting-edge exploration. In daily practice, I use Obsidian to build knowledge
            graphs based on Bloom's six-layer cognitive model, Markdown + Git to maintain a single
            source of truth documentation system, and AI Agents to drive
            development and content production pipelines. Every share is verified through actual
            use.
          </p>
          <p>
            As a senior information systems project management professional with 7 hard
            certifications including PMP, ITIL, and CCNP, I deeply understand that "hoarding is not
            management, choosing to slow down is itself a form of resistance". From the
            zero-new-feature refactoring of SystemPM, to the data pipeline reconstruction of
            StockAAssist, to the ground-up construction of the QiLab knowledge base — each time is a
            practice of the engineering philosophy of "systematic root cause rather than patching".
          </p>
        </div>
      </section>

      <Divider />

      <!-- History & Vision -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// JOURNEY" title="Brand Journey & Vision" />
        <div class="history-vision">
          <div class="history-card">
            <h3 class="history-title">📅 Brand Journey</h3>
            <div class="timeline">
              <div class="timeline-item">
                <span class="timeline-year">2024</span>
                <h4 class="timeline-event">Qi-Lab Founded</h4>
                <p class="timeline-desc">Starting from an idea for personal knowledge management, gradually building a complete website and content system</p>
              </div>
              <div class="timeline-item">
                <span class="timeline-year">2024</span>
                <h4 class="timeline-event">Design System Takes Shape</h4>
                <p class="timeline-desc">Building Qi-Lab visual design system from scratch, establishing oat gray, emerald, and amber gold brand colors</p>
              </div>
              <div class="timeline-item">
                <span class="timeline-year">2025</span>
                <h4 class="timeline-event">AI Workflow Integration</h4>
                <p class="timeline-desc">Deeply integrating AI technology into content production and development processes to improve efficiency and quality</p>
              </div>
              <div class="timeline-item">
                <span class="timeline-year">Future</span>
                <h4 class="timeline-event">Continuous Evolution</h4>
                <p class="timeline-desc">Maintaining focus on cutting-edge technologies, continuously improving the knowledge system, and empowering more creators</p>
              </div>
            </div>
          </div>
          <div class="vision-card">
            <h3 class="vision-title">🚀 Mission & Vision</h3>
            <div class="vision-content">
              <div class="vision-item">
                <h4 class="vision-item-title">Mission</h4>
                <p class="vision-item-desc">Making knowledge more powerful, giving direction to creativity</p>
              </div>
              <div class="vision-item">
                <h4 class="vision-item-title">Vision</h4>
                <p class="vision-item-desc">Becoming a hub where technology and creativity converge, helping people build systematic knowledge systems</p>
              </div>
              <div class="vision-item">
                <h4 class="vision-item-title">Commitment</h4>
                <p class="vision-item-desc">Only sharing verified experiences, not creating anxiety, not pursuing traffic shortcuts</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <Divider />

      <!-- Core Values -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// VALUES" title="Core Values" />
        <div class="values-grid">
          <div class="value-card">
            <div class="value-icon">🧠</div>
            <h3 class="value-title">Systematic Thinking</h3>
            <p class="value-desc">Rejecting patchwork solutions, pursuing systematic approaches from root causes</p>
          </div>
          <div class="value-card">
            <div class="value-icon">📝</div>
            <h3 class="value-title">Authentic Verification</h3>
            <p class="value-desc">Every tool recommendation comes from actual use, every technical viewpoint from real projects</p>
          </div>
          <div class="value-card">
            <div class="value-icon">🌱</div>
            <h3 class="value-title">Long-termism</h3>
            <p class="value-desc">Slow is fast, maintaining patience and persistence on the path of knowledge accumulation</p>
          </div>
          <div class="value-card">
            <div class="value-icon">🎨</div>
            <h3 class="value-title">Engineering Aesthetics</h3>
            <p class="value-desc">Code and design should not only work but be elegant, maintainable, and beautiful</p>
          </div>
          <div class="value-card">
            <div class="value-icon">🤖</div>
            <h3 class="value-title">Human-AI Collaboration</h3>
            <p class="value-desc">Embracing AI technology while upholding human values of creativity and judgment</p>
          </div>
          <div class="value-card">
            <div class="value-icon">💡</div>
            <h3 class="value-title">Open Sharing</h3>
            <p class="value-desc">Knowledge needs to flow, experiences are worth sharing, growing together on the journey</p>
          </div>
        </div>
      </section>

      <Divider />

      <!-- Philosophy -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// PHILOSOPHY" title="Design Philosophy" />
        <div class="philosophy-grid">
          <div class="philosophy-card">
            <span class="philosophy-number">01</span>
            <h3 class="philosophy-title">Qi-Lab Visual Philosophy</h3>
            <p class="philosophy-desc">
              A visual philosophy designed for workers at their desks late at night. The oat gray
              background is like warm paper, the emerald cursor flickers with rational light, and
              the amber gold desk lamp casts warm companionship. Core metaphor: a study with a desk
              lamp on late at night. Pursue a clear, comfortable, breathable visual environment,
              using low cognitive load design to offset the mental consumption of high-density
              information.
            </p>
          </div>
          <div class="philosophy-card">
            <span class="philosophy-number">02</span>
            <h3 class="philosophy-title">Engineering Aesthetics & Functional Isolation</h3>
            <p class="philosophy-desc">
              Code is not just a functional implementation, but also a systematic expression. CSS
              design tokens build a complete Qi-Lab visual system, fonts strictly divided into three
              categories (serif for titles → scholarly feel, sans-serif for body → clarity,
              monospace for code → geeky feel), Bento Grid with 24px spacing ensures spatial order.
              Readability, maintainability, and aesthetics are all essential.
            </p>
          </div>
          <div class="philosophy-card">
            <span class="philosophy-number">03</span>
            <h3 class="philosophy-title">Long-termism & Systematic Thinking</h3>
            <p class="philosophy-desc">
              Rather than chasing viral growth, we embrace the "endurance phase" of building from 0
              to 100. Every tool recommendation is validated through daily use, and every technical
              viewpoint stems from real project friction. In an age where AI can generate anything,
              human judgment and creativity become even more precious. Every share is a proof of
              authentic intent.
            </p>
          </div>
        </div>
      </section>

      <Divider />

      <!-- Tech Stack -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// TECH" title="Tech Stack" />
        <div class="tech-stack">
          <div class="tech-category">
            <h3 class="tech-category-title">Frontend Development</h3>
            <div class="tech-tags">
              <span class="tech-tag">Astro</span>
              <span class="tech-tag">TypeScript</span>
              <span class="tech-tag">React</span>
              <span class="tech-tag">CSS Custom Properties</span>
              <span class="tech-tag">Tailwind CSS</span>
              <span class="tech-tag">PWA</span>
            </div>
          </div>
          <div class="tech-category">
            <h3 class="tech-category-title">Knowledge Management</h3>
            <div class="tech-tags">
              <span class="tech-tag">Obsidian</span>
              <span class="tech-tag">Notion</span>
              <span class="tech-tag">Markdown</span>
              <span class="tech-tag">Git</span>
              <span class="tech-tag">Neo4j</span>
              <span class="tech-tag">D3.js</span>
            </div>
          </div>
          <div class="tech-category">
            <h3 class="tech-category-title">AI & Automation</h3>
            <div class="tech-tags">
              <span class="tech-tag">Claude API</span>
              <span class="tech-tag">AI Agents</span>
              <span class="tech-tag">Superpowers</span>
              <span class="tech-tag">OpenClaw</span>
              <span class="tech-tag">RAG</span>
              <span class="tech-tag">Prompt Engineering</span>
            </div>
          </div>
          <div class="tech-category">
            <h3 class="tech-category-title">Project Management</h3>
            <div class="tech-tags">
              <span class="tech-tag">PMP</span>
              <span class="tech-tag">ITIL</span>
              <span class="tech-tag">SystemPM</span>
              <span class="tech-tag">Agile</span>
              <span class="tech-tag">DevOps</span>
              <span class="tech-tag">Data-Driven</span>
            </div>
          </div>
        </div>
      </section>

      <Divider />

      <!-- Contact CTA -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// CONTACT" title="Get in Touch" />
        <div class="contact-cta">
          <p class="cta-text">
            Whether it's knowledge management exchange, AI workflow discussion, or project
            cooperation, feel free to contact us anytime.
          </p>
          <div class="cta-links">
            <a href="mailto:matthewhemhgz@gmail.com" class="cta-link">
              <span class="cta-label">Email</span>
              <span class="cta-value">matthewhemhgz@gmail.com</span>
            </a>
            <div class="cta-link">
              <span class="cta-label">WeChat</span>
              <span class="cta-value">Qi-Lab</span>
            </div>
            <div class="cta-link">
              <span class="cta-label">GitHub</span>
              <span class="cta-value">matthewhemhgz-dev</span>
            </div>
          </div>
          <a href="/en#contact" class="cta-btn">View Full Contact Information</a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
