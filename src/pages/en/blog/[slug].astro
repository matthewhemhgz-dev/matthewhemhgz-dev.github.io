---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { getReadingTime } from '../../../utils/reading-time';
import OptimizedImage from '../../../components/ui/OptimizedImage.astro';
import MermaidInit from '../../../components/global/MermaidInit.astro';
import Skeleton from '../../../components/ui/Skeleton.astro';
import GenerativeArt from '../../../components/ui/GenerativeArt.astro';
import '../../../styles/sections/article.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en');
  return posts.map((post, index) => ({
    params: { slug: post.id.replace('en/', '') },
    props: {
      post,
      prevPost: index > 0 ? posts[index - 1] : null,
      nextPost: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body || '');

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://matthewhemhgz-dev.github.io';
const articleUrl = `${siteUrl}/en/blog/${post.id.replace('en/', '')}/`;
const ogImage = post.data.heroImage ? `${siteUrl}${post.data.heroImage}` : '/og-default.png';

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  url: articleUrl,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate || post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author || 'Qi-Lab',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Qi-Lab',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/logo.svg`,
    },
  },
  inLanguage: 'en-US',
  ...(post.data.tags?.length > 0 && {
    keywords: post.data.tags.join(', '),
  }),
};
---

<BaseLayout
  title={`${post.data.title} — Qi-Lab`}
  description={post.data.description}
  ogImage={ogImage}
  ogType="article"
  pubDate={post.data.pubDate.toISOString()}
  modDate={(post.data.updatedDate || post.data.pubDate).toISOString()}
  jsonLd={articleJsonLd}
>
  <article class="article-container">
    <a href="/en/blog" class="article-back">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"
        ><path
          d="M10 3L5 8l5 5"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path></svg
      >
      <span>Back to List</span>
    </a>

    <header class="article-header">
      {
        post.data.heroImage && (
          <div class="article-hero-image">
            <OptimizedImage
              src={post.data.heroImage}
              alt={post.data.title}
              width={1200}
              height={675}
              loading="eager"
            />
          </div>
        )
      }
      <div class="article-meta-top">
        <span class="article-category">{post.data.category}</span>
        <time class="article-date"
          >{
            post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }</time
        >
        <span class="article-reading-time">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"
            ><path
              d="M8 1a7 7 0 100 14A7 7 0 008 1zm0 1.5a5.5 5.5 0 110 11 5.5 5.5 0 010-11zM8.25 4.5v3.75l2.5 1.5-.75 1.25-3.25-1.95V4.5h1.5z"
              fill="currentColor"></path></svg
          >
          {readingTime}
        </span>
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      {post.data.description && <p class="article-description">{post.data.description}</p>}
      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="article-tags">
            {post.data.tags.map((tag) => (
              <a href={`/en/tags/${tag}/`} class="article-tag">
                #{tag}
              </a>
            ))}
          </div>
        )
      }
      <div class="article-divider"></div>
    </header>

    <!-- Generative Art Component -->
    <GenerativeArt />

    {
      headings.length > 0 && (
        <nav class="toc">
          <div class="toc-header">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M4 2h8M4 8h8M4 14h5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
              />
            </svg>
            <span>Content</span>
          </div>
          <ul class="toc-list">
            {headings
              .filter((h) => h.depth <= 3)
              .map((h) => (
                <li class={`toc-item toc-item--depth-${h.depth}`}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
          </ul>
        </nav>
      )
    }

    <div class="prose">
      <div id="article-content">
        <Content />
      </div>
      <div id="article-skeleton" class="hidden">
        <Skeleton type="heading" width="80%" height="32px" />
        <Skeleton type="paragraph" count="5" />
        <Skeleton type="image" width="100%" />
        <Skeleton type="paragraph" count="3" />
      </div>
    </div>

    <footer class="article-footer">
      <div class="article-divider"></div>
      <div class="article-footer-content">
        <span class="article-footer-label">— Qi-Lab —</span>
        <p class="article-footer-hint">If this article helps you, feel free to share it.</p>
        <div class="article-share">
          <span class="article-share-label">Share:</span>
          <div class="article-share-buttons">
            <a
              href={`https://x.com/intent/tweet?url=${encodeURIComponent(articleUrl)}&text=${encodeURIComponent(post.data.title)}&via=qilab_dev`}
              class="article-share-btn"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Share on X"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              <span>X</span>
            </a>
            <button class="article-share-btn article-share-wechat" aria-label="Share on WeChat">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <path
                  d="M15 11.5a3.5 3.5 0 1 1-7 0"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              <span>WeChat</span>
              <div class="article-share-wechat-qr">
                <div class="article-share-wechat-qr-code">
                  <img
                    src={`https://api.qrserver.com/v1/create-qr-code/?size=128x128&data=${encodeURIComponent(articleUrl)}`}
                    alt="WeChat share QR code"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <span>Scan to share</span>
              </div>
            </button>
            <button class="article-share-btn article-share-copy" aria-label="Copy Link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect
                  x="9"
                  y="9"
                  width="13"
                  height="13"
                  rx="2"
                  ry="2"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></rect>
                <path
                  d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              <span>Copy</span>
            </button>
          </div>
        </div>
      </div>
      <nav class="article-nav">
        {
          prevPost && (
            <a
              href={`/en/blog/${prevPost.id.replace('en/', '')}/`}
              class="article-nav-link article-nav-link--prev"
            >
              <span class="article-nav-direction">← Prev</span>
              <span class="article-nav-title">{prevPost.data.title}</span>
            </a>
          )
        }
        {
          nextPost && (
            <a
              href={`/en/blog/${nextPost.id.replace('en/', '')}/`}
              class="article-nav-link article-nav-link--next"
            >
              <span class="article-nav-direction">Next →</span>
              <span class="article-nav-title">{nextPost.data.title}</span>
            </a>
          )
        }
      </nav>
    </footer>
  </article>
  <MermaidInit />
  <script>
    // 动态导入复制代码功能
    import('../../../scripts/copy-code.ts');

    // 骨架屏逻辑
    document.addEventListener('DOMContentLoaded', () => {
      const content = document.getElementById('article-content');
      const skeleton = document.getElementById('article-skeleton');

      if (content && skeleton) {
        // 初始显示骨架屏
        content.classList.add('hidden');
        skeleton.classList.remove('hidden');

        // 模拟内容加载完成
        setTimeout(() => {
          skeleton.classList.add('hidden');
          content.classList.remove('hidden');
        }, 500);
      }
    });

    document.addEventListener('astro:page-load', () => {
      // WeChat share QR code display/hide
      const wechatBtn = document.querySelector('.article-share-wechat');
      if (wechatBtn) {
        // Mouse hover events (desktop)
        wechatBtn.addEventListener('mouseenter', () => {
          const qrCode = wechatBtn.querySelector('.article-share-wechat-qr');
          if (qrCode) {
            qrCode.style.display = 'block';
          }
        });
        wechatBtn.addEventListener('mouseleave', () => {
          const qrCode = wechatBtn.querySelector('.article-share-wechat-qr');
          if (qrCode) {
            qrCode.style.display = 'none';
          }
        });

        // Touch events (mobile)
        let touchTimer;
        wechatBtn.addEventListener('touchstart', () => {
          const qrCode = wechatBtn.querySelector('.article-share-wechat-qr');
          if (qrCode) {
            qrCode.style.display = 'block';
            // Clear previous timer
            if (touchTimer) clearTimeout(touchTimer);
            // Auto-hide after 5 seconds
            touchTimer = setTimeout(() => {
              qrCode.style.display = 'none';
            }, 5000);
          }
        });

        // Click outside to hide QR code
        document.addEventListener('click', (e) => {
          if (!wechatBtn.contains(e.target)) {
            const qrCode = wechatBtn.querySelector('.article-share-wechat-qr');
            if (qrCode) {
              qrCode.style.display = 'none';
            }
          }
        });
      }

      // Copy link functionality
      const copyBtn = document.querySelector('.article-share-copy');
      if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(window.location.href);
            const originalText = copyBtn.querySelector('span').textContent;
            copyBtn.querySelector('span').textContent = 'Copied';
            setTimeout(() => {
              copyBtn.querySelector('span').textContent = originalText;
            }, 2000);
          } catch (err) {
            console.error('Failed to copy:', err);
          }
        });
      }
    });
  </script>
</BaseLayout>
