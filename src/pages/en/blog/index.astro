---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog — Qi-Lab" description="Knowledge management, project management, and tech insights." lang="en">
  <main class="container" style="padding-top: 120px; padding-bottom: 80px;">
    <h1 style="font-family: var(--qi-font-serif); font-size: 2.5rem; margin-bottom: 2rem;">Blog</h1>
    {allPosts.length === 0 ? (
      <p style="color: var(--qi-text-muted);">No English posts yet. <a href="/blog" style="color: var(--qi-brand-emerald);">Read in Chinese →</a></p>
    ) : (
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--qi-gap-bento);">
        {allPosts.map(post => (
          <a href={`/en/blog/${post.id.replace('en/', '')}/`} style="
            display: block; background: var(--qi-surface-main); color: var(--qi-text-inverse);
            border-radius: var(--qi-radius-card); padding: 1.5rem;
            transition: transform var(--qi-transition), box-shadow var(--qi-transition); text-decoration: none;
          ">
            <span style="display: inline-block; background: var(--qi-brand-emerald); color: #fff; padding: 2px 10px; border-radius: var(--qi-radius-sm); font-size: 0.75rem; margin-bottom: 0.75rem;">
              {post.data.category}
            </span>
            <h2 style="font-family: var(--qi-font-serif); font-size: 1.25rem; margin-bottom: 0.5rem;">{post.data.title}</h2>
            <p style="opacity: 0.7; font-size: 0.9rem; margin-bottom: 1rem;">{post.data.description}</p>
            <time style="font-size: 0.8rem; opacity: 0.6;">{post.data.pubDate.toDateString()}</time>
          </a>
        ))}
      </div>
    )}
  </main>
</BaseLayout>
