---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog — Qi-Lab" description="Knowledge management, project management, and tech insights." lang="en">
  <main class="container blog-list-page">
    <h1 class="blog-list-title">Blog</h1>
    {allPosts.length === 0 ? (
      <p class="blog-empty-state">No English posts yet. <a href="/blog" class="blog-empty-link">Read in Chinese →</a></p>
    ) : (
      <div class="blog-grid">
        {allPosts.map(post => (
          <a href={`/en/blog/${post.id.replace('en/', '')}/`} class="blog-card">
            <span class="blog-card-category">
              {post.data.category}
            </span>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-desc">{post.data.description}</p>
            <time class="blog-card-date">{post.data.pubDate.toDateString()}</time>
          </a>
        ))}
      </div>
    )}
  </main>
</BaseLayout>

<style>
  .blog-list-page {
    padding-top: var(--qi-space-5xl);
    padding-bottom: var(--qi-space-xl);
  }

  .blog-list-title {
    font-family: var(--qi-font-serif);
    font-size: var(--qi-text-xl);
    margin-bottom: var(--qi-space-xl);
  }

  .blog-empty-state {
    color: var(--qi-text-muted);
  }

  .blog-empty-link {
    color: var(--qi-brand-emerald);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--qi-gap-bento);
  }

  .blog-card {
    display: block;
    background: var(--qi-surface-main);
    color: var(--qi-text-inverse);
    border-radius: var(--qi-radius-card);
    padding: var(--qi-container-padding);
    transition: transform var(--qi-transition), box-shadow var(--qi-transition);
    text-decoration: none;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--qi-shadow-hover-warm);
  }

  .blog-card-category {
    display: inline-block;
    background: var(--qi-brand-emerald);
    color: var(--qi-text-inverse);
    padding: 2px 10px;
    border-radius: var(--qi-radius-sm);
    font-size: var(--qi-text-xs);
    margin-bottom: 0.75rem;
  }

  .blog-card-title {
    font-family: var(--qi-font-serif);
    font-size: var(--qi-text-sm);
    margin-bottom: 0.5rem;
  }

  .blog-card-desc {
    opacity: 0.7;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .blog-card-date {
    font-size: var(--qi-text-xs);
    opacity: 0.6;
  }

  /* === Large screen: EN Blog === */
  @media (min-width: 1440px) {
    .blog-list-title { font-size: var(--qi-text-2xl); }
    .blog-grid { gap: 32px; }
  }

  @media (min-width: 2560px) {
    .blog-list-title { font-size: var(--qi-text-3xl); }
    .blog-grid { gap: 40px; max-width: 1600px; margin-inline: auto; }
    .blog-card { padding: var(--qi-space-2xl); }
    .blog-card-title { font-size: var(--qi-text-xl); }
    .blog-card-desc { font-size: var(--qi-text-base); }
  }

  @media (min-width: 3440px) {
    .blog-grid { gap: 48px; max-width: 1920px; }
    .blog-card { padding: var(--qi-space-3xl); }
    .blog-card-title { font-size: var(--qi-text-2xl); }
    .blog-card-desc { font-size: var(--qi-text-lg); }
  }
</style>
