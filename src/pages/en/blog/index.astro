---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../../utils/reading-time';
import OptimizedImage from '../../../components/ui/OptimizedImage.astro';
import SectionHeader from '../../../components/ui/SectionHeader.astro';
import Divider from '../../../components/global/Divider.astro';
import '../../../styles/pages/blog.css';

const allPosts = (
  await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en')
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog | Qi-Lab"
  description="Knowledge Management × Project Management × IT/AI Tips × Trending Gossips"
>
  <div class="container blog-list-page">
    <!-- Page Hero -->
    <section class="page-hero" data-reveal>
      <span class="page-label">// BLOG</span>
      <h1 class="page-title">Blog</h1>
      <p class="page-subtitle">Knowledge Management × Project Management × IT/AI Tips × Trending Gossips</p>
    </section>

    <Divider />

    <!-- Blog List -->
    <section class="about-section" data-reveal>
      <SectionHeader label="// ARTICLES" title="All Articles" />
      <section class="blog-grid" aria-labelledby="blog-title">
        {
          allPosts.length > 0 ? (
            allPosts.map((post) => (
              <a href={`/en/blog/${post.id.replace('en/', '')}/`} class="blog-card" data-reveal>
                {post.data.heroImage && (
                  <div class="blog-card-image">
                    <OptimizedImage
                      src={post.data.heroImage}
                      alt={post.data.title}
                      width={800}
                      height={450}
                      loading="lazy"
                      sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 400px"
                    />
                  </div>
                )}
                <div class="blog-card-body">
                  <span class="blog-card-category">{post.data.category}</span>
                  <h2 class="blog-card-title">{post.data.title}</h2>
                  <p class="blog-card-desc">{post.data.description}</p>
                  <div class="blog-card-meta">
                    <time>
                      {post.data.pubDate.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </time>
                    <span class="blog-card-reading-time">{getReadingTime(post.body || '')}</span>
                  </div>
                </div>
              </a>
            ))
          ) : (
            <div class="empty-blog">
              <p>Writing in progress, stay tuned...</p>
            </div>
          )
        }
      </section>
    </section>
  </div>
</BaseLayout>
