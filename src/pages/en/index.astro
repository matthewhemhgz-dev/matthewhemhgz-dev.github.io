---
import '../../styles/home.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import AboutSection from '../../components/sections/AboutSection.astro';
import FeaturedSection from '../../components/sections/FeaturedSection.astro';
import ToolboxSection from '../../components/sections/ToolboxSection.astro';
import PlatformsSection from '../../components/sections/PlatformsSection.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import CtaSection from '../../components/sections/CtaSection.astro';
import SectionDivider from '../../components/decorations/SectionDivider.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en');

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://matthewhemhgz-dev.github.io';

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'QiLab',
  url: siteUrl,
  description: 'A systematic place for organizing knowledge management, project management, IT/AI skills, and cutting-edge trends',
  inLanguage: 'en-US',
  publisher: {
    '@type': 'Organization',
    name: 'QiLab',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/logo.svg`,
    },
  },
};

const toolboxCategories = [
  { label: 'Knowledge Management', icon: 'book', tools: [{ name: 'Obsidian', desc: 'Local-first knowledge graph with bidirectional links' }, { name: 'Graphify', desc: 'LLM-driven knowledge base auto-builder' }, { name: 'Markdown', desc: 'Single source of truth document format standard' }] },
  { label: 'Development Tools', icon: 'cog', tools: [{ name: 'Trae', desc: 'AI-enhanced code editor' }, { name: 'Git + GitHub', desc: 'Version control & open source collaboration' }, { name: 'Docker', desc: 'Containerized deployment & orchestration' }, { name: 'Astro', desc: 'Zero JS static site generation' }] },
  { label: 'AI Tools', icon: 'robot', tools: [{ name: 'OpenClaw', desc: 'Exclusive digital twin outer brain (model routing)' }, { name: 'Trae SOLO', desc: 'AI programming agent & Subagent orchestration' }, { name: 'Superpowers', desc: 'TDD + systematic debugging AI workflow' }] },
  { label: 'Data & DevOps', icon: 'database', tools: [{ name: 'n8n', desc: 'Automated workflow engine' }, { name: 'Metabase', desc: 'Operational data visualization dashboard' }, { name: 'PostgreSQL', desc: 'Structured data persistence storage' }] },
];

const platforms = [
  { name: 'GitHub', handle: '@matthewhemhgz-dev', url: 'https://github.com/matthewhemhgz-dev', icon: 'laptop', desc: 'Open source projects & knowledge base' },
  { name: 'WeChat Official Account', handle: '祈研所', url: '#', icon: 'smartphone', desc: 'In-depth articles & systematic sharing' },
  { name: 'Video Account', handle: '祈研所', url: '#', icon: 'film', desc: 'Short videos' },
  { name: 'Xiaohongshu', handle: '祈研所（Qi_Lab）', url: '#', icon: 'book', desc: 'Practical tips &图文 content' },
  { name: 'Douyin', handle: '祈研所（QiLab）', url: '#', icon: 'zap', desc: 'Short videos' },
  { name: 'GitHub Pages', handle: 'QiLab', url: 'https://matthewhemhgz-dev.github.io', icon: 'globe', desc: 'Blog & project showcase' },
];


---

<BaseLayout title="QiLab" description="A systematic place for organizing knowledge management, project management, IT/AI skills, and cutting-edge trends" jsonLd={websiteJsonLd}>

  <HeroSection
    titleLines={['In the Age of Information Overload', 'Structured Knowledge', 'Is True Power']}
    accentIndex={1}
    subtitle="Knowledge Management · Project Management · IT/AI Skills · Cutting-edge Trends"
    watermark="Qi"
    stats={[
      { value: String(allPosts.length), label: 'Original Articles', dataCount: allPosts.length },
      { value: '5', label: 'Content Platforms', dataCount: 5 },
      { value: 'Continuously', label: 'Updating', isText: true },
    ]}
    primaryBtn={{ text: 'Learn More', href: '/en/about' }}
    secondaryBtn={{ text: 'Browse Blog', href: '/en/blog' }}
  />

  <SectionDivider variant="dots" />

  <AboutSection
    label="// ABOUT"
    title="About QiLab"
    text="QiLab is my digital archive — a systematic place for organizing knowledge management, project management, IT/AI skills, and cutting-edge trends. Through personal experience, practical thinking, and systematic notes, I explore how to make technology truly serve human needs. Every article, every tool recommendation, has been verified through actual use. Adhering to human ontological value, long-termism."
    decoNumber="01"
    decoSlogan="Organize · Verify · Share"
    dashItems={[
      { label: 'Knowledge Management', value: '75+', percentage: 92, color: 'emerald' },
      { label: 'Project Management', value: '7 Certifications', percentage: 88, color: 'amber' },
      { label: 'IT/AI Skills', value: '5+', percentage: 85, color: 'emerald' },
      { label: 'Cutting-edge Trends', value: '10+', percentage: 70, color: 'gray' },
    ]}
  />

  <SectionDivider variant="line" />

  <FeaturedSection
    label="// FEATURED"
    title="Featured Content"
    posts={recentPosts}
    emptyText="No articles yet, coming soon..."
    emptyIcon="svg"
    readMoreText="Read More"
    browseBlogHref="/en/blog"
    browseBlogText="Browse Blog"
    largeCardLayout={true}
  />

  <SectionDivider variant="diamond" />

  <ToolboxSection
    label="// TOOLBOX"
    title="Toolbox"
    categories={toolboxCategories}
  />

  <PlatformsSection
    label="// PLATFORMS"
    title="Platform Matrix"
    platforms={platforms}
  />

  <TestimonialsSection
    label="// TIMELINE"
    title="Development History"
  />

  <SectionDivider variant="arcs" />

  <CtaSection
    label="// LET'S CONNECT"
    title="Let's Make Knowledge Truly Useful Together"
    description="Whether it's knowledge management exchange, AI workflow discussion, or project cooperation, feel free to contact us anytime."
    primaryBtn={{ text: 'Send Email', href: 'mailto:matthewhemhgz@gmail.com' }}
    secondaryBtn={{ text: 'GitHub', href: 'https://github.com/matthewhemhgz-dev', external: true }}
  />

</BaseLayout>

<style>
  /* === English homepage: language-specific overrides === */

  /* Hero stagger animation */
  .hero-stagger {
    opacity: 0;
    animation: heroSlideIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-stagger--1 { animation-delay: 0.1s; }
  .hero-stagger--2 { animation-delay: 0.2s; }
  .hero-stagger--3 { animation-delay: 0.35s; }
  .hero-stagger--4 { animation-delay: 0.5s; }

  @keyframes heroSlideIn {
    from {
      opacity: 0;
      transform: translateX(-24px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Hero fade-in for subtitle and below */
  .hero-fade-in {
    opacity: 0;
    animation: fadeIn 0.8s ease 0.8s both;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Reduced motion: show all hero content immediately */
  @media (prefers-reduced-motion: reduce) {
    .hero-stagger,
    .hero-fade-in {
      opacity: 1;
      animation: none;
      transform: none;
    }
  }

  /* Hero stat: transition for counter animation */
  .hero-stat-value {
    transition: color 0.3s ease;
  }

  .hero-stat-text {
    animation: none;
    opacity: 1;
  }

  /* 4B: Large bento card - magazine style with image overlay */
  .bento-card--large {
    min-height: 380px;
    padding: 0;
  }

  .bento-card--large__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .bento-card--large__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .bento-card:hover .bento-card--large__bg img {
    transform: scale(1.05);
  }

  .bento-card--large__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--qi-text-primary) 88%, transparent) 0%,
      color-mix(in srgb, var(--qi-text-primary) 60%, transparent) 50%,
      color-mix(in srgb, var(--qi-text-primary) 45%, transparent) 100%
    );
    z-index: 1;
  }

  .bento-card--large__bg--gradient {
    background: linear-gradient(
      135deg,
      var(--qi-text-primary) 0%,
      var(--qi-brand-emerald) 60%,
      var(--qi-brand-amber) 100%
    );
  }

  .bento-card--large__bg--gradient .bento-card--large__overlay {
    opacity: 0;
    pointer-events: none;
  }

  .bento-card__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: var(--qi-space-sm);
    padding: var(--qi-space-xl);
    height: 100%;
    justify-content: flex-end;
  }

  .bento-card--large .bento-card__content {
    justify-content: flex-end;
    padding: var(--qi-space-2xl);
  }

  .bento-card--large .bento-meta {
    position: absolute;
    top: var(--qi-space-xl);
    left: var(--qi-space-xl);
  }

  .bento-card--large .bento-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--qi-text-inverse);
  }

  .bento-card--large .bento-desc {
    color: color-mix(in srgb, var(--qi-text-inverse) 75%, transparent);
  }

  .bento-card--large .bento-tag {
    background: color-mix(in srgb, var(--qi-text-inverse) 15%, transparent);
    color: var(--qi-text-inverse);
  }

  .bento-card--large .bento-date {
    color: color-mix(in srgb, var(--qi-text-inverse) 60%, transparent);
  }

  .bento-card--large .bento-link {
    color: var(--qi-brand-amber);
  }

  .bento-card--large:hover .bento-link {
    color: var(--qi-text-inverse);
  }

  /* Empty state icon (SVG version) */
  .empty-icon :global(svg) {
    width: 40px;
    height: 40px;
  }

  /* --- Responsive overrides --- */
  @media (max-width: 768px) {
    .bento-card--large {
      min-height: 280px;
    }

    .bento-card--large .bento-meta {
      position: static;
    }
  }
</style>

<script>
  // Animate hero stat numbers on page load (compatible with View Transitions)
  function animateStats() {
    const statValues = document.querySelectorAll('.hero-stat-value[data-count]');
    statValues.forEach((el) => {
      // Reset to 0 to trigger animation again
      el.textContent = '0';
      const target = parseInt(el.getAttribute('data-count') || '0', 10);
      if (isNaN(target) || target === 0) return;
      let current = 0;
      const duration = 1200;
      const step = Math.max(1, Math.ceil(target / (duration / 30)));
      const timer = setInterval(() => {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = String(current);
      }, 30);
    });
  }
  document.addEventListener('astro:page-load', animateStats);
</script>