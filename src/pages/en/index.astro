---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import DashCard from '../../components/ui/DashCard.astro';
import TagCloud from '../../components/ui/TagCloud.astro';
import Divider from '../../components/global/Divider.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

// Dynamic category count (same as Chinese version)
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en');
const countByCategory = (cat) => allPosts.filter(p => p.data.category === cat).length;

const contentCategories = [
  { icon: 'chart-bar', title: 'Deep Dive', desc: 'In-depth analysis uncovering the essence and underlying principles of technology', color: 'emerald', count: countByCategory('Deep Dive') },
  { icon: 'wrench', title: 'Practical Tips', desc: 'Actionable techniques, tools, and workflow sharing', color: 'amber', count: countByCategory('Practical Tips') },
  { icon: 'magnifier', title: 'Trends', desc: 'Cutting-edge technology trends and industry observations', color: 'emerald', count: countByCategory('Trends') },
  { icon: 'thought-bubble', title: 'Thoughts', desc: 'Sparks of inspiration, reflections, and life musings', color: 'amber', count: countByCategory('Thoughts') },
];

const toolboxCategories = [
  {
    label: 'Knowledge Management',
    icon: 'book',
    tools: [
      { name: 'Notion', desc: 'All-in-one workspace' },
      { name: 'Obsidian', desc: 'Local-first knowledge graph' },
      { name: 'Logseq', desc: 'Outliner notes & bi-directional links' },
    ],
  },
  {
    label: 'Dev Tools',
    icon: 'cog',
    tools: [
      { name: 'VS Code', desc: 'Primary code editor' },
      { name: 'Git', desc: 'Version control & collaboration' },
      { name: 'Docker', desc: 'Containerized deployment' },
      { name: 'Astro', desc: 'Static site generation' },
    ],
  },
  {
    label: 'AI Tools',
    icon: 'robot',
    tools: [
      { name: 'ChatGPT', desc: 'Conversational AI assistant' },
      { name: 'Claude', desc: 'Deep reasoning & writing' },
      { name: 'Midjourney', desc: 'AI image generation' },
    ],
  },
  {
    label: 'Design Tools',
    icon: 'palette',
    tools: [
      { name: 'Figma', desc: 'Collaborative interface design' },
      { name: 'Excalidraw', desc: 'Hand-drawn style whiteboard' },
    ],
  },
];

const platforms = [
  { name: 'GitHub', handle: '@qi-lab', url: 'https://github.com/qi-lab', icon: 'laptop', desc: 'Open-source projects & code' },
  { name: 'WeChat', handle: 'Qi-Lab', url: '#', icon: 'smartphone', desc: 'Long-form articles & tech sharing' },
  { name: 'Zhihu', handle: 'Qi-Lab', url: '#', icon: 'book', desc: 'Tech Q&A & columns' },
  { name: 'Jike', handle: '@qilab', url: '#', icon: 'zap', desc: 'Fragments & updates' },
  { name: 'Twitter/X', handle: '@qilab_dev', url: '#', icon: 'bird', desc: 'English tech updates' },
  { name: 'Bilibili', handle: 'Qi-Lab', url: '#', icon: 'film', desc: 'Video tutorials & demos' },
];

const timelineItems = [
  { date: '2025.04', title: 'Qi-Lab Website v4.0 Launch', desc: 'Astro rebuild with new design system & i18n support', tag: 'Milestone' },
  { date: '2025.03', title: 'Dual-Track Knowledge System', desc: 'Obsidian + Notion collaborative workflow', tag: 'System' },
  { date: '2025.02', title: 'AI Tools Deep Review Series', desc: 'Systematic review of mainstream AI tools', tag: 'Content' },
  { date: '2025.01', title: 'Qi-Lab Brand Founded', desc: 'The starting point for tech exploration & creative experiments', tag: 'Origin' },
  { date: '2024.11', title: 'First Open-Source Tool Library', desc: 'Published utility toolkit, gained community traction', tag: 'Open Source' },
  { date: '2024.09', title: 'Started Systematic Tech Writing', desc: 'Built content system, focused on frontend & productivity', tag: 'Origin' },
];

const testimonials = [
  {
    quote: 'Qi-Lab\'s tech articles always explain complex concepts with remarkable clarity. The front-end performance optimization piece was especially enlightening.',
    author: 'A Front-End Developer',
    role: 'Reader Feedback',
  },
  {
    quote: 'The toolbox recommendations are incredibly practical, saving me hours of tool research. The knowledge management series directly changed how I organize my notes.',
    author: 'A Product Manager',
    role: 'Long-Time Reader',
  },
  {
    quote: 'Rare to find a personal blog with both technical depth and design aesthetics. Every visit is a genuine pleasure.',
    author: 'A Designer',
    role: 'Subscriber',
  },
];

// SVG icon map (same as Chinese version)
const svgIcons: Record<string, string> = {
  'chart-bar': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="12" width="4" height="9" rx="1"/><rect x="10" y="7" width="4" height="14" rx="1"/><rect x="17" y="3" width="4" height="18" rx="1"/></svg>',
  'wrench': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
  'magnifier': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
  'thought-bubble': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><circle cx="9" cy="10" r="0.5" fill="currentColor"/><circle cx="12" cy="10" r="0.5" fill="currentColor"/><circle cx="15" cy="10" r="0.5" fill="currentColor"/></svg>',
  'laptop': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="2" y1="20" x2="22" y2="20"/></svg>',
  'smartphone': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>',
  'book': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>',
  'zap': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
  'bird': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>',
  'film': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/><line x1="17" y1="17" x2="22" y2="17"/></svg>',
  'cog': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>',
  'robot': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><line x1="12" y1="7" x2="12" y2="11"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/></svg>',
  'palette': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"/><circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"/><circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"/><circle cx="6.5" cy="12.5" r="0.5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>',
  'user': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
  'edit': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>',
};
---

<BaseLayout title="Qi-Lab" description="Qi-Lab — Where technology, design, and creativity converge." tagline="Build with code, express through design">

  <!-- ===== Hero Section ===== -->
  <section class="hero-section" data-reveal>
    <div class="hero-bg-decoration" aria-hidden="true">
      <div class="hero-gradient-orb hero-gradient-orb--1"></div>
      <div class="hero-gradient-orb hero-gradient-orb--2"></div>
      <div class="hero-grid-pattern"></div>
      <div class="hero-watermark" aria-hidden="true">祈</div>
    </div>
    <div class="container hero-container">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span class="badge-text">Amber Geek Design System</span>
      </div>
      <h1 class="hero-title">
        <span class="title-line">Where Technology,</span>
        <span class="title-line title-accent">Design & Creativity</span>
        <span class="title-line">Converge</span>
      </h1>
      <p class="hero-subtitle">
        Frontend Dev · System Design · Creative Experiments — A creative lab that builds with code and expresses through design.
      </p>
      <div class="hero-actions">
        <a href="/en/about" class="btn btn-primary">
          <span>Learn More</span>
          <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/en/blog" class="btn btn-secondary">Browse Blog</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">Growing</span>
          <span class="hero-stat-label">Original Articles</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-value">Active</span>
          <span class="hero-stat-label">Platforms</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-value">Contributing</span>
          <span class="hero-stat-label">Open Source</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Hero -> About: no divider, large spacing for natural transition -->

  <!-- ===== About Section (Asymmetric Layout) ===== -->
  <section class="section about-section" data-reveal>
    <div class="container">
      <div class="about-layout">
        <div class="about-deco" aria-hidden="true">
          <span class="about-deco-number">01</span>
          <span class="about-deco-slogan">Explore · Create · Share</span>
        </div>
        <div class="about-main">
          <SectionHeader label="// ABOUT" title="About Qi-Lab" />
          <p class="about-text">
            Qi-Lab was born from a relentless curiosity about the intersection of technology and aesthetics.
            We believe that great code should feel like a carefully crafted work of art, and that good design
            stems from an unwavering pursuit of detail. Here we document our reflections and practices on
            front-end development, system design, open-source contributions, and creative experiments.
          </p>
          <div class="dash-grid">
            <DashCard label="Front-End Dev" value="5+" percentage="92" color="emerald" />
            <DashCard label="System Design" value="3+" percentage="78" color="amber" />
            <DashCard label="Open Source" value="20+" percentage="85" color="emerald" />
            <DashCard label="Creative Experiments" value="10+" percentage="70" color="gray" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <Divider />

  <!-- ===== FeaturedContent Section ===== -->
  <section class="section" data-reveal>
    <div class="container">
      <SectionHeader label="// FEATURED" title="Featured Content" />
      {recentPosts.length > 0 ? (
        <div class="bento-grid">
          {recentPosts.map((post, i) => (
            <a
              href={`/en/blog/${post.id}`}
              class:list={['bento-card', i === 0 ? 'bento-card--large' : 'bento-card--small']}
            >
              <div class="bento-meta">
                <span class="bento-date">
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </span>
                {post.data.tags && post.data.tags.length > 0 && (
                  <span class="bento-tag">{post.data.tags[0]}</span>
                )}
              </div>
              <h3 class="bento-title">{post.data.title}</h3>
              {post.data.description && (
                <p class="bento-desc">{post.data.description}</p>
              )}
              {i === 0 && post.data.heroImage && (
                <div class="bento-image-wrap">
                  <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                </div>
              )}
              <span class="bento-link">Read more &rarr;</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <div class="empty-icon" aria-hidden="true">&#x1F4DD;</div>
          <p class="empty-text">No posts yet. Stay tuned...</p>
          <a href="/en/blog" class="btn btn-secondary">Browse Blog</a>
        </div>
      )}
    </div>
  </section>

  <!-- Featured -> Skills: gradient divider -->

  <Divider variant="gradient" />

  <!-- ===== Skills Section (Dark Background) ===== -->
  <section class="section skills-section" data-reveal>
    <div class="skills-bg-decoration" aria-hidden="true">
      <div class="skills-glow"></div>
    </div>
    <div class="container">
      <SectionHeader label="// SKILLS" title="Tech Stack" />
      <p class="skills-intro">Building creative possibilities with technology</p>
      <TagCloud
        variant="dark"
        tags={[
          { text: 'TypeScript', size: 'lg', href: '/en/tags/typescript' },
          { text: 'React', size: 'lg', href: '/en/tags/react' },
          { text: 'Astro', size: 'lg', href: '/en/tags/astro' },
          { text: 'Node.js', size: 'md', href: '/en/tags/nodejs' },
          { text: 'Vue', size: 'md', href: '/en/tags/vue' },
          { text: 'CSS', size: 'md', href: '/en/tags/css' },
          { text: 'Rust', size: 'md' },
          { text: 'Go', size: 'sm' },
          { text: 'PostgreSQL', size: 'sm' },
          { text: 'Docker', size: 'sm' },
          { text: 'Figma', size: 'sm' },
          { text: 'Git', size: 'sm' },
          { text: 'Linux', size: 'sm' },
          { text: 'WebGL', size: 'sm' },
        ]}
      />
    </div>
    <div class="skills-fade-out" aria-hidden="true"></div>
  </section>

  <!-- Skills -> Categories: no divider, gradient transition handles it -->

  <!-- ===== ContentCategories Section ===== -->
  <section class="section" data-reveal>
    <div class="container">
      <SectionHeader label="// CATEGORIES" title="Content Categories" />
      <div class="category-grid">
        {contentCategories.map((cat) => (
          <div class:list={['category-card', `category-card--${cat.color}`]}>
            <div class="category-icon-wrap">
              <span class="category-icon" set:html={svgIcons[cat.icon]} />
            </div>
            <div class="category-body">
              <div class="category-header">
                <h3 class="category-title">{cat.title}</h3>
                <span class="category-count">{cat.count} posts</span>
              </div>
              <p class="category-desc">{cat.desc}</p>
            </div>
            <span class="category-arrow">&rarr;</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Categories -> Toolbox: no divider -->

  <!-- ===== Toolbox Section ===== -->
  <section class="section" data-reveal>
    <div class="container">
      <SectionHeader label="// TOOLBOX" title="Toolbox" />
      <div class="toolbox-grid">
        {toolboxCategories.map((cat) => (
          <div class="toolbox-category">
            <div class="toolbox-header">
              <span class="toolbox-icon" set:html={svgIcons[cat.icon]} />
              <h3 class="toolbox-label">{cat.label}</h3>
            </div>
            <div class="toolbox-items">
              {cat.tools.map((tool) => (
                <div class="tool-chip">
                  <span class="tool-name">{tool.name}</span>
                  <span class="tool-desc">{tool.desc}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Divider variant="dash" />

  <!-- ===== PlatformMatrix Section ===== -->
  <section class="section" data-reveal>
    <div class="container">
      <SectionHeader label="// PLATFORMS" title="Platform Matrix" />
      <div class="platform-grid">
        {platforms.map((p) => (
          <a href={p.url} title={p.url === '#' ? 'Coming soon' : undefined} class="platform-card" target="_blank" rel="noopener noreferrer">
            <span class="platform-icon" set:html={svgIcons[p.icon]} />
            <div class="platform-info">
              <h3 class="platform-name">{p.name}</h3>
              <span class="platform-handle">{p.handle}</span>
              <span class="platform-desc">{p.desc}</span>
            </div>
            <span class="platform-arrow">&nearr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Platform -> Timeline: no divider -->

  <!-- ===== Timeline Section ===== -->
  <section class="section" data-reveal>
    <div class="container">
      <SectionHeader label="// TIMELINE" title="Changelog" />
      <div class="timeline">
        {timelineItems.map((item, i) => (
          <div class:list={['timeline-item', i % 2 === 1 && 'timeline-item--alt']}>
            <div class="timeline-marker">
              <span class="timeline-dot"></span>
              {i < timelineItems.length - 1 && <span class="timeline-line"></span>}
            </div>
            <div class="timeline-body">
              <div class="timeline-header">
                <span class="timeline-date">{item.date}</span>
                <span class:list={['timeline-tag', `timeline-tag--${item.tag}`]}>{item.tag}</span>
              </div>
              <h3 class="timeline-title">{item.title}</h3>
              <p class="timeline-desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Divider variant="minimal" />

  <!-- ===== Testimonials Section ===== -->
  <section class="section" data-reveal>
    <div class="container">
      <SectionHeader label="// VOICES" title="Reader Reviews" />
      <div class="testimonial-grid">
        {testimonials.map((t, i) => (
          <blockquote class:list={['testimonial-card', `testimonial-card--${i}`]}>
            <span class="testimonial-quote">&ldquo;</span>
            <p class="testimonial-text">{t.quote}</p>
            <footer class="testimonial-footer">
              <div class="testimonial-avatar" aria-hidden="true" set:html={svgIcons['user']}></div>
              <div class="testimonial-author-info">
                <span class="testimonial-author">{t.author}</span>
                <span class="testimonial-role">{t.role}</span>
              </div>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA Section ===== -->
  <section class="section cta-section" data-reveal>
    <div class="container">
      <div class="cta-content">
        <span class="cta-label">// LET'S CONNECT</span>
        <h2 class="cta-title">Let's Explore Possibilities Together</h2>
        <p class="cta-desc">Whether it's tech exchange, project collaboration, or creative collision, feel free to reach out.</p>
        <div class="cta-actions">
          <a href="mailto:hello@qi-lab.dev" class="btn btn-primary">
            <span>Send Email</span>
            <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="https://github.com/qi-lab" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

