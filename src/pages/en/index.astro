---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Divider from '../../components/global/Divider.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import AboutSection from '../../components/sections/AboutSection.astro';
import FeaturedSection from '../../components/sections/FeaturedSection.astro';
import SkillsSection from '../../components/sections/SkillsSection.astro';
import CategoriesSection from '../../components/sections/CategoriesSection.astro';
import ToolboxSection from '../../components/sections/ToolboxSection.astro';
import PlatformsSection from '../../components/sections/PlatformsSection.astro';
import TimelineSection from '../../components/sections/TimelineSection.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import CtaSection from '../../components/sections/CtaSection.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en');
const countByCategory = (cat) => allPosts.filter(p => p.data.category === cat).length;

const contentCategories = [
  { icon: 'chart-bar', title: 'Deep Dive', desc: 'In-depth analysis uncovering the essence and underlying principles of technology', color: 'emerald', count: countByCategory('Deep Dive'), countLabel: 'posts' },
  { icon: 'wrench', title: 'Practical Tips', desc: 'Actionable techniques, tools, and workflow sharing', color: 'amber', count: countByCategory('Practical Tips'), countLabel: 'posts' },
  { icon: 'magnifier', title: 'Trends', desc: 'Cutting-edge technology trends and industry observations', color: 'emerald', count: countByCategory('Trends'), countLabel: 'posts' },
  { icon: 'thought-bubble', title: 'Thoughts', desc: 'Sparks of inspiration, reflections, and life musings', color: 'amber', count: countByCategory('Thoughts'), countLabel: 'posts' },
];

const toolboxCategories = [
  { label: 'Knowledge Management', icon: 'book', tools: [{ name: 'Notion', desc: 'All-in-one workspace' }, { name: 'Obsidian', desc: 'Local-first knowledge graph' }, { name: 'Logseq', desc: 'Outliner notes & bi-directional links' }] },
  { label: 'Dev Tools', icon: 'cog', tools: [{ name: 'VS Code', desc: 'Primary code editor' }, { name: 'Git', desc: 'Version control & collaboration' }, { name: 'Docker', desc: 'Containerized deployment' }, { name: 'Astro', desc: 'Static site generation' }] },
  { label: 'AI Tools', icon: 'robot', tools: [{ name: 'ChatGPT', desc: 'Conversational AI assistant' }, { name: 'Claude', desc: 'Deep reasoning & writing' }, { name: 'Midjourney', desc: 'AI image generation' }] },
  { label: 'Design Tools', icon: 'palette', tools: [{ name: 'Figma', desc: 'Collaborative interface design' }, { name: 'Excalidraw', desc: 'Hand-drawn style whiteboard' }] },
];

const platforms = [
  { name: 'GitHub', handle: '@qi-lab', url: 'https://github.com/qi-lab', icon: 'laptop', desc: 'Open-source projects & code', comingSoonText: 'Coming soon' },
  { name: 'WeChat', handle: 'Qi-Lab', url: '#', icon: 'smartphone', desc: 'Long-form articles & tech sharing', comingSoonText: 'Coming soon' },
  { name: 'Zhihu', handle: 'Qi-Lab', url: '#', icon: 'book', desc: 'Tech Q&A & columns', comingSoonText: 'Coming soon' },
  { name: 'Jike', handle: '@qilab', url: '#', icon: 'zap', desc: 'Fragments & updates', comingSoonText: 'Coming soon' },
  { name: 'Twitter/X', handle: '@qilab_dev', url: '#', icon: 'bird', desc: 'English tech updates', comingSoonText: 'Coming soon' },
  { name: 'Bilibili', handle: 'Qi-Lab', url: '#', icon: 'film', desc: 'Video tutorials & demos', comingSoonText: 'Coming soon' },
];

const timelineItems = [
  { date: '2025.04', title: 'Qi-Lab Website v4.0 Launch', desc: 'Astro rebuild with new design system & i18n support', tag: 'Milestone' },
  { date: '2025.03', title: 'Dual-Track Knowledge System', desc: 'Obsidian + Notion collaborative workflow', tag: 'System' },
  { date: '2025.02', title: 'AI Tools Deep Review Series', desc: 'Systematic review of mainstream AI tools', tag: 'Content' },
  { date: '2025.01', title: 'Qi-Lab Brand Founded', desc: 'The starting point for tech exploration & creative experiments', tag: 'Origin' },
  { date: '2024.11', title: 'First Open-Source Tool Library', desc: 'Published utility toolkit, gained community traction', tag: 'Open Source' },
  { date: '2024.09', title: 'Started Systematic Tech Writing', desc: 'Built content system, focused on frontend & productivity', tag: 'Origin' },
];

const testimonials = [
  { quote: 'Qi-Lab\'s tech articles always explain complex concepts with remarkable clarity. The front-end performance optimization piece was especially enlightening.', author: 'A Front-End Developer', role: 'Reader Feedback' },
  { quote: 'The toolbox recommendations are incredibly practical, saving me hours of tool research. The knowledge management series directly changed how I organize my notes.', author: 'A Product Manager', role: 'Long-Time Reader' },
  { quote: 'Rare to find a personal blog with both technical depth and design aesthetics. Every visit is a genuine pleasure.', author: 'A Designer', role: 'Subscriber' },
];
---

<BaseLayout title="Qi-Lab" description="Qi-Lab — Where technology, design, and creativity converge." tagline="Build with code, express through design">

  <HeroSection
    titleLines={['Where Technology,', 'Design & Creativity', 'Converge']}
    accentIndex={1}
    subtitle="Frontend Dev · System Design · Creative Experiments — A creative lab that builds with code and expresses through design."
    watermark="祈"
    stats={[
      { value: 'Growing', label: 'Original Articles', isText: true },
      { value: 'Active', label: 'Platforms', isText: true },
      { value: 'Contributing', label: 'Open Source', isText: true },
    ]}
    primaryBtn={{ text: 'Learn More', href: '/en/about' }}
    secondaryBtn={{ text: 'Browse Blog', href: '/en/blog' }}
  />

  <AboutSection
    label="// ABOUT"
    title="About Qi-Lab"
    text="Qi-Lab was born from a relentless curiosity about the intersection of technology and aesthetics. We believe that great code should feel like a carefully crafted work of art, and that good design stems from an unwavering pursuit of detail. Here we document our reflections and practices on front-end development, system design, open-source contributions, and creative experiments."
    decoNumber="01"
    decoSlogan="Explore · Create · Share"
    dashItems={[
      { label: 'Front-End Dev', value: '5+', percentage: 92, color: 'emerald' },
      { label: 'System Design', value: '3+', percentage: 78, color: 'amber' },
      { label: 'Open Source', value: '20+', percentage: 85, color: 'emerald' },
      { label: 'Creative Experiments', value: '10+', percentage: 70, color: 'gray' },
    ]}
  />

  <Divider />

  <FeaturedSection
    label="// FEATURED"
    title="Featured Content"
    posts={recentPosts}
    locale="en"
    emptyText="No posts yet. Stay tuned..."
    emptyIcon="emoji"
    readMoreText="Read more"
    browseBlogHref="/en/blog"
    browseBlogText="Browse Blog"
    largeCardLayout={false}
  />

  <Divider variant="gradient" />

  <SkillsSection
    label="// SKILLS"
    title="Tech Stack"
    intro="Building creative possibilities with technology"
    tags={[
      { text: 'TypeScript', size: 'lg', href: '/en/tags/typescript' },
      { text: 'React', size: 'lg', href: '/en/tags/react' },
      { text: 'Astro', size: 'lg', href: '/en/tags/astro' },
      { text: 'Node.js', size: 'md', href: '/en/tags/nodejs' },
      { text: 'Vue', size: 'md', href: '/en/tags/vue' },
      { text: 'CSS', size: 'md', href: '/en/tags/css' },
      { text: 'Rust', size: 'md' },
      { text: 'Go', size: 'sm' },
      { text: 'PostgreSQL', size: 'sm' },
      { text: 'Docker', size: 'sm' },
      { text: 'Figma', size: 'sm' },
      { text: 'Git', size: 'sm' },
      { text: 'Linux', size: 'sm' },
      { text: 'WebGL', size: 'sm' },
    ]}
  />

  <CategoriesSection
    label="// CATEGORIES"
    title="Content Categories"
    categories={contentCategories}
  />

  <ToolboxSection
    label="// TOOLBOX"
    title="Toolbox"
    categories={toolboxCategories}
  />

  <Divider variant="dash" />

  <PlatformsSection
    label="// PLATFORMS"
    title="Platform Matrix"
    platforms={platforms}
  />

  <TimelineSection
    label="// TIMELINE"
    title="Changelog"
    items={timelineItems}
  />

  <Divider variant="minimal" />

  <TestimonialsSection
    label="// VOICES"
    title="Reader Reviews"
    testimonials={testimonials}
  />

  <CtaSection
    label="// LET'S CONNECT"
    title="Let's Explore Possibilities Together"
    description="Whether it's tech exchange, project collaboration, or creative collision, feel free to reach out."
    primaryBtn={{ text: 'Send Email', href: 'mailto:hello@qi-lab.dev' }}
    secondaryBtn={{ text: 'GitHub', href: 'https://github.com/qi-lab', external: true }}
  />

</BaseLayout>

<style>
  /* === English homepage: language-specific overrides === */

  /* Hero title: slightly smaller for longer English text */
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    letter-spacing: -0.01em;
  }

  /* 4B: Large bento card - row layout for English */
  .bento-card--large {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--qi-space-xl);
  }

  /* Empty state icon (emoji version) */
  .empty-icon {
    font-size: 2.5rem;
  }

  /* English timeline tag color variants */
  .timeline-tag--Milestone {
    background: rgba(46, 125, 92, 0.1);
    color: var(--qi-brand-emerald);
  }

  .timeline-tag--Origin {
    background: rgba(229, 169, 60, 0.1);
    color: var(--qi-amber-dark);
  }

  .timeline-tag--System {
    background: rgba(42, 42, 42, 0.06);
    color: var(--qi-text-secondary);
  }

  .timeline-tag--Content {
    background: rgba(42, 42, 42, 0.06);
    color: var(--qi-text-secondary);
  }

  .timeline-tag--Open Source {
    background: rgba(229, 169, 60, 0.08);
    color: var(--qi-amber-dark);
  }
</style>
