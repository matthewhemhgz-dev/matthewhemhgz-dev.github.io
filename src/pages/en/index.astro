---
import '../../styles/home.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import AboutSection from '../../components/sections/AboutSection.astro';
import FeaturedSection from '../../components/sections/FeaturedSection.astro';
import ToolboxSection from '../../components/sections/ToolboxSection.astro';
import PlatformsSection from '../../components/sections/PlatformsSection.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import CtaSection from '../../components/sections/CtaSection.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en');

const toolboxCategories = [
  { label: 'Knowledge Management', icon: 'book', tools: [{ name: 'Notion', desc: 'All-in-one workspace' }, { name: 'Obsidian', desc: 'Local-first knowledge graph' }, { name: 'Logseq', desc: 'Outliner notes & bi-directional links' }] },
  { label: 'Dev Tools', icon: 'cog', tools: [{ name: 'VS Code', desc: 'Primary code editor' }, { name: 'Git', desc: 'Version control & collaboration' }, { name: 'Docker', desc: 'Containerized deployment' }, { name: 'Astro', desc: 'Static site generation' }] },
  { label: 'AI Tools', icon: 'robot', tools: [{ name: 'ChatGPT', desc: 'Conversational AI assistant' }, { name: 'Claude', desc: 'Deep reasoning & writing' }, { name: 'Midjourney', desc: 'AI image generation' }] },
  { label: 'Design Tools', icon: 'palette', tools: [{ name: 'Figma', desc: 'Collaborative interface design' }, { name: 'Excalidraw', desc: 'Hand-drawn style whiteboard' }] },
];

const platforms = [
  { name: 'GitHub', handle: '@qi-lab', url: 'https://github.com/qi-lab', icon: 'laptop', desc: 'Open-source projects & code', comingSoonText: 'Coming soon' },
  { name: 'WeChat', handle: 'Qi-Lab', url: '#', icon: 'smartphone', desc: 'Long-form articles & tech sharing', comingSoonText: 'Coming soon' },
  { name: 'Zhihu', handle: 'Qi-Lab', url: '#', icon: 'book', desc: 'Tech Q&A & columns', comingSoonText: 'Coming soon' },
  { name: 'Jike', handle: '@qilab', url: '#', icon: 'zap', desc: 'Fragments & updates', comingSoonText: 'Coming soon' },
  { name: 'Twitter/X', handle: '@qilab_dev', url: '#', icon: 'bird', desc: 'English tech updates', comingSoonText: 'Coming soon' },
  { name: 'Bilibili', handle: 'Qi-Lab', url: '#', icon: 'film', desc: 'Video tutorials & demos', comingSoonText: 'Coming soon' },
];

const testimonials = [
  { quote: 'Qi-Lab\'s tech articles always explain complex concepts with remarkable clarity. The front-end performance optimization piece was especially enlightening.', author: 'A Front-End Developer', role: 'Reader Feedback' },
  { quote: 'Rare to find a personal blog with both technical depth and design aesthetics. Every visit is a genuine pleasure.', author: 'A Designer', role: 'Subscriber' },
];
---

<BaseLayout title="Qi-Lab" description="Qi-Lab — Where technology, design, and creativity converge." tagline="Build with code, express through design" lang="en">

  <HeroSection
    titleLines={['Where Technology,', 'Design & Creativity', 'Converge']}
    accentIndex={1}
    subtitle="Frontend Dev · System Design · Creative Experiments — A creative lab that builds with code and expresses through design."
    watermark="祈"
    stats={[
      { value: String(allPosts.length), label: 'Original Articles', dataCount: allPosts.length },
      { value: '6', label: 'Platforms', dataCount: 6 },
      { value: 'Active', label: 'Updating', isText: true },
    ]}
    primaryBtn={{ text: 'Learn More', href: '/en/about' }}
    secondaryBtn={{ text: 'Browse Blog', href: '/en/blog' }}
  />

  <AboutSection
    label="// ABOUT"
    title="About Qi-Lab"
    text="Qi-Lab was born from a relentless curiosity about the intersection of technology and aesthetics. We believe that great code should feel like a carefully crafted work of art, and that good design stems from an unwavering pursuit of detail. Here we document our reflections and practices on front-end development, system design, open-source contributions, and creative experiments."
    decoNumber="01"
    decoSlogan="Explore · Create · Share"
    dashItems={[
      { label: 'Front-End Dev', value: '5+', percentage: 92, color: 'emerald' },
      { label: 'System Design', value: '3+', percentage: 78, color: 'amber' },
      { label: 'Open Source', value: '20+', percentage: 85, color: 'emerald' },
      { label: 'Creative Experiments', value: '10+', percentage: 70, color: 'gray' },
    ]}
  />

  <FeaturedSection
    label="// FEATURED"
    title="Featured Content"
    posts={recentPosts}
    locale="en"
    emptyText="No posts yet. Stay tuned..."
    emptyIcon="svg"
    readMoreText="Read more"
    browseBlogHref="/en/blog"
    browseBlogText="Browse Blog"
    largeCardLayout={true}
  />

  <ToolboxSection
    label="// TOOLBOX"
    title="Toolbox"
    categories={toolboxCategories}
  />

  <PlatformsSection
    label="// PLATFORMS"
    title="Platform Matrix"
    platforms={platforms}
  />

  <TestimonialsSection
    label="// VOICES"
    title="Reader Reviews"
    testimonials={testimonials}
  />

  <CtaSection
    label="// LET'S CONNECT"
    title="Let's Explore Possibilities Together"
    description="Whether it's tech exchange, project collaboration, or creative collision, feel free to reach out."
    primaryBtn={{ text: 'Send Email', href: 'mailto:hello@qi-lab.dev' }}
    secondaryBtn={{ text: 'GitHub', href: 'https://github.com/qi-lab', external: true }}
  />

</BaseLayout>

<style>
  /* === English homepage: language-specific overrides === */

  /* Hero title: slightly smaller for longer English text */
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    letter-spacing: -0.01em;
  }

  /* Hero stagger animation */
  .hero-stagger {
    opacity: 0;
    animation: heroSlideIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-stagger--1 { animation-delay: 0.1s; }
  .hero-stagger--2 { animation-delay: 0.2s; }
  .hero-stagger--3 { animation-delay: 0.35s; }
  .hero-stagger--4 { animation-delay: 0.5s; }

  @keyframes heroSlideIn {
    from {
      opacity: 0;
      transform: translateX(-24px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Hero fade-in for subtitle and below */
  .hero-fade-in {
    opacity: 0;
    animation: fadeIn 0.8s ease 0.6s both;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Hero stat: transition for counter animation */
  .hero-stat-value {
    transition: color 0.3s ease;
  }

  .hero-stat-text {
    animation: none;
    opacity: 1;
  }

  /* 4B: Large bento card - magazine style with image overlay */
  .bento-card--large {
    min-height: 320px;
    padding: 0;
  }

  .bento-card--large__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .bento-card--large__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .bento-card:hover .bento-card--large__bg img {
    transform: scale(1.05);
  }

  .bento-card--large__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--qi-text-primary) 85%, transparent) 0%,
      color-mix(in srgb, var(--qi-text-primary) 50%, transparent) 50%,
      color-mix(in srgb, var(--qi-text-primary) 30%, transparent) 100%
    );
    z-index: 1;
  }

  .bento-card--large__bg--gradient {
    background: linear-gradient(
      135deg,
      var(--qi-text-primary) 0%,
      var(--qi-brand-emerald) 60%,
      var(--qi-brand-amber) 100%
    );
  }

  .bento-card--large__bg--gradient .bento-card--large__overlay {
    display: none;
  }

  .bento-card__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: var(--qi-space-sm);
    padding: var(--qi-space-xl);
    height: 100%;
    justify-content: flex-end;
  }

  .bento-card--large .bento-card__content {
    justify-content: flex-end;
    padding: var(--qi-space-2xl);
  }

  .bento-card--large .bento-meta {
    position: absolute;
    top: var(--qi-space-xl);
    left: var(--qi-space-xl);
  }

  .bento-card--large .bento-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--qi-text-inverse);
  }

  .bento-card--large .bento-desc {
    color: color-mix(in srgb, var(--qi-text-inverse) 75%, transparent);
  }

  .bento-card--large .bento-tag {
    background: color-mix(in srgb, var(--qi-text-inverse) 15%, transparent);
    color: var(--qi-text-inverse);
  }

  .bento-card--large .bento-date {
    color: color-mix(in srgb, var(--qi-text-inverse) 60%, transparent);
  }

  .bento-card--large .bento-link {
    color: var(--qi-brand-amber);
  }

  .bento-card--large:hover .bento-link {
    color: var(--qi-text-inverse);
  }

  /* Empty state icon (emoji version) */
  .empty-icon {
    font-size: 2.5rem;
  }

  /* --- Responsive overrides --- */
  @media (max-width: 768px) {
    .bento-card--large {
      min-height: 280px;
    }

    .bento-card--large .bento-meta {
      position: static;
    }
  }
</style>

<script>
  // Animate hero stat numbers on page load (compatible with View Transitions)
  function animateStats() {
    const statValues = document.querySelectorAll('.hero-stat-value[data-count]');
    statValues.forEach((el) => {
      // Reset to 0 for re-triggering animation
      el.textContent = '0';
      const target = parseInt(el.getAttribute('data-count') || '0', 10);
      if (isNaN(target) || target === 0) return;
      let current = 0;
      const duration = 1200;
      const step = Math.max(1, Math.ceil(target / (duration / 30)));
      const timer = setInterval(() => {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = String(current);
      }, 30);
    });
  }
  document.addEventListener('astro:page-load', animateStats);
</script>
