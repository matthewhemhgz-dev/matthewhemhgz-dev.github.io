---
import '../../styles/home.css';
import '../../styles/page-home.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import AboutSection from '../../components/sections/AboutSection.astro';
import FeaturedSection from '../../components/sections/FeaturedSection.astro';
import ToolboxSection from '../../components/sections/ToolboxSection.astro';
import PlatformsSection from '../../components/sections/PlatformsSection.astro';
import ResearchSection from '../../components/sections/ResearchSection.astro';
import CtaSection from '../../components/sections/CtaSection.astro';
import SectionDivider from '../../components/decorations/SectionDivider.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en');

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://matthewhemhgz-dev.github.io';

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'QiLab',
  url: siteUrl,
  description:
    'A systematic place for organizing knowledge management, project management, IT/AI skills, and cutting-edge trends',
  inLanguage: 'en-US',
  publisher: {
    '@type': 'Organization',
    name: 'QiLab',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/logo.svg`,
    },
  },
};

const toolboxCategories = [
  {
    label: 'Knowledge Management',
    icon: 'book',
    tools: [
      { name: 'Obsidian', desc: 'Local-first knowledge graph with bidirectional links' },
      { name: 'Graphify', desc: 'LLM-driven knowledge base auto-builder' },
      { name: 'Markdown', desc: 'Single source of truth document format standard' },
    ],
  },
  {
    label: 'Development Tools',
    icon: 'cog',
    tools: [
      { name: 'Trae', desc: 'AI-enhanced code editor' },
      { name: 'Git + GitHub', desc: 'Version control & open source collaboration' },
      { name: 'Docker', desc: 'Containerized deployment & orchestration' },
      { name: 'Astro', desc: 'Zero JS static site generation' },
    ],
  },
  {
    label: 'AI Tools',
    icon: 'robot',
    tools: [
      { name: 'OpenClaw', desc: 'Exclusive digital twin outer brain (model routing)' },
      { name: 'Trae SOLO', desc: 'AI programming agent & Subagent orchestration' },
      { name: 'Superpowers', desc: 'TDD + systematic debugging AI workflow' },
    ],
  },
  {
    label: 'Data & DevOps',
    icon: 'database',
    tools: [
      { name: 'n8n', desc: 'Automated workflow engine' },
      { name: 'Metabase', desc: 'Operational data visualization dashboard' },
      { name: 'PostgreSQL', desc: 'Structured data persistence storage' },
    ],
  },
];

const platforms = [
  {
    name: 'GitHub',
    handle: '@matthewhemhgz-dev',
    url: 'https://github.com/matthewhemhgz-dev',
    icon: 'laptop',
    desc: 'Open source projects & knowledge base',
  },
  {
    name: 'WeChat OA',
    handle: 'Qi-Lab',
    url: '#',
    icon: 'smartphone',
    desc: 'In-depth articles & sharing',
    qrImage: '/images/social/wechat-oa-qr.jpg',
  },
  {
    name: 'Video Channel',
    handle: 'Qi-Lab',
    url: '#',
    icon: 'film',
    desc: 'Short videos',
    qrImage: '/images/social/wechat-oa-qr.jpg',
  },
  {
    name: 'Xiaohongshu',
    handle: 'Qi_Lab',
    url: '#',
    icon: 'book',
    desc: 'Practical tips & content',
    qrImage: '/images/social/xhs-qr.jpg',
  },
  {
    name: 'Douyin',
    handle: 'QiLab',
    url: '#',
    icon: 'zap',
    desc: 'Short videos',
    qrImage: '/images/social/douyin-qr.jpg',
  },
  {
    name: 'GitHub Pages',
    handle: 'QiLab',
    url: 'https://matthewhemhgz-dev.github.io',
    icon: 'globe',
    desc: 'Blog & project showcase',
  },
];
---

<BaseLayout
  title="QiLab"
  description="A systematic place for organizing knowledge management, project management, IT/AI skills, and cutting-edge trends"
  jsonLd={websiteJsonLd}
>
  <HeroSection
    titleLines={['In the Age of Information Overload', 'Structured Knowledge', 'Is True Power']}
    accentIndex={1}
    subtitle="A personal brand dedicated to the architecture of thought and engineering of knowledge."
    watermark="Qi"
    stats={[
      { value: String(allPosts.length), label: 'Articles', dataCount: allPosts.length },
      { value: '5', label: 'Platforms', dataCount: 5 },
      { value: 'Ongoing', label: 'Update', isText: true },
    ]}
    primaryBtn={{ text: 'Learn More', href: '/en/about' }}
    secondaryBtn={{ text: 'Browse Blog', href: '/en/blog' }}
    lang="en"
  />

  <SectionDivider variant="dots" />

  <AboutSection
    classList="qi-anim-scroll-reveal"
    label="// ABOUT"
    title="About QiLab"
    text="QiLab is my digital archive — a systematic place for organizing knowledge management, project management, IT/AI skills, and cutting-edge trends. Through personal experience, practical thinking, and systematic notes, I explore how to make technology truly serve human needs. Adhering to human ontological value, long-termism."
    decoNumber="01"
    decoSlogan="Organize · Verify · Share"
    dashItems={[
      { label: 'Knowledge Management', value: '75+ Items', percentage: 92, color: 'emerald' },
      { label: 'Project Management', value: '7 Certs', percentage: 88, color: 'amber' },
      { label: 'IT/AI Skills', value: '5+ Tools', percentage: 85, color: 'emerald' },
      { label: 'Trends', value: '10+ Years', percentage: 70, color: 'gray' },
    ]}
  />

  <SectionDivider variant="line" />

  <FeaturedSection
    classList="qi-anim-scroll-reveal qi-anim-delay-200"
    label="// FEATURED"
    title="Featured Content"
    posts={recentPosts}
    emptyText="No articles yet, coming soon..."
    emptyIcon="svg"
    readMoreText="Read More"
    browseBlogHref="/en/blog"
    browseBlogText="Browse Blog"
    largeCardLayout={true}
  />

  <SectionDivider variant="diamond" />

  <ToolboxSection
    classList="qi-anim-scroll-reveal qi-anim-delay-300"
    label="// TOOLBOX"
    title="Toolbox"
    categories={toolboxCategories}
  />

  <PlatformsSection
    classList="qi-anim-scroll-reveal qi-anim-delay-400"
    label="// PLATFORMS"
    title="Platform Matrix"
    platforms={platforms}
  />

  <ResearchSection
    classList="qi-anim-scroll-reveal qi-anim-delay-500"
    label="// METHODOLOGY"
    title="Research Methodology"
  />

  <SectionDivider variant="arcs" />

  <CtaSection
    class="qi-anim-scroll-reveal qi-anim-delay-600"
    label="// LET'S CONNECT"
    title="Let's Make Knowledge Truly Useful"
    description="Whether it's knowledge management exchange, AI workflows or project cooperation, feel free to contact us."
    primaryBtn={{ text: 'Email', href: 'mailto:matthewhemhgz@gmail.com' }}
    secondaryBtn={{ text: 'GitHub', href: 'https://github.com/matthewhemhgz-dev', external: true }}
    lang="en"
  />
</BaseLayout>

<script>
  // Animate hero stat numbers on page load (compatible with View Transitions)
  function animateStats() {
    const statValues = document.querySelectorAll('.hero-stat-value[data-count]');
    statValues.forEach((el) => {
      // Reset to 0 to trigger animation again
      el.textContent = '0';
      const target = parseInt(el.getAttribute('data-count') || '0', 10);
      if (isNaN(target) || target === 0) return;
      let current = 0;
      const duration = 1200;
      const step = Math.max(1, Math.ceil(target / (duration / 30)));
      const timer = setInterval(() => {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = String(current);
      }, 30);
    });
  }
  document.addEventListener('astro:page-load', animateStats);
</script>
