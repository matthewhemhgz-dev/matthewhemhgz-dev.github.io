---
import '../styles/about.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import Divider from '../components/global/Divider.astro';
---

<BaseLayout title="关于 | 祈研所" description="了解祈研所的品牌故事、理念与联系方式。">
  <div class="about-page">
    <div class="container">

      <!-- Page Hero -->
      <section class="page-hero" data-reveal>
        <span class="page-label">// ABOUT</span>
        <h1 class="page-title">关于祈研所</h1>
        <p class="page-subtitle">
          一个关于技术、设计与创造力的个人品牌
        </p>
      </section>

      <Divider />

      <!-- Brand Story -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// STORY" title="品牌故事" />
        <div class="about-prose">
          <p>
            祈研所（Qi-Lab）的名字源自对「祈」与「研」二字的理解 —— 「祈」代表对美好事物的向往与追求，
            「研」代表对技术深度的执着探索。二者结合，便是一个致力于在代码与美学之间寻找平衡的创意实验室。
          </p>
          <p>
            我们专注于前端工程、系统设计与创意实验三个交汇领域。在日常实践中，我们使用
            Astro 构建高性能静态站点，用设计令牌（Design Tokens）维护视觉一致性，
            用结构化的知识管理方法（Notion + Obsidian 双轨系统）沉淀技术思考。
            每一个项目都是对「工程美学」理念的验证。
          </p>
          <p>
            在这里，我们不满足于仅仅写出能运行的代码。每一行代码都承载着对优雅的追求，
            每一个设计决策都经过深思熟虑。从像素级的视觉打磨到系统级的架构思考，
            祈研所始终秉持着「精益求精」的工匠精神。我们相信，技术不是冰冷的工具，
            而是表达创意的媒介 —— 好的工程师同时也是好的艺术家，
            他们用代码绘制蓝图，用逻辑编织梦想。
          </p>
        </div>
      </section>

      <Divider />

      <!-- Philosophy -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// PHILOSOPHY" title="设计理念" />
        <div class="philosophy-grid">
          <div class="philosophy-card">
            <span class="philosophy-number">01</span>
            <h3 class="philosophy-title">温暖物理感</h3>
            <p class="philosophy-desc">
              燕麦灰的底色如同温暖的纸张，翡翠绿与琥珀金的点缀如同手绘的标记。
              我们追求数字界面中的物理质感 —— 磨砂玻璃的层次、纸张纹理的温度、
              光影流动的节奏。每一个交互都应该让人感受到「被精心设计过」。
            </p>
          </div>
          <div class="philosophy-card">
            <span class="philosophy-number">02</span>
            <h3 class="philosophy-title">代码即艺术</h3>
            <p class="philosophy-desc">
              代码不仅仅是功能的实现，更是一种创造性的表达。
              我们用 CSS 自定义属性构建 300+ 个设计令牌，用 Astro 的 Islands Architecture
              实现零冗余的交互，用 Playwright 确保每一次提交都经得起考验。
              可读性、可维护性与美学，三者缺一不可。
            </p>
          </div>
          <div class="philosophy-card">
            <span class="philosophy-number">03</span>
            <h3 class="philosophy-title">持续探索</h3>
            <p class="philosophy-desc">
              技术在不断演进，学习永无止境。从 Next.js 到 Astro 的迁移让我们重新理解了
              「默认零 JS」的价值，从 Tailwind 到设计令牌的转型让我们掌握了视觉一致性的本质。
              保持好奇心，勇于尝试新技术，在实践中不断成长。
            </p>
          </div>
        </div>
      </section>

      <Divider />

      <!-- Contact CTA -->
      <section class="about-section" data-reveal>
        <SectionHeader label="// CONTACT" title="取得联系" />
        <div class="contact-cta">
          <p class="cta-text">
            无论是技术合作、项目咨询，还是单纯想聊聊技术与设计，
            都欢迎通过以下方式联系祈研所。
          </p>
          <div class="cta-links">
            <a href="mailto:hello@qi-lab.dev" class="cta-link">
              <span class="cta-label">Email</span>
              <span class="cta-value">hello@qi-lab.dev</span>
            </a>
            <div class="cta-link">
              <span class="cta-label">WeChat</span>
              <span class="cta-value">QiLab_Studio</span>
            </div>
          </div>
          <a href="/#contact" class="cta-btn">查看完整联系方式</a>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

