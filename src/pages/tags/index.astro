---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import { getCollection } from 'astro:content';
import '../../styles/pages/tags.css';

const allPosts = (
  await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh')
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tagCounts = allPosts.flatMap(post => post.data.tags).reduce((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {});

const sortedTagsByPopularity = Object.entries(tagCounts)
  .sort(([tagA, countA], [tagB, countB]) => {
    if (countB !== countA) return countB - countA;
    return tagA.localeCompare(tagB, 'zh');
  })
  .map(([tag, count]) => ({ tag, count }));

const sortedTagsByAlphabet = Object.entries(tagCounts)
  .sort(([tagA], [tagB]) => tagA.localeCompare(tagB, 'zh'))
  .map(([tag, count]) => ({ tag, count }));

const counts = sortedTagsByPopularity.map(item => item.count);
const minCount = Math.min(...counts);
const maxCount = Math.max(...counts);

function getFontSize(count) {
  if (maxCount === minCount) return 1;
  return 0.7 + (count - minCount) / (maxCount - minCount) * 0.8;
}

function getTagSizeClass(count) {
  const ratio = (count - minCount) / (maxCount - minCount);
  if (ratio > 0.8) return 'tag-size-xl';
  if (ratio > 0.5) return 'tag-size-lg';
  if (ratio > 0.2) return 'tag-size-md';
  return 'tag-size-sm';
}

function getHotTagClass(count, index) {
  if (count >= maxCount * 0.7 && index < 5) return 'tag-hot';
  return '';
}

const totalTags = sortedTagsByPopularity.length;
const totalArticles = allPosts.length;
---

<BaseLayout
  title="标签 — 祈研所 Qi-Lab"
  description="祈研所所有内容标签 — 探索 AI、知识管理、前端开发等主题的深度文章"
>
  <div class="container tags-page">
    <h1 class="sr-only">标签</h1>
    
    <section class="tags-stats-section" data-reveal>
      <div class="tags-stats-grid">
        <div class="tags-stat-card">
          <div class="tags-stat-number">{totalTags}</div>
          <div class="tags-stat-label">标签总数</div>
        </div>
        <div class="tags-stat-card">
          <div class="tags-stat-number">{totalArticles}</div>
          <div class="tags-stat-label">文章总数</div>
        </div>
        <div class="tags-stat-card">
          <div class="tags-stat-number">{sortedTagsByPopularity[0]?.count || 0}</div>
          <div class="tags-stat-label">热门标签文章数</div>
        </div>
      </div>
    </section>

    <section class="tags-cloud-section" data-reveal>
      <SectionHeader label="// TAGS" title="标签云" />
      <div class="tags-cloud-controls">
        <button class="tags-sort-btn active" data-sort="popularity">按热度</button>
        <button class="tags-sort-btn" data-sort="alphabet">按字母</button>
      </div>
      
      <div class="tags-cloud-wrapper">
        <div class="tags-cloud tags-cloud-popularity">
          {sortedTagsByPopularity.map(({ tag, count }, index) => (
            <a 
              href={`/tags/${tag}/`} 
              class={`tag-link ${getTagSizeClass(count)} ${getHotTagClass(count, index)}`}
              title={`${count} 篇文章`}
            >
              <span class="tag-text">#{tag}</span>
              <span class="tag-count-badge">{count}</span>
            </a>
          ))}
        </div>
        
        <div class="tags-cloud tags-cloud-alphabet hidden">
          {sortedTagsByAlphabet.map(({ tag, count }) => (
            <a 
              href={`/tags/${tag}/`} 
              class={`tag-link ${getTagSizeClass(count)}`}
              title={`${count} 篇文章`}
            >
              <span class="tag-text">#{tag}</span>
              <span class="tag-count-badge">{count}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="tags-posts-section" data-reveal>
      <SectionHeader label="// RECENT" title="最新文章" />
      <div class="tags-posts-grid">
        {allPosts.map((post) => (
          <a href={`/blog/${post.id.replace('zh/', '')}/`} class="tags-post-card">
            <div class="tags-post-meta">
              <span class="tags-post-category">{post.data.category}</span>
              <time class="tags-post-date">
                {post.data.pubDate.toLocaleDateString('zh-CN', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </div>
            <h3 class="tags-post-title">{post.data.title}</h3>
            {post.data.description && <p class="tags-post-desc">{post.data.description}</p>}
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="tags-post-tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="tags-post-tag">#{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const sortBtns = document.querySelectorAll('.tags-sort-btn');
      const clouds = {
        popularity: document.querySelector('.tags-cloud-popularity'),
        alphabet: document.querySelector('.tags-cloud-alphabet')
      };

      sortBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          sortBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          const sort = btn.dataset.sort;
          Object.values(clouds).forEach(cloud => cloud.classList.add('hidden'));
          clouds[sort].classList.remove('hidden');
        });
      });
    });
  </script>
</BaseLayout>
