---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const allTags = [...new Set(allPosts.flatMap(post => post.data.tags))].sort();
---

<BaseLayout title="标签 — 祈研所 Qi-Lab" description="所有内容标签">
  <main class="container tags-page">
    <!-- Tag Cloud Section -->
    <section class="tags-cloud-section" data-reveal>
      <SectionHeader label="// TAGS" title="标签" />
      <div class="tags-cloud">
        {allTags.map(tag => (
          <a href={`/tags/${tag}/`} class="tag-link">
            #{tag}
          </a>
        ))}
      </div>
    </section>

    <!-- Recent Posts Section -->
    <section class="tags-posts-section" data-reveal>
      <SectionHeader label="// RECENT" title="最新文章" />
      <div class="tags-posts-grid">
        {allPosts.map(post => (
          <a href={`/blog/${post.id}/`} class="tags-post-card">
            <div class="tags-post-meta">
              <span class="tags-post-category">{post.data.category}</span>
              <time class="tags-post-date">
                {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
            <h3 class="tags-post-title">{post.data.title}</h3>
            {post.data.description && (
              <p class="tags-post-desc">{post.data.description}</p>
            )}
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="tags-post-tags">
                {post.data.tags.slice(0, 3).map(tag => (
                  <span class="tags-post-tag">#{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .tags-page {
    padding-top: var(--qi-space-5xl);
    padding-bottom: var(--qi-space-5xl);
  }

  .tags-cloud-section {
    margin-bottom: var(--qi-space-5xl);
  }

  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--qi-space-md);
  }

  .tag-link {
    display: inline-block;
    padding: var(--qi-space-sm) var(--qi-space-lg);
    background: var(--qi-surface-sub);
    border-radius: var(--qi-radius-button);
    color: var(--qi-text-primary);
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-sm);
    transition: background-color var(--qi-transition-fast), color var(--qi-transition-fast), transform var(--qi-transition-fast);
    text-decoration: none;
  }

  .tag-link:hover {
    background: var(--qi-brand-emerald);
    color: #fff;
    transform: translateY(-2px);
  }

  /* Posts grid */
  .tags-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--qi-gap-bento);
  }

  .tags-post-card {
    display: block;
    background: var(--qi-surface-main);
    color: var(--qi-text-inverse);
    border-radius: var(--qi-radius-card);
    padding: var(--qi-space-xl);
    transition: transform var(--qi-transition), box-shadow var(--qi-transition);
    text-decoration: none;
  }

  .tags-post-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--qi-shadow-hover-warm);
  }

  .tags-post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--qi-space-md);
  }

  .tags-post-category {
    display: inline-block;
    background: var(--qi-brand-emerald);
    color: #fff;
    padding: 2px 10px;
    border-radius: var(--qi-radius-sm);
    font-size: 0.75rem;
  }

  .tags-post-date {
    font-size: var(--qi-text-xs);
    opacity: 0.6;
  }

  .tags-post-title {
    font-family: var(--qi-font-serif);
    font-size: var(--qi-text-xl);
    margin-bottom: var(--qi-space-sm);
    line-height: 1.4;
  }

  .tags-post-desc {
    color: var(--qi-text-inverse);
    opacity: 0.7;
    font-size: var(--qi-text-sm);
    margin-bottom: var(--qi-space-md);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags-post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--qi-space-xs);
  }

  .tags-post-tag {
    font-family: var(--qi-font-mono);
    font-size: 0.7rem;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .tags-posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
