---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Divider from '../../components/global/Divider.astro';
import { getCollection } from 'astro:content';
import '../../styles/pages/tags.css';

const allPosts = (
  await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh')
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Calculate tag counts
const tagCounts: Record<string, number> = allPosts
  .flatMap((post) => post.data.tags)
  .reduce(
    (acc: Record<string, number>, tag) => {
      acc[tag] = (acc[tag] || 0) + 1;
      return acc;
    },
    {} as Record<string, number>,
  );

// Tag categories
const tagCategories = {
  '知识管理': ['知识管理', 'PKM', 'Obsidian', 'Zettelkasten', '笔记方法', '知识图谱', '信息管理'],
  'AI 技术': ['AI', '大模型', 'LLM', 'Agent', '人工智能', '机器学习', '深度学习'],
  '前端开发': ['前端', 'JavaScript', 'CSS', 'Astro', 'React', 'TypeScript', 'Web开发'],
  '项目管理': ['项目管理', 'PMP', '敏捷', 'Scrum', '看板', '时间管理', '团队协作'],
  '工具推荐': ['工具', '效率工具', '生产力', '软件推荐', '工作流', '自动化'],
  '其他': []
};

// Organize tags into categories
const organizedTags = Object.entries(tagCategories).reduce((acc, [category, categoryTags]) => {
  const tags = Object.entries(tagCounts)
    .filter(([tag]) => categoryTags.includes(tag))
    .map(([tag, count]) => ({ tag, count }))
    .sort((a, b) => b.count - a.count);
  
  if (tags.length > 0) {
    acc[category] = tags;
  }
  return acc;
}, {} as Record<string, Array<{ tag: string; count: number }>>);

// Add remaining tags to '其他' category
const categorizedTags = new Set(Object.values(tagCategories).flat());
const remainingTags = Object.entries(tagCounts)
  .filter(([tag]) => !categorizedTags.has(tag))
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => b.count - a.count);

if (remainingTags.length > 0) {
  organizedTags['其他'] = remainingTags;
}

// Calculate min/max counts for size scaling
const allCounts = Object.values(organizedTags).flat().map(item => item.count);
const minCount = Math.min(...allCounts);
const maxCount = Math.max(...allCounts);

// Function to calculate font size based on count
function getFontSize(count: number) {
  if (maxCount === minCount) return 1;
  return 0.8 + ((count - minCount) / (maxCount - minCount)) * 0.6; // Range from 0.8 to 1.4
}

// Get current filter from URL
const url = new URL(Astro.request.url);
const selectedCategory = url.searchParams.get('category') || '';
---

<BaseLayout
  title="标签 — 祈研所 Qi-Lab"
  description="祈研所所有内容标签 — 探索 AI、知识管理、前端开发等主题的深度文章"
>
  <div class="container tags-page">
    <!-- Page Hero -->
    <section class="page-hero" data-reveal>
      <span class="page-label">TAGS</span>
      <h1 class="page-title">标签</h1>
      <p class="page-subtitle">探索 AI、知识管理、前端开发等主题的深度文章</p>
    </section>

    <Divider />

    <!-- Category Filter -->
    <section class="filter-section" data-reveal>
      <div class="filter-container">
        <h3 class="filter-title">标签分类</h3>
        <div class="filter-buttons">
          <a href="/tags/" class={`filter-btn ${!selectedCategory ? 'active' : ''}`}>全部</a>
          {Object.keys(organizedTags).map(category => (
            <a 
              key={category} 
              href={`/tags/?category=${encodeURIComponent(category)}`} 
              class={`filter-btn ${selectedCategory === category ? 'active' : ''}`}
            >
              {category}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Tag Cloud Section -->
    <section class="about-section" data-reveal>
      <SectionHeader label="TAG CLOUD" title={selectedCategory ? `${selectedCategory}标签` : "标签云"} />
      {Object.entries(organizedTags).map(([category, tags]) => {
        if (selectedCategory && selectedCategory !== category) return null;
        return (
          <div key={category} class="tag-category">
            <h3 class="tag-category-title">{category}</h3>
            <div class="tags-cloud">
              {
                tags.map(({ tag, count }) => (
                  <a
                    key={tag}
                    href={`/tags/${tag}/`}
                    class="tag-link"
                    style={`font-size: ${getFontSize(count)}em;`}
                    title={`${count} 篇文章`}
                  >
                    #{tag} <span class="tag-count">({count})</span>
                  </a>
                ))
              }
            </div>
          </div>
        );
      })}
    </section>

    <Divider />

    <!-- Recent Posts Section -->
    <section class="about-section" data-reveal>
      <SectionHeader label="RECENT" title="最新文章" />
      <div class="tags-posts-grid">
        {
          allPosts.map((post) => (
            <a href={`/blog/${post.id.replace('zh/', '')}/`} class="tags-post-card">
              <div class="tags-post-meta">
                <span class="tags-post-category">{post.data.category}</span>
                <time class="tags-post-date">
                  {post.data.pubDate.toLocaleDateString('zh-CN', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              </div>
              <h3 class="tags-post-title">{post.data.title}</h3>
              {post.data.description && <p class="tags-post-desc">{post.data.description}</p>}
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="tags-post-tags">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="tags-post-tag">#{tag}</span>
                  ))}
                </div>
              )}
            </a>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
