---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh');
  const allTags = [...new Set(allPosts.flatMap(post => post.data.tags))];
  return allTags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts.filter(p => p.data.tags.includes(tag)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag} — 祈研所 Qi-Lab`} description={`${tag} 相关文章 — 祈研所的深度技术分享与思考`}>
  <main class="tag-page container">
    <a href="/tags" class="tag-back-link">← 所有标签</a>
    <h1 class="tag-heading">#{tag}</h1>
    <div class="tag-post-list">
      {posts.map(post => (
        <a href={`/blog/${post.id.replace('zh/', '')}/`} class="tag-post-card">
          <h2 class="tag-post-title">{post.data.title}</h2>
          <time class="tag-post-date">{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .tag-page {
    padding-top: 120px;
    padding-bottom: 80px;
  }

  .tag-back-link {
    color: var(--qi-brand-emerald);
    font-size: 0.9rem;
  }

  .tag-heading {
    font-family: var(--qi-font-serif);
    font-size: 2.5rem;
    margin: 1rem 0 2rem;
  }

  .tag-post-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .tag-post-card {
    display: block;
    padding: 1.25rem;
    background: var(--qi-surface-main);
    color: var(--qi-on-surface);
    border-radius: var(--qi-radius-card);
    text-decoration: none;
    transition: transform var(--qi-transition), box-shadow var(--qi-transition);
    border: 1px solid var(--qi-border-subtle);
  }

  .tag-post-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--qi-shadow-hover);
  }

  .tag-post-title {
    font-family: var(--qi-font-serif);
    font-size: 1.15rem;
    margin-bottom: 0.4rem;
  }

  .tag-post-date {
    font-size: 0.8rem;
    color: var(--qi-on-surface-dim);
  }

  @media (max-width: 768px) {
    .tag-page {
      padding-top: 100px;
      padding-bottom: 60px;
    }

    .tag-heading {
      font-size: 1.8rem;
      margin: 0.75rem 0 1.5rem;
    }

    .tag-post-card {
      padding: 1rem;
    }

    .tag-post-title {
      font-size: 1.05rem;
    }
  }

  @media (min-width: 1440px) {
    .tag-page {
      max-width: 900px;
      margin-left: auto;
      margin-right: auto;
    }

    .tag-heading {
      font-size: 3rem;
    }
  }

  @media (min-width: 2560px) {
    .tag-heading {
      font-size: 3.5rem;
    }

    .tag-post-title {
      font-size: 1.35rem;
    }

    .tag-post-card {
      padding: 1.5rem;
    }
  }
</style>
