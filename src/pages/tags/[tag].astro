---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import { getCollection } from 'astro:content';
import '../../styles/pages/tag.css';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh');
  const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];
  return allTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'zh');
const tagCounts = allPosts.flatMap(post => post.data.tags).reduce((acc, t) => {
  acc[t] = (acc[t] || 0) + 1;
  return acc;
}, {});

const counts = Object.values(tagCounts);
const minCount = Math.min(...counts);
const maxCount = Math.max(...counts);
const count = tagCounts[tag];
const ratio = (count - minCount) / (maxCount - minCount);

let sizeLabel = '冷门';
if (ratio > 0.8) sizeLabel = '极热门';
else if (ratio > 0.5) sizeLabel = '热门';
else if (ratio > 0.2) sizeLabel = '普通';
---

<BaseLayout
  title={`#${tag} — 祈研所 Qi-Lab`}
  description={`${tag} 相关文章 — 祈研所的深度技术分享与思考`}
>
  <div class="tag-page container">
    <a href="/tags" class="tag-back-link">← 返回标签列表</a>
    
    <header class="tag-header">
      <div class="tag-info">
        <h1 class="tag-heading">#{tag}</h1>
        <div class="tag-meta">
          <span class="tag-article-count">{posts.length} 篇文章</span>
          <span class="tag-popularity-badge">{sizeLabel}</span>
        </div>
      </div>
      
      <div class="tag-stats">
        <div class="tag-stat-item">
          <div class="tag-stat-value">{posts.length}</div>
          <div class="tag-stat-label">文章数</div>
        </div>
        <div class="tag-stat-item">
          <div class="tag-stat-value">{posts[0]?.data.pubDate.getFullYear() || new Date().getFullYear()}</div>
          <div class="tag-stat-label">最早年份</div>
        </div>
      </div>
    </header>

    <SectionHeader label="// ARTICLES" title="相关文章" />
    <div class="tag-post-list">
      {posts.map((post) => (
        <a href={`/blog/${post.id.replace('zh/', '')}/`} class="tag-post-card">
          <div class="tag-post-main">
            <h2 class="tag-post-title">{post.data.title}</h2>
            {post.data.description && <p class="tag-post-desc">{post.data.description}</p>}
          </div>
          <div class="tag-post-footer">
            <span class="tag-post-category">{post.data.category}</span>
            <time class="tag-post-date">
              {post.data.pubDate.toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </div>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="tag-post-tags">
              {post.data.tags.slice(0, 4).map((t) => (
                <span class="tag-post-tag">#{t}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
