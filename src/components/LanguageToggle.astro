---
import { Astro } from 'astro';

const currentLocale = Astro.url.pathname.startsWith('/en') ? 'en' : 'zh';
const locales = ['zh', 'en'];

const isDefaultLocale = (locale) => locale === 'zh';

// 生成对应语言的路径
const getLanguagePath = (locale) => {
  const currentPath = Astro.url.pathname;
  
  // 移除当前语言前缀
  let basePath = currentPath;
  if (currentLocale === 'en') {
    basePath = basePath.replace(/^\/en/, '');
  }
  
  // 确保路径以斜杠开头
  if (!basePath.startsWith('/')) {
    basePath = `/${basePath}`;
  }
  
  // 添加目标语言前缀
  if (isDefaultLocale(locale)) {
    return basePath === '' ? '/' : basePath;
  } else {
    return `/en${basePath === '/' ? '' : basePath}`;
  }
};
---

<div class="flex gap-1 bg-[var(--qi-base-04)] dark:bg-bg-surface rounded-md p-0.5">
  {locales.map((locale) => (
    <a
      key={locale}
      href={getLanguagePath(locale)}
      class={`px-3 py-1.5 rounded-sm font-mono text-xs font-medium transition-colors duration-200 no-underline min-h-9 flex items-center justify-center ${
        currentLocale === locale
          ? 'bg-[var(--qi-brand-emerald-12)] text-primary'
          : 'text-text-muted hover:text-text-primary'
      }`}
      aria-label={`Switch to ${locale === 'zh' ? '中文' : 'English'}`}
    >
      {locale === 'zh' ? '中文' : 'English'}
    </a>
  ))}
</div>