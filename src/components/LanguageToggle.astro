---
import { Astro } from 'astro';

const currentLocale = Astro.url.pathname.startsWith('/en') ? 'en' : 'zh';
const locales = ['zh', 'en'];

const isDefaultLocale = (locale) => locale === 'zh';

// 生成对应语言的路径
const getLanguagePath = (locale) => {
  const currentPath = Astro.url.pathname;
  
  // 移除当前语言前缀
  let basePath = currentPath;
  if (currentLocale === 'en') {
    basePath = basePath.replace(/^\/en/, '');
  }
  
  // 确保路径以斜杠开头
  if (!basePath.startsWith('/')) {
    basePath = `/${basePath}`;
  }
  
  // 添加目标语言前缀
  if (isDefaultLocale(locale)) {
    return basePath === '' ? '/' : basePath;
  } else {
    return `/en${basePath === '/' ? '' : basePath}`;
  }
};
---

<div class="lang-toggle-wrapper">
  {locales.map((locale) => (
    <a
      href={getLanguagePath(locale)}
      class:list={['lang-toggle-item', { active: currentLocale === locale }]}
      aria-label={`Switch to ${locale === 'zh' ? '中文' : 'English'}`}
    >
      {locale === 'zh' ? '中文' : 'English'}
    </a>
  ))}
</div>

<style>
  .lang-toggle-wrapper {
    display: flex;
    gap: 4px;
    background: var(--qi-base-04);
    padding: 3px; /* Slightly more padding for breathability */
    border-radius: var(--qi-radius-md);
    border: 1px solid var(--qi-base-06);
    flex-shrink: 0;
    width: fit-content;
  }

  .lang-toggle-item {
    padding: 4px 12px; /* Slightly reduced horizontal padding */
    border-radius: var(--qi-radius-sm);
    font-family: var(--qi-font-mono);
    font-size: 11px;
    font-weight: var(--qi-weight-medium);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    min-height: 28px; /* Slightly reduced height to fit better in small bars */
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--qi-text-secondary);
    opacity: 0.75;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .lang-toggle-item:hover {
    color: var(--qi-text-primary);
    background: var(--qi-base-03);
    opacity: 1;
  }

  .lang-toggle-item.active {
    background: var(--qi-brand-emerald-10);
    color: var(--qi-brand-emerald);
    box-shadow: var(--qi-shadow-sm);
    opacity: 1;
  }

  :global(.dark) .lang-toggle-wrapper {
    background: var(--qi-surface-sub);
    border-color: var(--qi-border-strong);
  }

  :global(.dark) .lang-toggle-item.active {
    background: var(--qi-brand-emerald-10);
    color: var(--qi-brand-emerald);
  }
</style>