---
import { Astro } from 'astro';

const currentLocale = Astro.url.pathname.startsWith('/en') ? 'en' : 'zh';
const locales = ['zh', 'en'];

const isDefaultLocale = (locale) => locale === 'zh';

// 生成对应语言的路径
const getLanguagePath = (locale) => {
  const currentPath = Astro.url.pathname;
  
  // 移除当前语言前缀
  let basePath = currentPath;
  if (currentLocale === 'en') {
    basePath = basePath.replace(/^\/en/, '');
  }
  
  // 确保路径以斜杠开头
  if (!basePath.startsWith('/')) {
    basePath = `/${basePath}`;
  }
  
  // 添加目标语言前缀
  if (isDefaultLocale(locale)) {
    return basePath === '' ? '/' : basePath;
  } else {
    return `/en${basePath === '/' ? '' : basePath}`;
  }
};
---

<div class="language-toggle">
  {locales.map((locale) => (
    <a
      key={locale}
      href={getLanguagePath(locale)}
      class={`language-toggle__link ${currentLocale === locale ? 'active' : ''}`}
      aria-label={`Switch to ${locale === 'zh' ? '中文' : 'English'}`}
    >
      {locale === 'zh' ? '中文' : 'English'}
    </a>
  ))}
</div>

<style>
  .language-toggle {
    display: flex;
    gap: 0.25rem;
    background: var(--qi-base-04);
    border-radius: var(--qi-radius-md);
    padding: 2px;
  }

  .language-toggle__link {
    padding: 0.375rem 0.75rem;
    border-radius: var(--qi-radius-sm);
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-xs);
    font-weight: 500;
    color: var(--qi-text-muted);
    transition: all 0.2s ease;
    text-decoration: none;
    min-height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .language-toggle__link:hover {
    color: var(--qi-text-primary);
  }

  .language-toggle__link.active {
    background: var(--qi-brand-emerald-12);
    color: var(--qi-brand-emerald);
  }

  /* Dark mode styles */
  :global(.dark) .language-toggle {
    background: var(--qi-bg-secondary);
  }

  :global(.dark) .language-toggle__link {
    color: var(--qi-text-muted);
  }

  :global(.dark) .language-toggle__link:hover {
    color: var(--qi-text-primary);
  }

  :global(.dark) .language-toggle__link.active {
    background: var(--qi-brand-emerald-12);
    color: var(--qi-brand-emerald);
  }
</style>