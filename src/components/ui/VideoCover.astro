---
interface Props {
  src: string;
  poster?: string;
  fallbackImage?: string;
  alt?: string;
  autoplay?: boolean;
  muted?: boolean;
  loop?: boolean;
  showControls?: boolean;
  width?: number;
  height?: number;
  class?: string;
}

const {
  src,
  poster,
  fallbackImage,
  alt = '',
  autoplay = true,
  muted = true,
  loop = true,
  showControls = false,
  width = 1200,
  height = 675,
  class: className = '',
} = Astro.props;
---

<div
  class:list={['video-cover', className]}
  data-autoplay={autoplay}
  data-muted={muted}
  data-loop={loop}
  data-show-controls={showControls}
>
  <div class="video-cover__placeholder" aria-hidden="true">
    {poster && (
      <img
        src={poster}
        alt=""
        class="video-cover__poster"
        loading="eager"
        decoding="async"
        width={width}
        height={height}
      />
    )}
    {!poster && fallbackImage && (
      <img
        src={fallbackImage}
        alt=""
        class="video-cover__poster"
        loading="eager"
        decoding="async"
        width={width}
        height={height}
      />
    )}
  </div>

  <video
    class="video-cover__video"
    preload="metadata"
    poster={poster || fallbackImage}
    width={width}
    height={height}
    aria-label={alt}
    playsinline
  >
    <source src={src} type="video/mp4" />
    {alt && <track kind="captions" />}
  </video>

  {showControls && (
    <button class="video-cover__play-btn" type="button" aria-label="播放/暂停视频">
      <svg class="video-cover__play-icon" width="48" height="48" viewBox="0 0 48 48" fill="none">
        <circle cx="24" cy="24" r="23" stroke="currentColor" stroke-width="2" fill="rgba(0,0,0,0.5)" />
        <path d="M19 14L34 24L19 34V14Z" fill="currentColor" />
      </svg>
      <svg class="video-cover__pause-icon" width="48" height="48" viewBox="0 0 48 48" fill="none">
        <circle cx="24" cy="24" r="23" stroke="currentColor" stroke-width="2" fill="rgba(0,0,0,0.5)" />
        <rect x="16" y="14" width="5" height="20" fill="currentColor" />
        <rect x="27" y="14" width="5" height="20" fill="currentColor" />
      </svg>
    </button>
  )}

  <div class="video-cover__loading" aria-hidden="true">
    <div class="video-cover__spinner"></div>
  </div>
</div>

<style>
  .video-cover {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-lg, 12px);
    background: var(--color-surface, #1a1a1a);
    aspect-ratio: 16 / 9;
  }

  .video-cover__placeholder {
    position: absolute;
    inset: 0;
    z-index: 1;
    transition: opacity 0.4s ease-out;
  }

  .video-cover--loaded .video-cover__placeholder {
    opacity: 0;
    pointer-events: none;
  }

  .video-cover__poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .video-cover__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.4s ease-out;
    background: transparent;
  }

  .video-cover--loaded .video-cover__video {
    opacity: 1;
  }

  .video-cover__play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: white;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.2s ease;
  }

  .video-cover:hover .video-cover__play-btn,
  .video-cover:focus-within .video-cover__play-btn {
    opacity: 1;
  }

  .video-cover__play-btn:hover {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .video-cover__play-btn:focus {
    outline: 2px solid var(--color-primary, #3b82f6);
    outline-offset: 4px;
    border-radius: 50%;
  }

  .video-cover--playing .video-cover__play-icon {
    display: none;
  }

  .video-cover__pause-icon {
    display: none;
  }

  .video-cover--playing .video-cover__pause-icon {
    display: block;
  }

  .video-cover__loading {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.3);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .video-cover--loading .video-cover__loading {
    opacity: 1;
  }

  .video-cover__spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255, 255, 255, 0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .video-cover__video {
      display: none;
    }

    .video-cover__placeholder {
      opacity: 1 !important;
    }

    .video-cover__play-btn {
      display: none;
    }

    .video-cover--loaded .video-cover__placeholder {
      opacity: 1 !important;
    }
  }
</style>

<script>
  function initVideoCovers() {
    const videoCovers = document.querySelectorAll('.video-cover');

    videoCovers.forEach((container) => {
      if (container.hasAttribute('data-initialized')) return;
      container.setAttribute('data-initialized', 'true');

      const video = container.querySelector('.video-cover__video') as HTMLVideoElement;
      const playBtn = container.querySelector('.video-cover__play-btn') as HTMLButtonElement;

      if (!video) return;

      const autoplay = container.getAttribute('data-autoplay') === 'true';
      const muted = container.getAttribute('data-muted') === 'true';
      const loop = container.getAttribute('data-loop') === 'true';
      const showControls = container.getAttribute('data-show-controls') === 'true';

      video.muted = muted;
      video.loop = loop;

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReducedMotion) {
        container.classList.add('video-cover--loaded');
        return;
      }

      const handleCanPlay = () => {
        container.classList.remove('video-cover--loading');
        container.classList.add('video-cover--loaded');

        if (autoplay && !showControls) {
          video.play().catch(() => {
            if (playBtn) playBtn.style.opacity = '1';
          });
        }
      };

      if (video.readyState >= 3) {
        handleCanPlay();
      } else {
        video.addEventListener('canplay', handleCanPlay, { once: true });
        video.addEventListener('canplaythrough', handleCanPlay, { once: true });
      }

      if (showControls && playBtn) {
        playBtn.addEventListener('click', () => {
          if (video.paused) {
            container.classList.add('video-cover--loading');
            video.play().then(() => {
              container.classList.remove('video-cover--loading');
              container.classList.add('video-cover--playing');
            }).catch(() => {
              container.classList.remove('video-cover--loading');
            });
          } else {
            video.pause();
            container.classList.remove('video-cover--playing');
          }
        });

        video.addEventListener('play', () => {
          container.classList.add('video-cover--playing');
        });

        video.addEventListener('pause', () => {
          container.classList.remove('video-cover--playing');
        });
      }

      video.addEventListener('waiting', () => {
        container.classList.add('video-cover--loading');
      });

      video.addEventListener('playing', () => {
        container.classList.remove('video-cover--loading');
      });
    });
  }

  document.addEventListener('astro:page-load', initVideoCovers);

  if (document.readyState === 'complete') {
    initVideoCovers();
  }

  window.matchMedia('(prefers-reduced-motion: reduce)').addEventListener('change', (e) => {
    if (e.matches) {
      const videos = document.querySelectorAll('.video-cover__video') as NodeListOf<HTMLVideoElement>;
      videos.forEach((video) => {
        video.pause();
      });
    }
  });
</script>
