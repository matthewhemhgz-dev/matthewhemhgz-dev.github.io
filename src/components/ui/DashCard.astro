---
interface Props {
  label?: string;
  value?: string;
  percentage?: number;
  color?: 'emerald' | 'amber' | 'gray';
}

const {
  label = 'Metric',
  value = '0',
  percentage = 0,
  color = 'emerald',
} = Astro.props;

const clampedPercentage = Math.max(0, Math.min(100, percentage));

const colorMap: Record<string, { bar: string; bg: string; glow: string }> = {
  emerald: {
    bar: 'var(--qi-emerald)',
    bg: 'rgba(46, 125, 92, 0.1)',
    glow: 'rgba(46, 125, 92, 0.3)',
  },
  amber: {
    bar: 'var(--qi-amber)',
    bg: 'rgba(229, 169, 60, 0.1)',
    glow: 'rgba(229, 169, 60, 0.3)',
  },
  gray: {
    bar: 'var(--qi-charcoal-lighter)',
    bg: 'rgba(42, 42, 42, 0.06)',
    glow: 'rgba(42, 42, 42, 0.15)',
  },
};

const colors = colorMap[color] || colorMap.emerald;
---

<div class="dash-card" data-color={color}>
  <div class="card-header">
    <span class="card-label">{label}</span>
    <span class="card-value">{value}</span>
  </div>
  <div class="progress-track">
    <div
      class="progress-fill"
      style={`--fill-width: ${clampedPercentage}%; --bar-color: ${colors.bar}; --bar-bg: ${colors.bg}; --bar-glow: ${colors.glow};`}
    >
      <span class="progress-pct">{clampedPercentage}%</span>
    </div>
  </div>
</div>

<style>
  .dash-card {
    background: var(--qi-oat);
    border: 1px solid rgba(42, 42, 42, 0.06);
    border-radius: var(--qi-radius-lg);
    padding: var(--qi-space-lg);
    transition: box-shadow var(--qi-transition-base), transform var(--qi-transition-base);
  }

  .dash-card:hover {
    box-shadow: var(--qi-shadow-md);
    transform: translateY(-2px);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--qi-space-md);
  }

  .card-label {
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-xs);
    font-weight: 500;
    color: var(--qi-charcoal-lighter);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .card-value {
    font-family: var(--qi-font-serif);
    font-size: var(--qi-text-2xl);
    font-weight: 700;
    color: var(--qi-charcoal);
    line-height: 1;
  }

  .progress-track {
    width: 100%;
    height: 6px;
    background: rgba(42, 42, 42, 0.06);
    border-radius: var(--qi-radius-full);
    overflow: hidden;
    position: relative;
  }

  .progress-fill {
    position: relative;
    height: 100%;
    width: var(--fill-width, 0%);
    background: var(--bar-color, var(--qi-emerald));
    border-radius: var(--qi-radius-full);
    transition: width 1s cubic-bezier(0.34, 1.56, 0.64, 1);
    animation: fill-in 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    box-shadow: 0 0 8px var(--bar-glow, transparent);
  }

  @keyframes fill-in {
    from {
      width: 0%;
    }
    to {
      width: var(--fill-width, 0%);
    }
  }

  .progress-pct {
    position: absolute;
    right: 0;
    top: -22px;
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-xs);
    color: var(--bar-color, var(--qi-emerald));
    font-weight: 600;
    opacity: 0;
    animation: fade-up 0.5s ease 0.8s forwards;
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
