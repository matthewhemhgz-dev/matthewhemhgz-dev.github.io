---
interface Props {
  label?: string;
  value?: string;
  percentage?: number;
  color?: 'emerald' | 'amber' | 'gray';
}

const { label = 'Metric', value = '0', percentage = 0, color = 'emerald' } = Astro.props;

const clampedPercentage = Math.max(0, Math.min(100, percentage));

const colorMap: Record<string, { bar: string; bg: string; glow: string }> = {
  emerald: {
    bar: 'var(--qi-brand-emerald)',
    bg: 'var(--qi-brand-emerald-10)',
    glow: 'var(--qi-brand-emerald-30)',
  },
  amber: {
    bar: 'var(--qi-amber)',
    bg: 'var(--qi-brand-amber-10)',
    glow: 'var(--qi-brand-amber-30)',
  },
  gray: {
    bar: 'var(--qi-text-muted)',
    bg: 'var(--qi-base-06)',
    glow: 'var(--qi-base-15)',
  },
};

const colors = colorMap[color] || colorMap.emerald;
---

<div
  class="bg-bg-base border border-[var(--qi-base-06)] rounded-lg p-lg hover:shadow-md hover:-translate-y-0.5 transition-all duration-base tilt-card"
  data-color={color}
  role="status"
  aria-label={`${label}: ${value} (${clampedPercentage}%)`}
>
  <div class="flex justify-between items-baseline mb-md">
    <span class="font-mono text-xs font-medium text-text-muted uppercase tracking-[0.08em]"
      >{label}</span
    >
    <span class="font-serif text-2xl font-bold text-text-primary leading-none">{value}</span>
  </div>
  <div class="w-full h-1.5 bg-[var(--qi-base-06)] rounded-full overflow-hidden relative">
    <div
      class="relative h-full rounded-full transition-all duration-1000 ease-spring animate-fillIn"
      style={`width: ${clampedPercentage}%; background: ${colors.bar}; box-shadow: 0 0 8px ${colors.glow};`}
    >
      <span
        class="absolute right-0 -top-5.5 font-mono text-xs font-semibold opacity-0 animate-fadeUp"
        style="color: ${colors.bar}">{clampedPercentage}%</span
      >
    </div>
  </div>
</div>
