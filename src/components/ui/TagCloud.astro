---
interface Tag {
  text: string;
  size?: 'sm' | 'md' | 'lg';
  href?: string;
}

interface Props {
  tags?: Tag[];
  variant?: 'light' | 'dark';
}

const {
  tags = [],
  variant = 'light',
} = Astro.props;

const sizeConfig = {
  sm: { padding: '6px 12px', fontSize: 'var(--qi-text-xs)' },
  md: { padding: '8px 16px', fontSize: 'var(--qi-text-sm)' },
  lg: { padding: '10px 20px', fontSize: 'var(--qi-text-base)' },
};
---

<div class:list={['tag-cloud', `tag-cloud--${variant}`]}>
  {tags.map((tag) => {
    const size = tag.size || 'md';
    const config = sizeConfig[size];
    const Tag = tag.href ? 'a' : 'span';

    return (
      <Tag
        href={tag.href}
        class:list={['tag-item', `tag-item--${size}`]}
        style={`--tag-padding: ${config.padding}; --tag-font-size: ${config.fontSize};`}
      >
        {tag.text}
      </Tag>
    );
  })}
</div>

<style>
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--qi-space-sm);
    align-items: center;
  }

  .tag-item {
    display: inline-flex;
    align-items: center;
    padding: var(--tag-padding, 8px 16px);
    font-family: var(--qi-font-mono);
    font-size: var(--tag-font-size, var(--qi-text-sm));
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: var(--qi-radius-full);
    transition: transform var(--qi-transition-fast), box-shadow var(--qi-transition-fast), background-color var(--qi-transition-fast), color var(--qi-transition-fast), border-color var(--qi-transition-fast);
    text-decoration: none;
    cursor: default;
    white-space: nowrap;
    position: relative;
    overflow: hidden;
  }

  .tag-item::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at var(--tag-x, 50%) var(--tag-y, 50%), rgba(255,255,255,0.15), transparent 60%);
    opacity: 0;
    transition: opacity var(--qi-transition-fast);
    pointer-events: none;
  }

  .tag-item:hover::after {
    opacity: 1;
  }

  .tag-item[href] {
    cursor: pointer;
  }

  /* Light variant */
  .tag-cloud--light .tag-item {
    background: var(--qi-base-04);
    color: var(--qi-text-secondary);
    border: 1px solid var(--qi-base-06);
  }

  .tag-cloud--light .tag-item:hover {
    background: var(--qi-brand-emerald-08);
    color: var(--qi-brand-emerald);
    border-color: var(--qi-brand-emerald-15);
    transform: translateY(-1px);
    box-shadow: var(--qi-shadow-sm);
  }

  /* Dark variant */
  .tag-cloud--dark .tag-item {
    background: var(--qi-base-08);
    color: var(--qi-inverse-70);
    border: 1px solid var(--qi-base-08);
  }

  .tag-cloud--dark .tag-item:hover {
    background: var(--qi-brand-amber-12);
    color: var(--qi-amber);
    border-color: var(--qi-brand-amber-20);
    transform: translateY(-1px);
  }

  /* Size variants */
  .tag-item--sm {
    font-weight: 400;
  }

  .tag-item--lg {
    font-weight: 600;
  }
</style>
