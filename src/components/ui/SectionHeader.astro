---
import '../../styles/components/section-header.css';

interface Props {
  label?: string;
  title?: string;
  align?: 'left' | 'center';
  variant?: 'default' | 'minimal';
}

const { label = '// SECTION', title = 'Section Title', align = 'left', variant = 'default' } = Astro.props;
---

<div class:list={['section-header', `section-header--${align}`, `section-header--${variant}`]}>
  {label && <span class="section-label">{label}</span>}
  {title && <h2 class="section-title">{title}</h2>}
  {variant === 'default' && <span class="section-accent" aria-hidden="true"></span>}
</div>
