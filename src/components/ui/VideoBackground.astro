---
interface Props {
  videoSrc: string;
  posterSrc?: string;
  fallbackImageSrc?: string;
  overlayOpacity?: number;
  mobileBreakpoint?: number;
  class?: string;
}

const {
  videoSrc,
  posterSrc,
  fallbackImageSrc,
  overlayOpacity = 0.4,
  mobileBreakpoint = 768,
  class: className = '',
} = Astro.props;

const overlayStyle = `--video-overlay-opacity: ${overlayOpacity}`;
---

<div class:list={['video-background', className]} style={overlayStyle} data-mobile-breakpoint={mobileBreakpoint}>
  <div class="video-background__placeholder" aria-hidden="true">
    {posterSrc && (
      <img
        src={posterSrc}
        alt=""
        class="video-background__poster video-background__poster--blur"
        loading="eager"
        decoding="async"
      />
    )}
  </div>

  <div class="video-background__fallback" aria-hidden="true">
    {fallbackImageSrc && (
      <img
        src={fallbackImageSrc}
        alt=""
        class="video-background__fallback-image"
        loading="eager"
        decoding="async"
      />
    )}
    {!fallbackImageSrc && posterSrc && (
      <img
        src={posterSrc}
        alt=""
        class="video-background__fallback-image"
        loading="eager"
        decoding="async"
      />
    )}
  </div>

  <video
    class="video-background__video"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={posterSrc}
    aria-hidden="true"
  >
    <source src={videoSrc} type="video/mp4" />
  </video>

  <div class="video-background__overlay" aria-hidden="true"></div>
</div>

<style>
  .video-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .video-background__placeholder {
    position: absolute;
    inset: 0;
    z-index: 1;
    transition: opacity 0.5s ease-out;
  }

  .video-background--loaded .video-background__placeholder {
    opacity: 0;
    pointer-events: none;
  }

  .video-background__poster,
  .video-background__fallback-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .video-background__poster--blur {
    filter: blur(20px);
    transform: scale(1.1);
  }

  .video-background__fallback {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: none;
  }

  .video-background__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 3;
    opacity: 0;
    transition: opacity 0.5s ease-out;
  }

  .video-background--loaded .video-background__video {
    opacity: 1;
  }

  .video-background__overlay {
    position: absolute;
    inset: 0;
    z-index: 4;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, calc(var(--video-overlay-opacity) * 0.3)) 0%,
      rgba(0, 0, 0, calc(var(--video-overlay-opacity) * 0.5)) 50%,
      rgba(0, 0, 0, calc(var(--video-overlay-opacity) * 0.7)) 100%
    );
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .video-background__video {
      display: none;
    }

    .video-background__placeholder {
      display: none;
    }

    .video-background__fallback {
      display: block;
    }

    .video-background--loaded .video-background__placeholder {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .video-background__video {
      display: none;
    }

    .video-background__placeholder {
      display: none;
    }

    .video-background__fallback {
      display: block;
    }
  }
</style>

<script>
  function initVideoBackground() {
    const videoBackgrounds = document.querySelectorAll('.video-background');

    videoBackgrounds.forEach((container) => {
      const video = container.querySelector('.video-background__video') as HTMLVideoElement;

      if (!video) return;

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const mobileBreakpoint = parseInt(container.getAttribute('data-mobile-breakpoint') || '768', 10);
      const isMobile = window.innerWidth <= mobileBreakpoint;

      if (prefersReducedMotion || isMobile) {
        container.classList.add('video-background--loaded');
        return;
      }

      if (video.readyState >= 3) {
        container.classList.add('video-background--loaded');
        return;
      }

      const handleCanPlay = () => {
        container.classList.add('video-background--loaded');
        video.removeEventListener('canplay', handleCanPlay);
        video.removeEventListener('canplaythrough', handleCanPlay);
      };

      video.addEventListener('canplay', handleCanPlay);
      video.addEventListener('canplaythrough', handleCanPlay);

      video.play().catch(() => {
        container.classList.add('video-background--loaded');
      });
    });
  }

  document.addEventListener('astro:page-load', initVideoBackground);

  if (document.readyState === 'complete') {
    initVideoBackground();
  }

  window.matchMedia('(prefers-reduced-motion: reduce)').addEventListener('change', (e) => {
    if (e.matches) {
      const videos = document.querySelectorAll('.video-background__video') as NodeListOf<HTMLVideoElement>;
      videos.forEach((video) => {
        video.pause();
      });
    }
  });
</script>
