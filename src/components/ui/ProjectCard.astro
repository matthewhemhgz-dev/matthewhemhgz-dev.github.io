---
import type { Project } from '../../data/projects';
import OptimizedImage from './OptimizedImage.astro';

interface Props {
  project: Project;
  lang?: 'zh' | 'en';
}

const { project, lang = 'zh' } = Astro.props;

const title = lang === 'en' ? project.titleEn : project.title;
const description = lang === 'en' ? project.descriptionEn : project.description;
const category = lang === 'en' ? project.categoryEn : project.category;

const hasPreview = project.previewImage && project.previewType;
---

<article
  class="project-card"
  data-category={category}
  data-tags={project.tags.join(',')}
  data-project-id={project.id}
  data-has-preview={hasPreview ? 'true' : 'false'}
>
  <div class="project-image-wrapper" data-preview-type={project.previewType || 'none'}>
    <OptimizedImage
      src={project.image}
      alt={title}
      width={400}
      height={250}
      loading="lazy"
      class="project-image static-image"
    />
    
    {hasPreview && project.previewType === 'gif' && (
      <img
        src={project.previewImage}
        alt={title}
        width={400}
        height={250}
        loading="lazy"
        class="project-image preview-image gif-preview"
        style="display: none;"
      />
    )}
    
    {hasPreview && project.previewType === 'video' && (
      <video
        src={project.previewImage}
        muted
        loop
        playsinline
        preload="none"
        class="project-image preview-image video-preview"
        style="display: none;"
      />
    )}
    
    <div class="project-overlay">
      <button class="overlay-link detail-btn" data-project-id={project.id}>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0" />
          <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7Z" />
        </svg>
      </button>
      {project.url && (
        <a href={project.url} class="overlay-link" target="_blank" rel="noopener noreferrer">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10 6H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
      {project.github && (
        <a href={project.github} class="overlay-link" target="_blank" rel="noopener noreferrer">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="12" cy="7" r="4" />
            <path d="M21 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
        </a>
      )}
    </div>
    
    {hasPreview && (
      <div class="preview-indicator">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="5 3 19 12 5 21 5 3" />
        </svg>
      </div>
    )}
  </div>

  <div class="project-content">
    <div class="project-category">
      <span class="project-category-tag">{category}</span>
    </div>
    
    <h3 class="project-title">
      {project.url ? (
        <a href={project.url} target="_blank" rel="noopener noreferrer">
          {title}
        </a>
      ) : (
        <span>{title}</span>
      )}
    </h3>
    
    <p class="project-description">
      {description}
    </p>

    <div class="project-tags">
      {project.tags.map((tag) => (
        <span key={tag} class="project-tag">{tag}</span>
      ))}
    </div>

    <div class="project-meta">
      <span class="project-year">{project.year}</span>
    </div>
  </div>
</article>

<style>
.project-card {
  background: var(--qi-bg-surface);
  border-radius: var(--qi-radius-card);
  overflow: hidden;
  box-shadow: var(--qi-shadow-md);
  transition: all var(--qi-transition);
  border: 1px solid var(--qi-border-default);
}

.project-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--qi-shadow-hover-warm);
  border-color: var(--qi-brand-emerald);
}

.project-image-wrapper {
  position: relative;
  aspect-ratio: 16 / 10;
  overflow: hidden;
  cursor: pointer;
}

.project-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--qi-transition-slow);
  position: absolute;
  top: 0;
  left: 0;
}

.project-card:hover .project-image {
  transform: scale(1.05);
}

.static-image {
  z-index: 1;
}

.preview-image {
  z-index: 2;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.project-card:hover .preview-image {
  opacity: 1;
}

.project-card:hover .static-image {
  opacity: 0;
}

.project-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--qi-space-lg);
  opacity: 0;
  transition: opacity var(--qi-transition);
  z-index: 10;
}

.project-card:hover .project-overlay {
  opacity: 1;
}

.overlay-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background: var(--qi-bg-surface);
  border-radius: 50%;
  color: var(--qi-text-primary);
  cursor: pointer;
  transition: all var(--qi-transition);
  text-decoration: none;
  border: none;
}

.overlay-link:hover {
  background: var(--qi-brand-emerald);
  color: var(--qi-text-inverse);
  transform: scale(1.1);
}

.preview-indicator {
  position: absolute;
  bottom: var(--qi-space-sm);
  right: var(--qi-space-sm);
  width: 28px;
  height: 28px;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  z-index: 5;
  opacity: 0.8;
  transition: opacity var(--qi-transition);
}

.project-card:hover .preview-indicator {
  opacity: 0;
}

.project-content {
  padding: var(--qi-space-xl);
}

.project-category {
  margin-bottom: var(--qi-space-sm);
}

.project-category-tag {
  display: inline-block;
  padding: 2px 10px;
  background: var(--qi-brand-emerald-04);
  color: var(--qi-brand-emerald);
  border-radius: var(--qi-radius-sm);
  font-family: var(--qi-font-mono);
  font-size: var(--qi-text-xs);
  font-weight: 600;
}

.project-title {
  margin: 0 0 var(--qi-space-sm);
  font-family: var(--qi-font-serif);
  font-size: var(--qi-text-lg);
  font-weight: var(--qi-weight-semibold);
}

.project-title a {
  color: var(--qi-text-primary);
  text-decoration: none;
  transition: color var(--qi-transition);
}

.project-title a:hover {
  color: var(--qi-brand-emerald);
}

.project-description {
  margin: 0 0 var(--qi-space-md);
  font-size: var(--qi-text-sm);
  color: var(--qi-text-secondary);
  line-height: 1.6;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--qi-space-xs);
  margin-bottom: var(--qi-space-md);
}

.project-tag {
  padding: 2px 8px;
  background: var(--qi-surface-sub);
  border-radius: var(--qi-radius-sm);
  font-size: var(--qi-text-xs);
  color: var(--qi-text-muted);
  font-family: var(--qi-font-mono);
}

.project-meta {
  display: flex;
  justify-content: flex-end;
}

.project-year {
  font-family: var(--qi-font-mono);
  font-size: var(--qi-text-xs);
  color: var(--qi-text-muted);
}

@media (min-width: 1440px) {
  .project-content {
    padding: var(--qi-space-2xl);
  }

  .project-title {
    font-size: var(--qi-text-xl);
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const projectCards = document.querySelectorAll('.project-card');
  
  projectCards.forEach((card) => {
    const wrapper = card.querySelector('.project-image-wrapper');
    const video = wrapper?.querySelector('.video-preview') as HTMLVideoElement | null;
    
    if (video) {
      card.addEventListener('mouseenter', () => {
        video.style.display = 'block';
        video.play().catch(() => {});
      });
      
      card.addEventListener('mouseleave', () => {
        video.pause();
        video.currentTime = 0;
        video.style.display = 'none';
      });
    }
    
    const gifPreview = wrapper?.querySelector('.gif-preview') as HTMLImageElement | null;
    if (gifPreview) {
      card.addEventListener('mouseenter', () => {
        gifPreview.style.display = 'block';
      });
      
      card.addEventListener('mouseleave', () => {
        gifPreview.style.display = 'none';
      });
    }
  });
});
</script>
