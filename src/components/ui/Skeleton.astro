---
interface Props {
  type: 'text' | 'heading' | 'paragraph' | 'image' | 'card' | 'button';
  count?: number;
  width?: string;
  height?: string;
  className?: string;
}

const {
  type,
  count = 1,
  width = '100%',
  height = '16px',
  className = '',
} = Astro.props;
---

<style>
  .skeleton {
    background: linear-gradient(90deg, var(--qi-base-06) 25%, var(--qi-base-08) 50%, var(--qi-base-06) 75%);
    background-size: 200% 100%;
    animation: skeleton-loading 1.5s ease-in-out infinite;
    border-radius: var(--qi-radius-sm);
  }

  @keyframes skeleton-loading {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  .skeleton-heading {
    height: 32px;
    max-width: 80%;
    margin-bottom: var(--qi-space-md);
  }

  .skeleton-paragraph {
    display: flex;
    flex-direction: column;
    gap: var(--qi-space-sm);
  }

  .skeleton-image {
    aspect-ratio: 16 / 9;
    border-radius: var(--qi-radius-lg);
  }

  .skeleton-card {
    padding: var(--qi-space-lg);
    border-radius: var(--qi-radius-lg);
    background: var(--qi-surface-main);
    border: 1px solid var(--qi-border-default);
  }

  .skeleton-button {
    height: 44px;
    max-width: 200px;
  }
</style>

{type === 'paragraph' ? (
  <div class={`skeleton-paragraph ${className}`} style={{ width }}>
    {Array.from({ length: count }).map((_, index) => (
      <div key={index} class="skeleton" style={{ height, width: index === count - 1 ? '80%' : '100%' }}></div>
    ))}
  </div>
) : type === 'heading' ? (
  <div class={`skeleton skeleton-heading ${className}`} style={{ width, height }}></div>
) : type === 'image' ? (
  <div class={`skeleton skeleton-image ${className}`} style={{ width, height }}></div>
) : type === 'card' ? (
  <div class={`skeleton-card ${className}`} style={{ width }}>
    <div class="skeleton skeleton-heading" style={{ marginBottom: 'var(--qi-space-md)' }}></div>
    <div class="skeleton" style={{ height: '16px', marginBottom: 'var(--qi-space-sm)' }}></div>
    <div class="skeleton" style={{ height: '16px', width: '80%' }}></div>
  </div>
) : type === 'button' ? (
  <div class={`skeleton skeleton-button ${className}`} style={{ width, height }}></div>
) : (
  <div class={`skeleton ${className}`} style={{ width, height }}></div>
)
