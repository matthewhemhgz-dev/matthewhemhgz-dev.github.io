---
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  sizes?: string;
  aspectRatio?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  fetchpriority,
  class: className,
  sizes = '100vw',
  aspectRatio,
} = Astro.props;

/**
 * OptimizedImage — 封装 Astro <Image /> 的优化图片组件
 *
 * 对于本地图片，使用 Astro 内置优化（WebP/AVIF + srcset）
 * 对于外部 URL，回退到原生 <img> 标签（添加 loading + decoding 优化）
 */
const isExternalImage = src.startsWith('http') || src.startsWith('//');
const isPublicImage = src.startsWith('/');
---

{
  isExternalImage ? (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      fetchpriority={fetchpriority}
      class={className}
      decoding="async"
    />
  ) : isPublicImage ? (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      fetchpriority={fetchpriority}
      class={className}
      decoding="async"
    />
  ) : (
    <Image
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      fetchpriority={fetchpriority}
      class={className}
      sizes={sizes}
      aspectRatio={aspectRatio}
    />
  )
}
