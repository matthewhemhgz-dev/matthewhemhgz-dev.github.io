---
// 生成式艺术组件
---

<div class="generative-art-container">
  <canvas id="generative-art-canvas" class="generative-art-canvas"></canvas>
</div>

<script type="module">
  import p5 from 'https://cdn.skypack.dev/p5@1.9.0';
  import { GenerativeHarmony } from '../../scripts/generative-harmony.js';

  let generativeArt;

  const sketch = (p) => {
    p.setup = () => {
      const canvas = p.createCanvas(window.innerWidth, 400);
      canvas.parent('generative-art-canvas');
      p.noFill();
      
      // 初始化生成式艺术
      generativeArt = new GenerativeHarmony(p.width, p.height, Math.floor(Math.random() * 100000));
      
      // 添加鼠标移动事件监听器
      canvas.mouseMoved(() => {
        if (generativeArt && generativeArt.setMousePosition) {
          generativeArt.setMousePosition(p.mouseX, p.mouseY);
        }
      });
    };

    p.draw = () => {
      p.background(255);
      if (generativeArt) {
        generativeArt.update();
        generativeArt.draw();
      }
    };

    p.windowResized = () => {
      p.resizeCanvas(window.innerWidth, 400);
      if (generativeArt) {
        // 调用setSize方法进行响应式调整
        if (generativeArt.setSize) {
          generativeArt.setSize(p.width, p.height);
        } else {
          generativeArt.width = p.width;
          generativeArt.height = p.height;
        }
      }
    };
  };

  // 创建p5.js实例
  new p5(sketch);
</script>

<style>
  .generative-art-container {
    width: 100%;
    height: 400px;
    margin: 2rem 0;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .generative-art-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .generative-art-container {
      height: 300px;
    }
  }
</style>
