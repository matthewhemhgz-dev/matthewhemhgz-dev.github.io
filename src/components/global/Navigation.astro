---
import BrandLogo from './BrandLogo.astro';
import '../../styles/navigation.css';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { label: '首页', href: '/' },
  { label: '关于', href: '/about' },
  { label: '博客', href: '/blog' },
  { label: '标签', href: '/tags' },
];
---

<header class="nav-wrapper" transition:name="main-nav">
  <nav class="nav">
    <BrandLogo variant="icon" size="sm" />

    <!-- Mobile checkbox hack -->
    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-label="Toggle navigation" aria-expanded="false" />
    <label for="nav-toggle" class="nav-toggle-label" aria-hidden="true">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </label>
    <div id="nav-status" class="sr-only" aria-live="polite"></div>

    <ul class="nav-links">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={['nav-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <button
          class="nav-search-btn"
          id="nav-search-btn"
          aria-label="搜索文章 (Ctrl+K)"
          type="button"
        >
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.5" />
            <path d="M12 12l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          <span class="nav-search-label">搜索</span>
          <kbd class="nav-search-kbd">⌘K</kbd>
        </button>
      </li>
    </ul>
  </nav>
</header>

<script>
  // Sync aria-expanded on page load
  const navToggleInit = document.getElementById('nav-toggle');
  if (navToggleInit) {
    navToggleInit.setAttribute('aria-expanded', String(navToggleInit.checked));
  }

  const navToggle = document.getElementById('nav-toggle');
  const navStatus = document.getElementById('nav-status');
  if (navToggle) {
    navToggle.addEventListener('change', () => {
      const isOpen = navToggle.checked;
      navToggle.setAttribute('aria-expanded', String(isOpen));
      if (navStatus) {
        navStatus.textContent = isOpen
          ? '导航菜单已打开'
          : '导航菜单已关闭';
      }
    });
  }

  // Search button opens search modal
  document.addEventListener('astro:page-load', () => {
    const searchBtn = document.getElementById('nav-search-btn');
    const searchModal = document.getElementById('search-modal');
    searchBtn?.addEventListener('click', () => {
      searchModal?.setAttribute('aria-hidden', 'false');
      const searchInput = document.getElementById('search-input') as HTMLInputElement;
      searchInput?.focus();
    });
  });
</script>
