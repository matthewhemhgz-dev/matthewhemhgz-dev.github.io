---
import BrandLogo from './BrandLogo.astro';
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from '../LanguageToggle.astro';
import '../../styles/components/navigation.css';
import '../../styles/utilities/glass.css';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

// 更稳健的 Language 判定逻辑：优先检查路径前缀
const isEnglish = currentPath.startsWith('/en') || Astro.url.pathname.startsWith('/en');

const navItems = [
  { label: isEnglish ? 'Home' : '首页', href: isEnglish ? '/en' : '/' },
  { label: isEnglish ? 'About' : '关于', href: isEnglish ? '/en/about' : '/about' },
  { label: isEnglish ? 'Blog' : '博客', href: isEnglish ? '/en/blog' : '/blog' },
  { label: isEnglish ? 'Projects' : '项目', href: isEnglish ? '/en/projects' : '/projects' },
  { label: isEnglish ? 'Tags' : '标签', href: isEnglish ? '/en/tags' : '/tags' },
];
---

<header class="nav-wrapper" transition:name="main-nav">
  <nav class="nav qi-glass-nav" aria-label={isEnglish ? 'Main Navigation' : '主导航'}>
    <div class="nav-left">
      <BrandLogo variant="icon" size="sm" />
    </div>

    <!-- Mobile checkbox hack -->
    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle-input"
      aria-label={isEnglish ? 'Toggle navigation menu' : '切换导航菜单'}
      aria-expanded="false"
      aria-controls="nav-links"
    />

    <label
      for="nav-toggle"
      class="nav-toggle-label"
      aria-hidden="true"
      touch-action="manipulation"
      tabindex="-1"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </label>
    <div id="nav-status" class="sr-only" aria-live="polite"></div>

    <ul id="nav-links" class="nav-links" role="menubar">
      {
        navItems.map((item) => (
          <li role="none">
            <a
              href={item.href}
              class:list={[
                'nav-link',
                {
                  active:
                    currentPath === item.href ||
                    (item.href !== '/' && currentPath.startsWith(item.href)),
                },
              ]}
              touch-action="manipulation"
              role="menuitem"
              aria-current={
                currentPath === item.href ||
                (item.href !== '/' && currentPath.startsWith(item.href))
                  ? 'page'
                  : undefined
              }
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li role="none">
        <button
          class="nav-search-btn"
          id="nav-search-btn"
          aria-label={isEnglish ? 'Search articles (Ctrl+K)' : '搜索文章 (Ctrl+K)'}
          type="button"
          touch-action="manipulation"
          role="menuitem"
        >
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.5"></circle>
            <path d="M12 12l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
            ></path>
          </svg>
          <span class="nav-search-label">{isEnglish ? 'Search' : '搜索'}</span>
          <kbd class="nav-search-kbd">⌘K</kbd>
        </button>
      </li>
      <li class="nav-close-item" role="none">
        <button
          class="nav-close-btn"
          aria-label={isEnglish ? 'Close navigation menu' : '关闭导航菜单'}
          type="button"
          touch-action="manipulation"
          role="menuitem"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"
            ></path>
            <path d="M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"
            ></path>
          </svg>
          <span>{isEnglish ? 'Close' : '关闭'}</span>
        </button>
      </li>
    </ul>

    <div class="nav-right">
      <!-- Theme toggle -->
      <ThemeToggle />

      <!-- Language toggle -->
      <LanguageToggle />
    </div>
    <label for="nav-toggle" class="nav-backdrop" aria-hidden="true" tabindex="-1"></label>
  </nav>
</header>

<script>
  // Sync aria-expanded on page load
  const navToggleInit = document.getElementById('nav-toggle');
  if (navToggleInit) {
    navToggleInit.setAttribute('aria-expanded', String(navToggleInit.checked));
  }

  // Add index to nav items for animation delay
  const navItems = document.querySelectorAll('#nav-links li');
  navItems.forEach((item, index) => {
    item.style.setProperty('--nav-item-index', index);
  });

  const navToggle = document.getElementById('nav-toggle');
  const navStatus = document.getElementById('nav-status');
  if (navToggle) {
    navToggle.addEventListener('change', () => {
      const isOpen = navToggle.checked;
      const isEn = document.documentElement.lang.startsWith('en');
      navToggle.setAttribute('aria-expanded', String(isOpen));
      if (navStatus) {
        navStatus.textContent = isOpen
          ? isEn
            ? 'Navigation menu opened'
            : '导航菜单已打开'
          : isEn
            ? 'Navigation menu closed'
            : '导航菜单已关闭';
      }
    });
  }

  // Close button functionality
  document.addEventListener('astro:page-load', () => {
    // Add index to nav items for animation delay
    const navItems = document.querySelectorAll('#nav-links li');
    navItems.forEach((item, index) => {
      item.style.setProperty('--nav-item-index', index);
    });

    const isEn = document.documentElement.lang.startsWith('en');
    const closeBtn = document.querySelector('.nav-close-btn');
    closeBtn?.addEventListener('click', () => {
      const navToggle = document.getElementById('nav-toggle');
      if (navToggle) {
        navToggle.checked = false;
        navToggle.setAttribute('aria-expanded', 'false');
        if (navStatus) {
          navStatus.textContent = isEn ? 'Navigation menu closed' : '导航菜单已关闭';
        }
      }
    });

    // Search button opens search modal
    const searchBtn = document.getElementById('nav-search-btn');
    const searchModal = document.getElementById('search-modal');
    searchBtn?.addEventListener('click', () => {
      searchModal?.setAttribute('aria-hidden', 'false');
      setTimeout(() => {
        const searchInput = document.getElementById('search-input') as HTMLInputElement;
        searchInput?.focus();
      }, 100);
    });

    // Keyboard navigation for mobile menu
    const navLinks = document.getElementById('nav-links');
    if (navLinks) {
      navLinks.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          const navToggle = document.getElementById('nav-toggle');
          if (navToggle) {
            navToggle.checked = false;
            navToggle.setAttribute('aria-expanded', 'false');
            if (navStatus) {
              navStatus.textContent = isEn ? 'Navigation menu closed' : '导航菜单已关闭';
            }
          }
        }
      });
    }

    // Scroll animation for navigation
    const navWrapper = document.querySelector('.nav-wrapper');
    const navToggle = document.getElementById('nav-toggle');
    let ticking = false;

    function updateNav() {
      // 检查导航菜单是否打开，如果打开则不执行滚动动画
      const isMenuOpen = navToggle?.checked || false;
      if (isMenuOpen) {
        ticking = false;
        return;
      }

      const scrollY = window.scrollY;
      const isMobile = window.innerWidth <= 768;
      
      if (scrollY > 100) {
        // 移动端不添加 nav-collapsed 类，保持导航按钮始终可用
        if (!isMobile) {
          navWrapper?.classList.add('nav-collapsed');
        }
        navWrapper?.classList.add('scrolled');
      } else {
        navWrapper?.classList.remove('nav-collapsed');
        navWrapper?.classList.remove('scrolled');
      }
      
      ticking = false;
    }

    function requestTick() {
      if (!ticking) {
        requestAnimationFrame(updateNav);
        ticking = true;
      }
    }

    window.addEventListener('scroll', requestTick);

    // 窗口 resize 时重新检查是否需要 nav-collapsed 类
    window.addEventListener('resize', () => {
      const scrollY = window.scrollY;
      const isMobile = window.innerWidth <= 768;
      
      if (isMobile) {
        navWrapper?.classList.remove('nav-collapsed');
      } else if (scrollY > 100) {
        navWrapper?.classList.add('nav-collapsed');
      }
    });
  });
</script>
