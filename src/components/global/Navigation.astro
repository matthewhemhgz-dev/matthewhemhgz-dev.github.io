---
import { getLangFromUrl } from '../../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const navItems = lang === 'en'
  ? [
      { label: 'Home', href: '/en/' },
      { label: 'About', href: '/en/about' },
      { label: 'Blog', href: '/en/blog' },
      { label: 'Tags', href: '/en/tags' },
    ]
  : [
      { label: '首页', href: '/' },
      { label: '关于', href: '/about' },
      { label: '博客', href: '/blog' },
      { label: '标签', href: '/tags' },
    ];

const brandName = lang === 'en' ? 'Qi-Lab' : '祈研所';
---

<header class="nav-wrapper" transition:persist transition:name="main-nav">
  <nav class="nav">
    <a href={lang === 'en' ? '/en/' : '/'} class="nav-brand">
      <span class="brand-icon">&#x1F52C;</span>
      <span class="brand-text">{brandName}</span>
    </a>

    <!-- Mobile checkbox hack -->
    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-label="Toggle navigation" aria-expanded="false" />
    <label for="nav-toggle" class="nav-toggle-label" aria-hidden="true">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </label>
    <div id="nav-status" class="sr-only" aria-live="polite"></div>

    <ul class="nav-links">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={['nav-link', { active: currentPath === item.href || (item.href !== '/' && item.href !== '/en/' && currentPath.startsWith(item.href)) }]}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="nav-lang-separator">
        <LanguageSwitcher />
      </li>
    </ul>
  </nav>
</header>

<style>
  .nav-wrapper {
    position: fixed;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--qi-z-nav);
    background: rgba(247, 243, 238, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 9999px;
    padding: 10px 28px;
    border: 1px solid rgba(42, 42, 42, 0.06);
    box-shadow: 0 4px 24px rgba(42, 42, 42, 0.06);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    max-width: calc(100% - 32px);
  }

  .nav-wrapper.scrolled {
    border-color: rgba(42, 42, 42, 0.08);
    box-shadow: var(--qi-shadow-sm);
  }

  .nav-wrapper.nav-collapsed {
    padding: 8px 18px;
    box-shadow: 0 8px 32px rgba(42, 42, 42, 0.1);
    border-color: rgba(42, 42, 42, 0.1);
  }

  .nav-wrapper.nav-collapsed .nav-links {
    opacity: 0;
    width: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
    transition: opacity 0.3s ease, width 0.3s ease;
  }

  .nav-wrapper.nav-collapsed .nav-lang-separator {
    opacity: 0;
    width: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
    transition: opacity 0.3s ease, width 0.3s ease;
  }

  .nav-wrapper.nav-collapsed:hover {
    padding: 10px 28px;
    box-shadow: 0 4px 24px rgba(42, 42, 42, 0.06);
  }

  .nav-wrapper.nav-collapsed:hover .nav-links,
  .nav-wrapper.nav-collapsed:hover .nav-lang-separator {
    opacity: 1;
    width: auto;
    margin: revert;
    padding: revert;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--qi-max-width);
    margin-inline: auto;
    padding: 0 var(--qi-space-lg);
    height: var(--qi-nav-height);
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--qi-space-sm);
    font-family: var(--qi-font-serif);
    font-weight: 600;
    font-size: var(--qi-text-xl);
    color: var(--qi-text-primary);
    transition: color var(--qi-transition-fast);
    text-decoration: none;
  }

  .nav-brand:hover {
    color: var(--qi-brand-emerald);
  }

  .brand-icon {
    font-size: 1.4rem;
    line-height: 1;
  }

  .brand-text {
    letter-spacing: 0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--qi-space-xs);
    transition: opacity 0.3s ease, width 0.3s ease, margin 0.3s ease, padding 0.3s ease;
    white-space: nowrap;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: var(--qi-space-sm) var(--qi-space-md);
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-sm);
    font-weight: 500;
    color: var(--qi-text-muted);
    letter-spacing: 0.03em;
    text-decoration: none;
    border-radius: var(--qi-radius-md);
    transition: color var(--qi-transition-fast), background-color var(--qi-transition-fast);
  }

  .nav-link:hover {
    color: var(--qi-text-primary);
    background-color: rgba(42, 42, 42, 0.04);
  }

  .nav-link.active {
    color: var(--qi-brand-emerald);
    background-color: rgba(46, 125, 92, 0.06);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 2px;
    background: var(--qi-brand-emerald);
    border-radius: var(--qi-radius-full);
  }

  .nav-lang-separator {
    margin-left: var(--qi-space-sm);
    padding-left: var(--qi-space-sm);
    border-left: 1px solid rgba(42, 42, 42, 0.1);
    transition: opacity 0.3s ease, width 0.3s ease, margin 0.3s ease;
  }

  .nav-toggle-input {
    display: none;
  }

  .nav-toggle-label {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 28px;
    height: 28px;
    cursor: pointer;
    z-index: calc(var(--qi-z-nav) + 1);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--qi-text-primary);
    border-radius: var(--qi-radius-full);
    transition: transform var(--qi-transition-base), opacity var(--qi-transition-fast);
    transform-origin: center;
  }

  @media (max-width: 768px) {
    .nav-wrapper {
      top: 0;
      left: 0;
      right: 0;
      transform: none;
      border-radius: 0;
      max-width: 100%;
      padding: 0 var(--qi-container-padding, 24px);
      border: none;
      border-bottom: 1px solid transparent;
    }

    .nav-wrapper.nav-collapsed {
      padding: 0 var(--qi-container-padding, 24px);
    }

    .nav-wrapper.nav-collapsed .nav-links,
    .nav-wrapper.nav-collapsed .nav-lang-separator {
      /* Keep hidden on mobile - hamburger menu handles navigation */
    }

    .nav-wrapper.nav-collapsed:hover .nav-links,
    .nav-wrapper.nav-collapsed:hover .nav-lang-separator {
      opacity: 0;
      width: 0;
      overflow: hidden;
    }

    .nav-toggle-label {
      display: flex;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: 0;
      width: min(280px, 80vw);
      height: 100vh;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: var(--qi-space-sm);
      padding: var(--qi-space-2xl);
      background: var(--qi-bg-base);
      border-left: 1px solid rgba(42, 42, 42, 0.08);
      box-shadow: var(--qi-shadow-xl);
      transform: translateX(100%);
      transition: transform var(--qi-transition-base);
      z-index: var(--qi-z-nav);
    }

    .nav-link {
      font-size: var(--qi-text-base);
      padding: var(--qi-space-md) var(--qi-space-lg);
      width: 100%;
    }

    .nav-link.active::after {
      left: 0;
      transform: none;
      bottom: auto;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 16px;
    }

    .nav-lang-separator {
      margin-left: 0;
      padding-left: 0;
      border-left: none;
      margin-top: var(--qi-space-sm);
      padding-top: var(--qi-space-sm);
      border-top: 1px solid rgba(42, 42, 42, 0.08);
    }

    .nav-toggle-input:checked ~ .nav-links {
      transform: translateX(0);
    }

    .nav-toggle-input:checked ~ .nav-toggle-label .hamburger-line:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle-input:checked ~ .nav-toggle-label .hamburger-line:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle-input:checked ~ .nav-toggle-label .hamburger-line:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  // Sync aria-expanded on page load
  const navToggleInit = document.getElementById('nav-toggle');
  if (navToggleInit) {
    navToggleInit.setAttribute('aria-expanded', String(navToggleInit.checked));
  }

  const navToggle = document.getElementById('nav-toggle');
  const navStatus = document.getElementById('nav-status');
  if (navToggle) {
    navToggle.addEventListener('change', () => {
      const isOpen = navToggle.checked;
      navToggle.setAttribute('aria-expanded', String(isOpen));
      if (navStatus) {
        const isEn = document.documentElement.lang === 'en';
        navStatus.textContent = isOpen
          ? (isEn ? 'Navigation menu opened' : '导航菜单已打开')
          : (isEn ? 'Navigation menu closed' : '导航菜单已关闭');
      }
    });
  }
</script>
