---
import BrandLogo from './BrandLogo.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { label: '首页', href: '/' },
  { label: '关于', href: '/about' },
  { label: '博客', href: '/blog' },
  { label: '标签', href: '/tags' },
];
---

<header class="nav-wrapper" transition:name="main-nav">
  <nav class="nav">
    <BrandLogo variant="icon" size="sm" />

    <!-- Mobile checkbox hack -->
    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-label="Toggle navigation" aria-expanded="false" />
    <label for="nav-toggle" class="nav-toggle-label" aria-hidden="true">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </label>
    <div id="nav-status" class="sr-only" aria-live="polite"></div>

    <ul class="nav-links">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={['nav-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .nav-wrapper {
    position: relative;
  }

  .nav-wrapper.nav-collapsed {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }
  .nav-wrapper.nav-collapsed .nav {
    backdrop-filter: blur(8px);
    background: rgba(247, 243, 238, 0.85);
  }

  /* 导航栏底部翡翠绿光晕线（滚动后显示） */
  .nav-wrapper.nav-collapsed::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 15%;
    right: 15%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(46, 125, 92, 0.15), transparent);
    box-shadow: 0 2px 20px -4px rgba(46, 125, 92, 0.1);
    pointer-events: none;
  }
</style>