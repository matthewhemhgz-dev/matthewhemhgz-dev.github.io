---
/**
 * Theme Toggle - 明暗主题切换按钮
 *
 * 功能：
 * - 在 .dark / 浅色之间切换
 * - localStorage 持久化用户偏好
 * - 尊重 prefers-color-scheme 系统偏好
 * - View Transitions 兼容
 * - 多语言支持
 */

import { Astro } from 'astro';

const currentLocale = Astro.url.pathname.startsWith('/en') ? 'en' : 'zh';

const getThemeToggleText = (isDark) => {
  if (currentLocale === 'en') {
    return isDark ? 'Switch to light mode' : 'Switch to dark mode';
  }
  return isDark ? '切换浅色模式' : '切换深色模式';
};
---

<button
  class="theme-toggle-btn"
  id="theme-toggle"
  type="button"
  aria-label={getThemeToggleText(false)}
  title={getThemeToggleText(false)}
  aria-pressed="false"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg
    class="theme-icon-sun"
    width="16"
    height="16"
    viewBox="0 0 16 16"
    fill="none"
    aria-hidden="true"
  >
    <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.5"></circle>
    <path
      d="M8 1v2M8 13v2M1 8h2M13 8h2M3.05 3.05l1.41 1.41M11.54 11.54l1.41 1.41M3.05 12.95l1.41-1.41M11.54 4.46l1.41-1.41"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"></path>
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg
    class="theme-icon-moon"
    width="16"
    height="16"
    viewBox="0 0 16 16"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M14 8.5A6.5 6.5 0 017.5 2 6.5 6.5 0 1014 8.5z"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
</button>

<style>
  .theme-toggle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    background: var(--qi-base-04);
    border: 1px solid var(--qi-base-06);
    border-radius: var(--qi-radius-md);
    cursor: pointer;
    color: var(--qi-text-secondary);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    flex-shrink: 0;
  }

  .theme-toggle-btn:hover {
    color: var(--qi-text-primary);
    background: var(--qi-base-06);
    border-color: var(--qi-base-08);
  }

  .theme-toggle-btn:focus-visible {
    outline: 2px solid var(--qi-brand-emerald);
    outline-offset: 2px;
  }

  .theme-icon-sun,
  .theme-icon-moon {
    position: absolute;
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s ease;
  }

  /* Logic handled by script classes, but we can set defaults */
  :global(.light) .theme-icon-sun {
    opacity: 0;
    transform: rotate(90deg) scale(0.5);
  }
  :global(.light) .theme-icon-moon {
    opacity: 1;
    transform: rotate(0) scale(1);
  }

  :global(.dark) .theme-icon-sun {
    opacity: 1;
    transform: rotate(0) scale(1);
  }
  :global(.dark) .theme-icon-moon {
    opacity: 0;
    transform: rotate(-90deg) scale(0.5);
  }

  :global(.dark) .theme-toggle-btn {
    background: var(--qi-surface-sub);
    border-color: var(--qi-border-strong);
  }
</style>

<script>
  const STORAGE_KEY = 'qi-theme';
  let htmlElement: HTMLElement;
  let themeToggleBtn: HTMLElement | null;
  let themeMeta: HTMLMetaElement | null;

  function getCurrentLocale() {
    return window.location.pathname.startsWith('/en') ? 'en' : 'zh';
  }

  function getThemeToggleText(isDark: boolean) {
    const currentLocale = getCurrentLocale();
    if (currentLocale === 'en') {
      return isDark ? 'Switch to light mode' : 'Switch to dark mode';
    }
    return isDark ? '切换浅色模式' : '切换深色模式';
  }

  function getSystemPreference(): 'dark' | 'light' {
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function getStoredTheme(): 'dark' | 'light' | null {
    try {
      return localStorage.getItem(STORAGE_KEY) as 'dark' | 'light' | null;
    } catch {
      // localStorage access might be blocked
      return null;
    }
  }

  function applyTheme(theme: 'dark' | 'light') {
    // Cache DOM elements for better performance
    if (!htmlElement) htmlElement = document.documentElement;
    if (!themeMeta) themeMeta = document.querySelector('meta[name="theme-color"]');
    if (!themeToggleBtn) themeToggleBtn = document.getElementById('theme-toggle');

    // Apply theme class
    if (theme === 'dark') {
      htmlElement.classList.add('dark');
      htmlElement.classList.remove('light');
    } else {
      htmlElement.classList.remove('dark');
      htmlElement.classList.add('light');
    }

    // Update meta theme-color
    if (themeMeta) {
      themeMeta.setAttribute('content', theme === 'dark' ? '#121010' : '#F7F3EE');
    }

    // Update aria attributes
    if (themeToggleBtn) {
      themeToggleBtn.setAttribute('aria-pressed', String(theme === 'dark'));
      themeToggleBtn.setAttribute('aria-label', getThemeToggleText(theme === 'dark'));
      themeToggleBtn.setAttribute('title', getThemeToggleText(theme === 'dark'));
    }
  }

  function toggleTheme() {
    const isDark = document.documentElement.classList.contains('dark');
    const newTheme = isDark ? 'light' : 'dark';
    applyTheme(newTheme);

    // Optimize localStorage write
    try {
      localStorage.setItem(STORAGE_KEY, newTheme);
    } catch {
      // Ignore if localStorage is blocked
    }
  }

  // Initialize theme before paint (prevent flash)
  (function initTheme() {
    const stored = getStoredTheme();
    const theme = stored || getSystemPreference();
    document.documentElement.classList.toggle('dark', theme === 'dark');
    document.documentElement.classList.toggle('light', theme === 'light');
    applyTheme(theme);
  })();

  // Bind toggle button after DOM ready
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('theme-toggle');
    if (btn) {
      themeToggleBtn = btn;
      // Use passive event listener for better performance
      btn.addEventListener('click', toggleTheme, { passive: true });
    }

    // Listen for system preference changes
    const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
    mediaQuery.addEventListener('change', (event) => {
      if (!getStoredTheme()) {
        applyTheme(event.matches ? 'dark' : 'light');
      }
    });
  });
</script>
