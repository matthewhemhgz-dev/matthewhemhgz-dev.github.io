---
import BrandLogo from './BrandLogo.astro';
import '../../styles/components/loading-animation.css';
---

<div class="loading-overlay" id="loading-overlay" aria-hidden="true" role="status" aria-label="Loading">
  <div class="loading-content">
    <div class="loading-logo">
      <BrandLogo variant="icon" size="lg" />
    </div>
    
    <div class="loading-progress">
      <div class="loading-progress-bar" id="loading-progress-bar"></div>
    </div>
    
    <div class="loading-dots">
      <span class="loading-dot"></span>
      <span class="loading-dot"></span>
      <span class="loading-dot"></span>
    </div>
  </div>
</div>

<script>
  const overlay = document.getElementById('loading-overlay');
  const progressBar = document.getElementById('loading-progress-bar');
  
  let progress = 0;
  let progressInterval: ReturnType<typeof setInterval> | null = null;
  let isLoading = false;
  let safetyTimeout: ReturnType<typeof setTimeout> | null = null;
  
  const MAX_LOADING_TIME = 5000;
  const MIN_LOADING_TIME = 300;
  let loadingStartTime = 0;
  
  function startProgress() {
    if (progressInterval) return;
    
    progressInterval = setInterval(() => {
      progress += Math.random() * 15;
      if (progress > 90) progress = 90;
      if (progressBar) {
        progressBar.style.width = `${progress}%`;
      }
    }, 100);
  }
  
  function stopProgress() {
    if (progressInterval) {
      clearInterval(progressInterval);
      progressInterval = null;
    }
  }
  
  function clearSafetyTimeout() {
    if (safetyTimeout) {
      clearTimeout(safetyTimeout);
      safetyTimeout = null;
    }
  }
  
  function setSafetyTimeout() {
    clearSafetyTimeout();
    safetyTimeout = setTimeout(() => {
      if (isLoading) {
        console.warn('[LoadingAnimation] Safety timeout reached, forcing hide');
        hideLoading();
      }
    }, MAX_LOADING_TIME);
  }
  
  function showLoading() {
    if (!overlay || isLoading) return;
    
    isLoading = true;
    loadingStartTime = Date.now();
    progress = 0;
    
    overlay.classList.add('is-visible');
    overlay.setAttribute('aria-hidden', 'false');
    
    if (progressBar) {
      progressBar.style.width = '0%';
    }
    
    startProgress();
    setSafetyTimeout();
  }
  
  function hideLoading() {
    if (!overlay) return;
    
    const elapsed = Date.now() - loadingStartTime;
    const remainingTime = Math.max(0, MIN_LOADING_TIME - elapsed);
    
    clearSafetyTimeout();
    stopProgress();
    
    if (progressBar) {
      progressBar.style.width = '100%';
    }
    
    setTimeout(() => {
      overlay.classList.remove('is-visible');
      overlay.setAttribute('aria-hidden', 'true');
      isLoading = false;
      progress = 0;
    }, Math.max(200, remainingTime));
  }
  
  document.addEventListener('astro:page-load', () => {
    hideLoading();
  });
  
  document.addEventListener('astro:before-preparation', () => {
    showLoading();
  });
  
  document.addEventListener('astro:before-swap', () => {
    hideLoading();
  });
  
  if (document.readyState === 'complete') {
    setTimeout(() => {
      hideLoading();
    }, 100);
  } else {
    window.addEventListener('load', () => {
      setTimeout(() => {
        hideLoading();
      }, 100);
    });
  }
</script>
