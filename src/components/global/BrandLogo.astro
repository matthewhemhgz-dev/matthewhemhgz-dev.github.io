---
/**
 * BrandLogo — 祈研所品牌 Logo 组件
 * 使用 VI 设计图片：祈字 + 月桂环 + 金色几何框架
 *
 * Props:
 *   variant: 'full' | 'icon'  — 完整 Logo（图标+文字）或仅图标
 *   size:    'sm' | 'md' | 'lg'
 */
interface Props {
  variant?: 'full' | 'icon';
  size?: 'sm' | 'md' | 'lg';
}

const { variant = 'icon', size = 'md' } = Astro.props;

const sizeMap = {
  sm: { icon: 28, text: '0.95rem', gap: '6px' },
  md: { icon: 36, text: '1.15rem', gap: '8px' },
  lg: { icon: 48, text: '1.5rem', gap: '12px' },
};

const s = sizeMap[size];
---

<a href="/" class="brand-logo brand-logo--{variant} brand-logo--{size}" aria-label="祈研所">
  <img
    class="brand-logo__icon"
    src="/images/logo.svg"
    alt=""
    width={s.icon}
    height={s.icon}
    loading="eager"
    decoding="async"
  />

  {variant === 'full' && (
    <span class="brand-logo__text" style={`font-size: ${s.text}`}>祈研所</span>
  )}
</a>

<style>
  .brand-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--logo-gap, 8px);
    text-decoration: none;
    color: var(--qi-text-primary);
    transition: color var(--qi-transition-fast), opacity var(--qi-transition-fast);
  }

  .brand-logo:hover {
    color: var(--qi-brand-emerald);
  }

  .brand-logo--sm {
    --logo-gap: 6px;
  }

  .brand-logo--md {
    --logo-gap: 8px;
  }

  .brand-logo--lg {
    --logo-gap: 12px;
  }

  .brand-logo__icon {
    flex-shrink: 0;
    line-height: 0;
    object-fit: contain;
    border-radius: var(--qi-radius-sm);
  }

  .brand-logo__text {
    font-family: var(--qi-font-serif);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
</style>
