---
/**
 * BrandLogo — 祈研所品牌 Logo 组件
 * 使用 VI 设计图片：祈字 + 月桂环 + 金色几何框架
 *
 * Props:
 *   variant: 'full' | 'icon'  — 完整 Logo（图标+文字）或仅图标
 *   size:    'sm' | 'md' | 'lg'
 */
interface Props {
  variant?: 'full' | 'icon';
  size?: 'sm' | 'md' | 'lg';
}

const { variant = 'icon', size = 'md' } = Astro.props;

const sizeMap = {
  sm: { icon: 28, text: '0.95rem', gap: '6px' },
  md: { icon: 36, text: '1.15rem', gap: '8px' },
  lg: { icon: 48, text: '1.5rem', gap: '12px' },
};

const s = sizeMap[size];
---

<a href="/" class="brand-logo brand-logo--{variant} brand-logo--{size}" aria-label="祈研所">
  <svg
    class="brand-logo__icon"
    viewBox="0 0 512 512"
    xmlns="http://www.w3.org/2000/svg"
    width={s.icon}
    height={s.icon}
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="qi-logo-gold" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#EDD98A"/>
        <stop offset="100%" stop-color="#C49A3A"/>
      </linearGradient>
    </defs>
    <rect width="512" height="512" rx="96" fill="#2E7D5C"/>
    <text x="256" y="256" text-anchor="middle" dominant-baseline="central"
          font-family="'Noto Serif SC','Source Han Serif SC','SimSun',serif"
          font-weight="700" font-size="280"
          fill="url(#qi-logo-gold)">祈</text>
  </svg>

  {variant === 'full' && (
    <span class="brand-logo__text" style={`font-size: ${s.text}`}>祈研所</span>
  )}
</a>

<style>
  .brand-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--logo-gap, 8px);
    text-decoration: none;
    color: var(--qi-text-primary);
    transition: color var(--qi-transition-fast), opacity var(--qi-transition-fast);
  }

  .brand-logo:hover {
    color: var(--qi-brand-emerald);
  }

  .brand-logo--sm {
    --logo-gap: 6px;
  }

  .brand-logo--md {
    --logo-gap: 8px;
  }

  .brand-logo--lg {
    --logo-gap: 12px;
  }

  .brand-logo__icon {
    flex-shrink: 0;
    line-height: 0;
    object-fit: contain;
    border-radius: var(--qi-radius-sm);
  }

  .brand-logo__text {
    font-family: var(--qi-font-serif);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
</style>
