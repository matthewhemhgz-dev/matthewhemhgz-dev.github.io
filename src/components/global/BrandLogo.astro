---
import '../../styles/components/brand-logo.css';

/**
 * BrandLogo — 祈研所品牌 Logo 组件
 * 使用 screenshot_2 设计图片作为 Logo
 *
 * Props:
 *   variant: 'full' | 'icon'  — 完整 Logo（图标+文字）或仅图标
 *   size:    'sm' | 'md' | 'lg'
 */
interface Props {
  variant?: 'full' | 'icon';
  size?: 'sm' | 'md' | 'lg';
}

const { variant = 'icon', size = 'md' } = Astro.props;

const sizeMap = {
  sm: { icon: 32, text: '0.95rem', gap: '8px' },
  md: { icon: 48, text: '1.15rem', gap: '10px' },
  lg: { icon: 84, text: '1.75rem', gap: '12px' },
};

const isEn = Astro.url.pathname.startsWith('/en');
const homeUrl = isEn ? '/en/' : '/';
const brandName = isEn ? 'Qi-Lab' : '祈研所';

const s = sizeMap[size];
---

<a href={homeUrl} class={`brand-logo brand-logo--${variant} brand-logo--${size}`} aria-label={brandName}>
  <img
    class="brand-logo__image"
    src="/images/logo.webp"
    alt={`${brandName} Logo`}
    width={s.icon}
    height={s.icon}
    loading="eager"
    decoding="async"
  />

  {/* Only show CSS text if specifically requested for old-style layout, 
      otherwise the new logo image already contains the branding text */}
  {variant === 'full' && size === 'lg' && (
     <span class="brand-logo__text sr-only">{brandName}</span>
  )}
</a>

