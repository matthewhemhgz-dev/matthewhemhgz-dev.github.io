---
/**
 * SearchModal — Pagefind 驱动的搜索弹窗
 *
 * 使用 Pagefind JavaScript API 实现自定义搜索 UI
 * 支持 Cmd+K / Ctrl+K 快捷键唤起
 * View Transitions 兼容（transition:persist）
 */
---

<div id="search-modal" class="search-modal" role="dialog" aria-label="搜索" aria-hidden="true" transition:persist>
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-container">
    <div class="search-input-wrap">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.5" />
        <path d="M12 12l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <input
        id="search-input"
        type="search"
        class="search-input"
        placeholder="搜索文章…"
        autocomplete="off"
        aria-label="搜索文章"
      />
      <kbd class="search-kbd">ESC</kbd>
    </div>
    <div id="search-results" class="search-results" aria-live="polite">
      <p class="search-hint">输入关键词开始搜索</p>
    </div>
  </div>
</div>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: var(--qi-z-modal, 9000);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 15vh;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
  }

  .search-modal[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .search-container {
    position: relative;
    width: 90%;
    max-width: 560px;
    max-height: 60vh;
    background: var(--qi-surface-main, #1a1714);
    border: 1px solid var(--qi-border-inverse, rgba(255, 255, 255, 0.1));
    border-radius: var(--qi-radius-card, 12px);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--qi-border-inverse, rgba(255, 255, 255, 0.1));
  }

  .search-icon {
    flex-shrink: 0;
    color: var(--qi-text-muted, rgba(255, 255, 255, 0.5));
  }

  .search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--qi-text-primary, #fff);
    font-size: var(--qi-text-base, 1rem);
    font-family: var(--qi-font-sans, system-ui);
  }

  .search-input::placeholder {
    color: var(--qi-text-muted, rgba(255, 255, 255, 0.4));
  }

  .search-kbd {
    flex-shrink: 0;
    padding: 2px 6px;
    font-size: 11px;
    font-family: var(--qi-font-mono, monospace);
    color: var(--qi-text-muted, rgba(255, 255, 255, 0.4));
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }

  .search-results {
    overflow-y: auto;
    max-height: calc(60vh - 60px);
    padding: 8px;
  }

  .search-hint {
    padding: 20px;
    text-align: center;
    color: var(--qi-text-muted, rgba(255, 255, 255, 0.4));
    font-size: var(--qi-text-sm, 0.875rem);
  }

  .search-result-item {
    display: block;
    padding: 12px 14px;
    border-radius: var(--qi-radius-sm, 8px);
    text-decoration: none;
    color: var(--qi-text-primary, #fff);
    transition: background 0.15s ease;
  }

  .search-result-item:hover,
  .search-result-item:focus-visible {
    background: rgba(255, 255, 255, 0.06);
    outline: none;
  }

  .search-result-title {
    font-family: var(--qi-font-serif, serif);
    font-size: var(--qi-text-base, 1rem);
    font-weight: 600;
    margin-bottom: 4px;
    line-height: 1.4;
  }

  .search-result-title mark {
    background: rgba(229, 169, 60, 0.3);
    color: inherit;
    border-radius: 2px;
    padding: 0 2px;
  }

  .search-result-excerpt {
    font-size: var(--qi-text-xs, 0.8rem);
    color: var(--qi-text-muted, rgba(255, 255, 255, 0.5));
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-result-excerpt mark {
    background: rgba(229, 169, 60, 0.2);
    color: inherit;
    border-radius: 2px;
    padding: 0 2px;
  }

  .search-result-meta {
    font-size: 11px;
    color: var(--qi-text-muted, rgba(255, 255, 255, 0.35));
    margin-top: 4px;
    font-family: var(--qi-font-mono, monospace);
  }

  .search-status {
    padding: 12px 14px;
    font-size: var(--qi-text-xs, 0.8rem);
    color: var(--qi-text-muted, rgba(255, 255, 255, 0.4));
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 480px) {
    .search-modal {
      padding-top: 10vh;
    }
    .search-container {
      width: 95%;
      max-height: 70vh;
    }
  }

  @media (min-width: 2560px) {
    .search-container {
      max-width: 700px;
    }
    .search-input {
      font-size: var(--qi-text-lg, 1.125rem);
    }
    .search-result-title {
      font-size: var(--qi-text-lg, 1.125rem);
    }
  }
</style>

<script>
  let pagefind: any = null;
  let searchTimeout: ReturnType<typeof setTimeout> | null = null;

  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const results = document.getElementById('search-results');
  const backdrop = document.getElementById('search-backdrop');

  async function initPagefind() {
    if (pagefind) return pagefind;
    try {
      pagefind = await import('/pagefind/pagefind.js');
      // Pagefind needs to discover its index location
      await pagefind.init();
      return pagefind;
    } catch {
      return null;
    }
  }

  function openSearch() {
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'false');
    input?.focus();
    document.body.style.overflow = 'hidden';
  }

  function closeSearch() {
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'true');
    input!.value = '';
    if (results) results.innerHTML = '<p class="search-hint">输入关键词开始搜索</p>';
    document.body.style.overflow = '';
  }

  async function performSearch(query: string) {
    if (!results) return;

    if (!query.trim()) {
      results.innerHTML = '<p class="search-hint">输入关键词开始搜索</p>';
      return;
    }

    results.innerHTML = '<p class="search-status">搜索中…</p>';

    const pf = await initPagefind();
    if (!pf) {
      results.innerHTML = '<p class="search-status">搜索功能加载失败，请刷新页面重试</p>';
      return;
    }

    try {
      const search = await pf.search(query);
      const items = await Promise.all(
        search.results.slice(0, 8).map((r: any) => r.data())
      );

      if (items.length === 0) {
        results.innerHTML = `<p class="search-status">未找到与"${query}"相关的结果</p>`;
        return;
      }

      results.innerHTML = items
        .map((item: any) => {
          const url = item.url.startsWith('/') ? item.url : `/${item.url}`;
          const title = item.meta?.title || item.url;
          const excerpt = item.excerpt || '';
          return `
            <a href="${url}" class="search-result-item">
              <div class="search-result-title">${title}</div>
              ${excerpt ? `<div class="search-result-excerpt">${excerpt}</div>` : ''}
            </a>
          `;
        })
        .join('');
    } catch {
      results.innerHTML = '<p class="search-status">搜索出错，请重试</p>';
    }
  }

  // Event listeners
  document.addEventListener('astro:page-load', () => {
    // Keyboard shortcut: Cmd+K / Ctrl+K
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        const isHidden = modal?.getAttribute('aria-hidden') === 'true';
        isHidden ? openSearch() : closeSearch();
      }
      if (e.key === 'Escape' && modal?.getAttribute('aria-hidden') === 'false') {
        closeSearch();
      }
    });

    // Input debounce
    input?.addEventListener('input', () => {
      if (searchTimeout) clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => performSearch(input.value), 200);
    });

    // Backdrop click to close
    backdrop?.addEventListener('click', closeSearch);
  });
</script>
