---
/**
 * SearchModal — Pagefind 驱动的搜索弹窗
 *
 * 使用 Pagefind JavaScript API 实现自定义搜索 UI
 * 支持 Cmd+K / Ctrl+K 快捷键唤起
 * View Transitions 兼容（transition:persist）
 */
---

<div id="search-modal" class="search-modal" role="dialog" aria-labelledby="search-modal-title" aria-hidden="true" aria-modal="true" transition:persist>
  <div class="search-backdrop" id="search-backdrop" tabindex="-1"></div>
  <div class="search-container">
    <div class="search-input-wrap">
      <h2 id="search-modal-title" class="sr-only">搜索</h2>
      <svg class="search-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.5" />
        <path d="M12 12l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <input
        id="search-input"
        type="search"
        class="search-input"
        placeholder="搜索文章…"
        autocomplete="off"
        aria-label="搜索文章"
        aria-describedby="search-hint"
      />
      <kbd class="search-kbd">ESC</kbd>
    </div>
    <div id="search-results" class="search-results" aria-live="polite">
      <p id="search-hint" class="search-hint">输入关键词开始搜索</p>
    </div>
  </div>
</div>

<style>
  @import '../../styles/search-modal.css';
</style>

<script client:load>
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  let pagefind: any = null;
  let searchTimeout: ReturnType<typeof setTimeout> | null = null;

  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const results = document.getElementById('search-results');
  const backdrop = document.getElementById('search-backdrop');

  async function initPagefind() {
    if (pagefind) return pagefind;
    try {
      // 尝试导入 pagefind.js
      // 在开发模式下，这个文件不存在，会抛出错误
      pagefind = await import('/pagefind/pagefind.js');
      // Pagefind needs to discover its index location
      await pagefind.init();
      return pagefind;
    } catch (error) {
      // 开发模式下，返回 null 并显示友好提示
      return null;
    }
  }

  function openSearch() {
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'false');
    input?.focus();
    document.body.style.overflow = 'hidden';
  }

  function closeSearch() {
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'true');
    input!.value = '';
    if (results) results.innerHTML = '<p class="search-hint">输入关键词开始搜索</p>';
    document.body.style.overflow = '';
  }

  async function performSearch(query: string) {
    if (!results) return;

    if (!query.trim()) {
      results.innerHTML = '<p class="search-hint">输入关键词开始搜索</p>';
      return;
    }

    results.innerHTML = '<p class="search-status">搜索中…</p>';

    const pf = await initPagefind();
    if (!pf) {
      results.innerHTML = '<p class="search-status">搜索功能仅在生产环境可用</p>';
      return;
    }

    try {
      const search = await pf.search(query);
      const items = await Promise.all(
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        search.results.slice(0, 8).map((r: any) => r.data())
      );

      if (items.length === 0) {
        results.innerHTML = `<p class="search-status">未找到与"${query}"相关的结果</p>`;
        return;
      }

      results.innerHTML = items
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        .map((item: any) => {
          const url = item.url.startsWith('/') ? item.url : `/${item.url}`;
          const title = item.meta?.title || item.url;
          const excerpt = item.excerpt || '';
          return `
            <a href="${url}" class="search-result-item">
              <div class="search-result-title">${title}</div>
              ${excerpt ? `<div class="search-result-excerpt">${excerpt}</div>` : ''}
            </a>
          `;
        })
        .join('');
    } catch {
      results.innerHTML = '<p class="search-status">搜索出错，请重试</p>';
    }
  }

  // Event listeners
  document.addEventListener('astro:page-load', () => {
    // Keyboard shortcut: Cmd+K / Ctrl+K
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        const isHidden = modal?.getAttribute('aria-hidden') === 'true';
        if (isHidden) openSearch(); else closeSearch();
      }
      if (e.key === 'Escape' && modal?.getAttribute('aria-hidden') === 'false') {
        closeSearch();
      }
    });

    // Input debounce
    input?.addEventListener('input', () => {
      if (searchTimeout) clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => performSearch(input.value), 200);
    });

    // Backdrop click to close
    backdrop?.addEventListener('click', closeSearch);
  });
</script>
