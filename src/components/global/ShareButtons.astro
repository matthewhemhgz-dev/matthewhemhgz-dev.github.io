---
interface Props {
  url: string;
  title: string;
  description?: string;
  image?: string;
  lang?: 'zh' | 'en';
}

const {
  url,
  title,
  image = '',
  lang = 'zh'
} = Astro.props;

const isZh = lang === 'zh';

const labels = {
  shareLabel: isZh ? '分享到：' : 'Share:',
  wechat: isZh ? '微信' : 'WeChat',
  weibo: isZh ? '微博' : 'Weibo',
  twitter: 'X',
  linkedin: 'LinkedIn',
  copyLink: isZh ? '复制链接' : 'Copy Link',
  copied: isZh ? '已复制' : 'Copied',
  scanToShare: isZh ? '扫码分享' : 'Scan to share',
  shareOnX: isZh ? '分享到 X' : 'Share on X',
  shareOnWeibo: isZh ? '分享到微博' : 'Share on Weibo',
  shareOnLinkedIn: isZh ? '分享到 LinkedIn' : 'Share on LinkedIn',
  shareOnWeChat: isZh ? '分享到微信' : 'Share on WeChat',
  copyLinkAria: isZh ? '复制链接' : 'Copy Link',
};

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const encodedImage = encodeURIComponent(image);

const twitterShareUrl = `https://x.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}&via=qilab_dev`;
const weiboShareUrl = `https://service.weibo.com/share/share.php?url=${encodedUrl}&title=${encodedTitle}&pic=${encodedImage}`;
const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
const qrCodeUrl = `https://api.qrserver.com/v1/create-qr-code/?size=128x128&data=${encodedUrl}`;
---

<div class="share-buttons">
  <span class="share-label">{labels.shareLabel}</span>
  <div class="share-buttons-list">
    <a
      href={twitterShareUrl}
      class="share-btn share-btn--twitter"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={labels.shareOnX}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      <span>{labels.twitter}</span>
    </a>

    <a
      href={weiboShareUrl}
      class="share-btn share-btn--weibo"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={labels.shareOnWeibo}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M10.098 20c-4.612 0-8.363-2.463-8.363-5.5 0-1.755 1.227-3.632 3.333-5.095 2.8-1.947 6.06-2.55 7.274-1.346.344.341.47.79.423 1.318 1.26-.434 2.413-.4 2.96.22.6.68.464 1.76-.26 3.015.26.05.508.117.743.2 1.865.584 3.09 1.88 3.09 3.188 0 2.248-3.08 4-9.2 4zm-1.547-8.5c-2.535.126-4.544 1.538-4.487 3.154.057 1.616 2.152 2.826 4.687 2.7 2.535-.127 4.544-1.538 4.487-3.154-.057-1.616-2.152-2.827-4.687-2.7zm1.547 4c-.86.18-1.783-.23-2.062-.915-.28-.686.19-1.398 1.05-1.59.873-.195 1.825.203 2.12.887.295.683-.177 1.422-1.108 1.618zm1.073-2.29c-.32.097-.665-.05-.77-.328-.105-.278.073-.577.393-.67.327-.095.678.05.786.332.108.28-.07.57-.409.666z"
          fill="currentColor"></path>
        <path
          d="M17.5 8.5c.276 0 .5-.224.5-.5s-.224-.5-.5-.5-.5.224-.5.5.224.5.5.5z"
          fill="currentColor"></path>
        <path
          d="M18.5 4.5c-1.38 0-2.5 1.12-2.5 2.5s1.12 2.5 2.5 2.5 2.5-1.12 2.5-2.5-1.12-2.5-2.5-2.5zm0 4c-.828 0-1.5-.672-1.5-1.5s.672-1.5 1.5-1.5 1.5.672 1.5 1.5-.672 1.5-1.5 1.5z"
          fill="currentColor"></path>
      </svg>
      <span>{labels.weibo}</span>
    </a>

    <a
      href={linkedinShareUrl}
      class="share-btn share-btn--linkedin"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={labels.shareOnLinkedIn}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          fill="currentColor"></path>
      </svg>
      <span>{labels.linkedin}</span>
    </a>

    <button
      class="share-btn share-btn--wechat"
      type="button"
      aria-label={labels.shareOnWeChat}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 0 1 .598.082l1.584.926a.272.272 0 0 0 .14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 0 1-.023-.156.49.49 0 0 1 .201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-6.656-6.088V8.89c-.135-.01-.269-.03-.407-.03zm-2.53 3.274c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.969-.982z"
          fill="currentColor"></path>
      </svg>
      <span>{labels.wechat}</span>
      <div class="share-wechat-qr">
        <div class="share-wechat-qr-code">
          <img
            src={qrCodeUrl}
            alt={isZh ? '微信分享二维码' : 'WeChat share QR code'}
            loading="lazy"
            decoding="async"
          />
        </div>
        <span>{labels.scanToShare}</span>
      </div>
    </button>

    <button
      class="share-btn share-btn--copy"
      type="button"
      aria-label={labels.copyLinkAria}
      data-copied-text={labels.copied}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect
          x="9"
          y="9"
          width="13"
          height="13"
          rx="2"
          ry="2"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></rect>
        <path
          d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      <span>{labels.copyLink}</span>
    </button>
  </div>
</div>

<style>
  .share-buttons {
    margin-top: var(--qi-space-lg);
    margin-bottom: var(--qi-space-lg);
  }

  .share-label {
    display: block;
    margin-bottom: var(--qi-space-sm);
    font-size: var(--qi-text-sm);
    color: var(--qi-on-surface-secondary);
  }

  .share-buttons-list {
    display: flex;
    gap: var(--qi-space-sm);
    flex-wrap: wrap;
  }

  .share-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border: 1px solid var(--qi-border-subtle);
    border-radius: var(--qi-radius-md);
    background: var(--qi-surface-main);
    color: var(--qi-on-surface);
    text-decoration: none;
    font-size: var(--qi-text-xs);
    transition: all var(--qi-transition);
    cursor: pointer;
    position: relative;
  }

  .share-btn:hover {
    background: var(--qi-surface-sub);
    border-color: var(--qi-brand-emerald);
    transform: translateY(-2px);
  }

  .share-btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .share-btn--wechat {
    position: relative;
  }

  .share-wechat-qr {
    position: absolute;
    bottom: 100%;
    right: 0;
    margin-bottom: 8px;
    background: var(--qi-surface-main);
    border: 1px solid var(--qi-border-subtle);
    border-radius: var(--qi-radius-md);
    padding: var(--qi-space-sm);
    box-shadow: var(--qi-shadow-hover-warm);
    display: none;
    z-index: 100;
  }

  .share-wechat-qr-code {
    margin-bottom: var(--qi-space-xs);
  }

  .share-wechat-qr-code img {
    width: 128px;
    height: 128px;
    display: block;
  }

  .share-wechat-qr span {
    display: block;
    text-align: center;
    font-size: var(--qi-text-xs);
    color: var(--qi-on-surface-secondary);
  }

  :global(.dark) .share-btn {
    border-color: var(--qi-border-inverse);
  }

  :global(.dark) .share-btn:hover {
    border-color: var(--qi-brand-emerald);
    background: var(--qi-brand-emerald-10);
  }

  :global(.dark) .share-wechat-qr {
    background: var(--qi-surface-main);
    border-color: var(--qi-border-inverse);
  }

  @media (max-width: 768px) {
    .share-buttons-list {
      flex-direction: column;
    }

    .share-btn {
      justify-content: center;
    }

    .share-wechat-qr {
      right: 50%;
      transform: translateX(50%);
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const wechatBtn = document.querySelector('.share-btn--wechat');
    if (wechatBtn) {
      wechatBtn.addEventListener('mouseenter', () => {
        const qrCode = wechatBtn.querySelector('.share-wechat-qr');
        if (qrCode) {
          (qrCode as HTMLElement).style.display = 'block';
        }
      });
      wechatBtn.addEventListener('mouseleave', () => {
        const qrCode = wechatBtn.querySelector('.share-wechat-qr');
        if (qrCode) {
          (qrCode as HTMLElement).style.display = 'none';
        }
      });

      let touchTimer: ReturnType<typeof setTimeout>;
      wechatBtn.addEventListener('touchstart', () => {
        const qrCode = wechatBtn.querySelector('.share-wechat-qr');
        if (qrCode) {
          (qrCode as HTMLElement).style.display = 'block';
          if (touchTimer) clearTimeout(touchTimer);
          touchTimer = setTimeout(() => {
            (qrCode as HTMLElement).style.display = 'none';
          }, 5000);
        }
      });

      document.addEventListener('click', (e) => {
        if (!wechatBtn.contains(e.target)) {
          const qrCode = wechatBtn.querySelector('.share-wechat-qr');
          if (qrCode) {
            (qrCode as HTMLElement).style.display = 'none';
          }
        }
      });
    }

    const copyBtn = document.querySelector('.share-btn--copy');
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          const spanEl = copyBtn.querySelector('span');
          const originalText = spanEl?.textContent || '';
          const copiedText = copyBtn.getAttribute('data-copied-text') || 'Copied';
          if (spanEl) {
            spanEl.textContent = copiedText;
            setTimeout(() => {
              spanEl.textContent = originalText;
            }, 2000);
          }
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    }
  });
</script>
