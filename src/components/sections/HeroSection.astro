---
interface Props {
  titleLines: string[];
  accentIndex?: number;
  subtitle: string;
  watermark?: string;
  badgeText?: string;
  stats: Array<{
    value: string;
    label: string;
    dataCount?: number;
    isText?: boolean;
  }>;
  primaryBtn?: { text: string; href: string };
  secondaryBtn?: { text: string; href: string };
}

const {
  titleLines,
  accentIndex = 1,
  subtitle,
  watermark = '祈',
  badgeText = '祈研所 · Qi-Lab',
  stats,
  primaryBtn,
  secondaryBtn,
} = Astro.props;
---

<section class="hero-section" data-reveal>
  <div class="hero-bg-decoration" aria-hidden="true">
    <div class="hero-gradient-orb hero-gradient-orb--1"></div>
    <div class="hero-gradient-orb hero-gradient-orb--2"></div>
    <!-- 柔光晕 — 大面积翡翠绿氛围光 -->
    <div class="hero-ambient-glow"></div>
    <div class="hero-rays"></div>
    <div class="hero-beam hero-beam--amber"></div>
    <div class="hero-beam hero-beam--mint"></div>
    <div class="hero-grid-pattern"></div>
    <div class="hero-dot-pattern"></div>
    <div class="hero-watermark" aria-hidden="true">{watermark}</div>
    <!-- 边缘暗角 — 焦点引导 -->
    <div class="hero-vignette"></div>
    <!-- 同心圆弧装饰 -->
    <svg class="hero-arcs" width="320" height="320" viewBox="0 0 320 320" fill="none" aria-hidden="true">
      <circle cx="160" cy="160" r="140" stroke="currentColor" stroke-width="0.75" opacity="0.10" />
      <circle cx="160" cy="160" r="105" stroke="currentColor" stroke-width="0.75" opacity="0.08" stroke-dasharray="6 8" />
      <circle cx="160" cy="160" r="70" stroke="currentColor" stroke-width="0.5" opacity="0.06" />
      <circle cx="160" cy="160" r="150" stroke="currentColor" stroke-width="1" opacity="0.14" stroke-dasharray="100 842" stroke-linecap="round" />
    </svg>
  </div>
  <div class="container hero-container">
    <div class="hero-content">
      <div class="hero-badge hero-stagger hero-stagger--1">
        <span class="badge-dot"></span>
        <span class="badge-text">{badgeText}</span>
      </div>
      <h1 class="hero-title">
        {titleLines.map((line, i) => (
          <span class:list={['title-line', 'hero-stagger', `hero-stagger--${i + 2}`, i === accentIndex && 'title-accent']}>
            {line}
          </span>
        ))}
      </h1>
      <p class="hero-subtitle hero-fade-in">{subtitle}</p>
      <div class="hero-actions hero-fade-in">
        {primaryBtn && (
          <a href={primaryBtn.href} class="btn btn-primary">
            <span>{primaryBtn.text}</span>
            <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        )}
        {secondaryBtn && (
          <a href={secondaryBtn.href} class="btn btn-secondary">{secondaryBtn.text}</a>
        )}
      </div>
      <div class="hero-stats hero-fade-in">
        {stats.map((stat, i) => (
          <>
            {i > 0 && <div class="hero-stat-divider"></div>}
            <div class="hero-stat">
              <span class:list={['hero-stat-value', stat.isText && 'hero-stat-text']} data-count={stat.dataCount}>
                {stat.isText ? stat.value : '0'}
              </span>
              <span class="hero-stat-label">{stat.label}</span>
            </div>
          </>
        ))}
      </div>
    </div>
    <!-- 右侧浮动代码卡片装饰 -->
    <div class="hero-float-card hero-float-card--code" aria-hidden="true">
      <div class="float-card-header">
        <span class="float-card-dot float-card-dot--red"></span>
        <span class="float-card-dot float-card-dot--yellow"></span>
        <span class="float-card-dot float-card-dot--green"></span>
        <span class="float-card-filename">tokens.css</span>
      </div>
      <div class="float-card-body">
        <code><span class="fc-prop">--qi-brand-emerald</span>: <span class="fc-val">#4ADE80</span>;</code>
        <code><span class="fc-prop">--qi-brand-amber</span>: <span class="fc-val">#FBbF24</span>;</code>
        <code><span class="fc-prop">--qi-brand-mint</span>: <span class="fc-val">#99F6E4</span>;</code>
        <code><span class="fc-comment">/* 工程美学 */</span></code>
      </div>
    </div>
    <div class="hero-float-card hero-float-card--stat" aria-hidden="true">
      <div class="float-stat-label">Lighthouse</div>
      <div class="float-stat-value">100</div>
      <div class="float-stat-bar">
        <div class="float-stat-fill"></div>
      </div>
    </div>
  </div>
</section>
