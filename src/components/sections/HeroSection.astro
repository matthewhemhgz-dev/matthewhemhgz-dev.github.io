---
import HeroFloatCard from '../ui/HeroFloatCard.astro';

interface Props {
  titleLines: string[];
  accentIndex?: number;
  subtitle: string;
  watermark?: string;
  badgeText?: string;
  stats: Array<{
    value: string;
    label: string;
    dataCount?: number;
    isText?: boolean;
  }>;
  primaryBtn?: { text: string; href: string };
  secondaryBtn?: { text: string; href: string };
  lang?: string;
}

const {
  titleLines,
  accentIndex = 1,
  subtitle,
  watermark = '祈',
  badgeText = 'QiLab',
  stats,
  primaryBtn,
  secondaryBtn,
  lang = 'zh',
} = Astro.props;

const trophyIcon =
  '<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2L12.09 7.26L18 7.64L13.55 11.42L14.82 17.18L10 14.27L5.18 17.18L6.45 11.42L2 7.64L7.91 7.26L10 2Z" fill="currentColor"/></svg>';
---

<section class="hero-section" data-reveal>
  <div class="hero-bg-decoration" aria-hidden="true">
    <div class="hero-gradient-orb hero-gradient-orb--1"></div>
    <div class="hero-gradient-orb hero-gradient-orb--2"></div>
    <div class="hero-ambient-glow"></div>
    <div class="hero-rays"></div>
    <div class="hero-beam hero-beam--amber"></div>
    <div class="hero-beam hero-beam--mint"></div>
    <div class="hero-grid-pattern"></div>
    <div class="hero-dot-pattern"></div>
    <div class="hero-watermark" aria-hidden="true">{watermark}</div>
    <div class="hero-vignette"></div>
    <svg
      class="hero-arcs"
      width="320"
      height="320"
      viewBox="0 0 320 320"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="160" cy="160" r="140" stroke="currentColor" stroke-width="0.75" opacity="0.10"
      ></circle>
      <circle
        cx="160"
        cy="160"
        r="105"
        stroke="currentColor"
        stroke-width="0.75"
        opacity="0.08"
        stroke-dasharray="6 8"></circle>
      <circle cx="160" cy="160" r="70" stroke="currentColor" stroke-width="0.5" opacity="0.06"
      ></circle>
      <circle
        cx="160"
        cy="160"
        r="150"
        stroke="currentColor"
        stroke-width="1"
        opacity="0.14"
        stroke-dasharray="100 842"
        stroke-linecap="round"></circle>
    </svg>
  </div>
  <div class="container hero-container">
    <div class="hero-content">
      <div class="hero-badge hero-stagger hero-stagger--1">
        <span class="badge-dot"></span>
        <span class="badge-text">{badgeText}</span>
      </div>
      <h1 class="hero-title">
        {
          titleLines.map((line, i) => (
            <span
              class:list={[
                'title-line',
                'hero-stagger',
                `hero-stagger--${i + 2}`,
                i === accentIndex && 'title-accent',
              ]}
            >
              {line}
            </span>
          ))
        }
      </h1>
      <p class="hero-subtitle hero-fade-in">{subtitle}</p>
      <div class="hero-actions hero-fade-in">
        {
          primaryBtn && (
            <a href={primaryBtn.href} class="btn btn-primary">
              <span>{primaryBtn.text}</span>
              <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path
                  d="M3 8h10m0 0L9 4m4 4L9 12"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          )
        }
        {
          secondaryBtn && (
            <a href={secondaryBtn.href} class="btn btn-secondary">
              {secondaryBtn.text}
            </a>
          )
        }
      </div>
      <div class="hero-stats hero-fade-in" role="status" aria-label={lang === 'zh' ? '网站统计数据' : 'Site statistics'}>
        {
          stats.map((stat, i) => (
            <>
              {i > 0 && <div class="hero-stat-divider" aria-hidden="true" />}
              <div class="hero-stat" role="group" aria-label={stat.label}>
                <span
                  class:list={['hero-stat-value', stat.isText && 'hero-stat-text']}
                  data-count={stat.dataCount}
                  aria-label={stat.isText ? stat.value : `${stat.value} ${stat.label}`}
                >
                  {stat.isText ? stat.value : '0'}
                </span>
                <span class="hero-stat-label">{stat.label}</span>
              </div>
            </>
          ))
        }
      </div>
    </div>

    <div class="hero-extra hero-fade-in">
      <div class="hero-extra-item hero-extra-item--1">
        <HeroFloatCard
          type="insight"
          icon={trophyIcon}
          label={lang === 'zh' ? '祈研所' : 'QiLab'}
          value={lang === 'zh' ? '知识管理与技术实践' : 'Knowledge Management & Tech Practice'}
          color="emerald"
          ariaHidden={true}
        />
      </div>
    </div>
  </div>
</section>
