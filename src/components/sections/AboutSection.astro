---
import SectionHeader from '../ui/SectionHeader.astro';
import DashCard from '../ui/DashCard.astro';

interface Props {
  label: string;
  title: string;
  text: string;
  decoNumber?: string;
  decoSlogan?: string;
  dashItems: Array<{
    label: string;
    value: string;
    percentage: number;
    color: string;
  }>;
  classList?: string;
}

const {
  label,
  title,
  text,
  decoNumber = '01',
  decoSlogan,
  dashItems,
  classList = '',
} = Astro.props;
---

<section class="section about-section ${classList}" data-reveal>
  <div class="container">
    <div class="about-layout">
      <div class="about-deco" aria-hidden="true">
        <span class="about-deco-number">{decoNumber}</span>
        {decoSlogan && <span class="about-deco-slogan">{decoSlogan}</span>}
        <svg
          class="about-crosshair"
          width="64"
          height="64"
          viewBox="0 0 64 64"
          fill="none"
          aria-hidden="true"
        >
          <line
            x1="0"
            y1="32"
            x2="24"
            y2="32"
            stroke="currentColor"
            stroke-width="0.5"
            opacity="0.3"></line>
          <line
            x1="40"
            y1="32"
            x2="64"
            y2="32"
            stroke="currentColor"
            stroke-width="0.5"
            opacity="0.3"></line>
          <line
            x1="32"
            y1="0"
            x2="32"
            y2="24"
            stroke="currentColor"
            stroke-width="0.5"
            opacity="0.3"></line>
          <line
            x1="32"
            y1="40"
            x2="32"
            y2="64"
            stroke="currentColor"
            stroke-width="0.5"
            opacity="0.3"></line>
          <circle cx="32" cy="32" r="3" stroke="currentColor" stroke-width="0.5" opacity="0.4"
          ></circle>
          <circle
            cx="32"
            cy="32"
            r="12"
            stroke="currentColor"
            stroke-width="0.5"
            opacity="0.15"
            stroke-dasharray="3 3"></circle>
        </svg>
        <svg
          class="about-deco-lines"
          width="120"
          height="40"
          viewBox="0 0 120 40"
          fill="none"
          aria-hidden="true"
        >
          <line
            x1="0"
            y1="20"
            x2="40"
            y2="20"
            stroke="currentColor"
            stroke-width="0.5"
            opacity="0.2"></line>
          <circle cx="50" cy="20" r="2" fill="currentColor" opacity="0.25"></circle>
          <line
            x1="60"
            y1="20"
            x2="120"
            y2="20"
            stroke="currentColor"
            stroke-width="0.5"
            opacity="0.15"
            stroke-dasharray="4 4"></line>
        </svg>
      </div>
      <div class="about-main">
        <SectionHeader label={label} title={title} />
        <p class="about-text">{text}</p>
        <div class="dash-grid">
          {
            dashItems.map((item) => (
              <DashCard
                label={item.label}
                value={item.value}
                percentage={item.percentage}
                color={item.color}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
