---
import { projects, projectCategories, type Project } from '../../data/projects';
import SectionHeader from '../ui/SectionHeader.astro';
import OptimizedImage from '../ui/OptimizedImage.astro';

interface Props {
  classList?: string;
  label?: string;
  title?: string;
  showCategories?: boolean;
}

const { classList = '', label = '// PROJECTS', title = '项目展示', showCategories = true } = Astro.props;

let activeCategory = 'all';
const filteredProjects = projects.filter(p => activeCategory === 'all' || p.category === activeCategory);
---

<section class={`projects-section ${classList}`}>
  <div class="container">
    <SectionHeader label={label} title={title} />

    {showCategories && (
      <div class="projects-categories">
        {projectCategories.map((cat) => (
          <button
            key={cat.id}
            class="project-category-btn"
            data-category={cat.id}
            aria-label={`Filter projects by ${cat.label}`}
          >
            {cat.label}
          </button>
        ))}
      </div>
    )}

    <div class="projects-grid">
      {filteredProjects.map((project) => (
        <article
          key={project.id}
          class="project-card"
          tabindex="0"
          role="article"
          aria-labelledby={`project-${project.id}-title`}
        >
          <div class="project-card-inner">
            <div class="project-card-cover">
              <OptimizedImage
                src={project.coverImage}
                alt={project.title}
                width={600}
                height={400}
                loading="lazy"
                class="project-card-image"
              />
              <div class="project-card-overlay">
                <div class="project-card-actions">
                  {project.liveUrl && (
                    <a
                      href={project.liveUrl}
                      class="project-action-btn project-action-btn--live"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`View live demo of ${project.title}`}
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                        <polyline points="15 3 21 3 21 9"/>
                        <line x1="10" y1="14" x2="21" y2="3"/>
                      </svg>
                    </a>
                  )}
                  {project.repoUrl && (
                    <a
                      href={project.repoUrl}
                      class="project-action-btn project-action-btn--repo"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`View repository of ${project.title}`}
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-1 1.02-1.28 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                        <path d="M9 18c-2 0-3.5-1.5-3.5-3.5S7 11 9 11s3.5 1.5 3.5 3.5S11 18 9 18"/>
                      </svg>
                    </a>
                  )}
                </div>
              </div>
              <div class="project-card-year">{project.year}</div>
            </div>

            <div class="project-card-content">
              <div class="project-card-category">{project.category}</div>
              <h3 id={`project-${project.id}-title`} class="project-card-title">
                {project.title}
              </h3>
              <p class="project-card-description">{project.description}</p>

              <div class="project-card-tags">
                {project.tags.map((tag) => (
                  <span key={tag} class="project-tag">{tag}</span>
                ))}
              </div>

              <div class="project-card-tech">
                {project.technologies.slice(0, 4).map((tech) => (
                  <span key={tech} class="project-tech-tag">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding: var(--qi-space-5xl) 0;
  }

  .projects-categories {
    display: flex;
    flex-wrap: wrap;
    gap: var(--qi-space-sm);
    justify-content: center;
    margin-bottom: var(--qi-space-3xl);
  }

  .project-category-btn {
    padding: 0.6rem 1.25rem;
    border: 1px solid var(--qi-border-default);
    border-radius: var(--qi-radius-full);
    background: transparent;
    color: var(--qi-text-secondary);
    font-size: var(--qi-text-sm);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--qi-transition);
  }

  .project-category-btn:hover {
    border-color: var(--qi-brand-emerald);
    color: var(--qi-brand-emerald);
    background: var(--qi-brand-emerald-04);
  }

  .project-category-btn.active {
    background: var(--qi-brand-emerald);
    border-color: var(--qi-brand-emerald);
    color: var(--qi-bg-base);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--qi-space-xl);
  }

  .project-card {
    background: var(--qi-surface-sub);
    border-radius: var(--qi-radius-lg);
    overflow: hidden;
    border: 1px solid var(--qi-border-subtle);
    transition: all var(--qi-transition);
    cursor: pointer;
  }

  .project-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--qi-shadow-lg);
    border-color: var(--qi-brand-emerald-20);
  }

  .project-card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .project-card-cover {
    position: relative;
    aspect-ratio: 3/2;
    overflow: hidden;
    background: var(--qi-surface-main);
  }

  .project-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--qi-transition-base);
  }

  .project-card:hover .project-card-image {
    transform: scale(1.05);
  }

  .project-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0, 0, 0, 0.6));
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: var(--qi-space-lg);
    opacity: 0;
    transition: opacity var(--qi-transition);
  }

  .project-card:hover .project-card-overlay {
    opacity: 1;
  }

  .project-card-actions {
    display: flex;
    gap: var(--qi-space-sm);
    transform: translateY(20px);
    transition: transform var(--qi-transition);
  }

  .project-card:hover .project-card-actions {
    transform: translateY(0);
  }

  .project-action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--qi-radius-button);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    color: var(--qi-text-inverse);
    transition: all var(--qi-transition);
  }

  .project-action-btn:hover {
    background: var(--qi-brand-emerald);
    transform: translateY(-2px);
  }

  .project-card-year {
    position: absolute;
    top: var(--qi-space-sm);
    right: var(--qi-space-sm);
    padding: 4px 10px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    color: var(--qi-text-inverse);
    font-size: var(--qi-text-xs);
    font-weight: 600;
    border-radius: var(--qi-radius-sm);
  }

  .project-card-content {
    padding: var(--qi-space-xl);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .project-card-category {
    font-family: var(--qi-font-mono);
    font-size: var(--qi-text-xs);
    font-weight: 600;
    color: var(--qi-brand-emerald);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--qi-space-sm);
  }

  .project-card-title {
    font-family: var(--qi-font-serif);
    font-size: var(--qi-text-lg);
    font-weight: 600;
    color: var(--qi-text-primary);
    margin-bottom: var(--qi-space-sm);
    line-height: 1.4;
  }

  .project-card-description {
    font-size: var(--qi-text-sm);
    color: var(--qi-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--qi-space-md);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .project-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: var(--qi-space-md);
  }

  .project-tag {
    padding: 3px 8px;
    background: var(--qi-brand-emerald-04);
    color: var(--qi-brand-emerald);
    font-size: var(--qi-text-xs);
    font-weight: 500;
    border-radius: var(--qi-radius-sm);
  }

  .project-card-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding-top: var(--qi-space-md);
    border-top: 1px solid var(--qi-border-subtle);
  }

  .project-tech-tag {
    padding: 3px 8px;
    background: var(--qi-base-06);
    color: var(--qi-text-muted);
    font-size: var(--qi-text-xs);
    font-family: var(--qi-font-mono);
    border-radius: var(--qi-radius-sm);
  }

  :global(.dark) .project-card {
    background: var(--qi-surface-main);
    border-color: var(--qi-border-inverse);
  }

  :global(.dark) .project-card-cover {
    background: var(--qi-bg-base);
  }

  :global(.dark) .project-tag {
    background: var(--qi-brand-emerald-08);
    color: var(--qi-brand-emerald);
  }

  :global(.dark) .project-tech-tag {
    background: var(--qi-inverse-12);
    color: var(--qi-on-surface-secondary);
  }
</style>
