---
import { projects } from '../../data/projects';
import OptimizedImage from '../ui/OptimizedImage.astro';
import SectionHeader from '../ui/SectionHeader.astro';

interface Props {
  locale?: string;
}

const { locale = 'zh' } = Astro.props;
const isEnglish = locale === 'en';
// 只显示前 3 个精选项目
const featuredProjects = projects.slice(0, 3);
const projectsUrl = isEnglish ? '/en/projects' : '/projects';
const viewAllText = isEnglish ? 'View All Projects' : '查看全部项目';
---

<section id="projects" class="projects-section">
  <div class="container">
    <SectionHeader 
      title={isEnglish ? 'Projects' : '项目展示'} 
      subtitle={isEnglish ? 'Explore my technical practices and creative works' : '探索我的技术实践与创意作品'} 
    />

    <div class="projects-grid">
      {featuredProjects.map((project) => (
        <article key={project.id} class="project-card" role="article" aria-labelledby={`project-${project.id}-title`}>
          <div class="project-image-wrapper">
            <OptimizedImage 
              src={project.image} 
              alt={isEnglish ? project.titleEn : project.title}
              width={400}
              height={250}
              loading="lazy"
            />
            <div class="project-overlay">
              <a href={project.url} class="overlay-link">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 6H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
              {project.github && (
                <a href={project.github} class="overlay-link" target="_blank" rel="noopener noreferrer">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M15 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                    <path d="M21 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  </svg>
                </a>
              )}
            </div>
          </div>

          <div class="project-content">
            <div class="project-category">
              <span class="project-category-tag">{isEnglish ? project.categoryEn : project.category}</span>
            </div>
            
            <h3 id={`project-${project.id}-title`} class="project-title">
              <a href={project.url}>
                {isEnglish ? project.titleEn : project.title}
              </a>
            </h3>
            
            <p class="project-description">
              {isEnglish ? project.descriptionEn : project.description}
            </p>

            <div class="project-tags">
              {project.tags.map((tag) => (
                <span key={tag} class="project-tag">{tag}</span>
              ))}
            </div>

            <div class="project-meta">
              <span class="project-year">{project.year}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="view-all-container">
      <a href={projectsUrl} class="view-all-btn">
        {viewAllText}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14" />
          <path d="M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
.projects-section {
  padding: var(--qi-space-5xl) 0;
  background: linear-gradient(180deg, var(--qi-bg-base) 0%, var(--qi-bg-surface) 100%);
}

.container {
  max-width: var(--qi-container-max);
  margin: 0 auto;
  padding: 0 var(--qi-container-padding);
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: var(--qi-space-xl);
  margin-bottom: var(--qi-space-3xl);
}

.project-card {
  background: var(--qi-bg-surface);
  border-radius: var(--qi-radius-card);
  overflow: hidden;
  box-shadow: var(--qi-shadow-md);
  transition: all var(--qi-transition);
  border: 1px solid var(--qi-border-default);
}

.project-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--qi-shadow-hover-warm);
  border-color: var(--qi-brand-emerald);
}

.project-image-wrapper {
  position: relative;
  aspect-ratio: 16 / 10;
  overflow: hidden;
}

.project-image-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--qi-transition-slow);
}

.project-card:hover .project-image-wrapper img {
  transform: scale(1.05);
}

.project-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--qi-space-lg);
  opacity: 0;
  transition: opacity var(--qi-transition);
}

.project-card:hover .project-overlay {
  opacity: 1;
}

.overlay-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background: var(--qi-bg-surface);
  border-radius: 50%;
  color: var(--qi-text-primary);
  transition: all var(--qi-transition);
}

.overlay-link:hover {
  background: var(--qi-brand-emerald);
  color: var(--qi-text-inverse);
  transform: scale(1.1);
}

.project-content {
  padding: var(--qi-space-xl);
}

.project-category {
  margin-bottom: var(--qi-space-sm);
}

.project-category-tag {
  display: inline-block;
  padding: 2px 10px;
  background: var(--qi-brand-emerald-04);
  color: var(--qi-brand-emerald);
  border-radius: var(--qi-radius-sm);
  font-family: var(--qi-font-mono);
  font-size: var(--qi-text-xs);
  font-weight: 600;
}

.project-title {
  margin: 0 0 var(--qi-space-sm);
  font-family: var(--qi-font-serif);
  font-size: var(--qi-text-lg);
  font-weight: var(--qi-weight-semibold);
}

.project-title a {
  color: var(--qi-text-primary);
  text-decoration: none;
  transition: color var(--qi-transition);
}

.project-title a:hover {
  color: var(--qi-brand-emerald);
}

.project-description {
  margin: 0 0 var(--qi-space-md);
  font-size: var(--qi-text-sm);
  color: var(--qi-text-secondary);
  line-height: 1.6;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--qi-space-xs);
  margin-bottom: var(--qi-space-md);
}

.project-tag {
  padding: 2px 8px;
  background: var(--qi-surface-sub);
  border-radius: var(--qi-radius-sm);
  font-size: var(--qi-text-xs);
  color: var(--qi-text-muted);
  font-family: var(--qi-font-mono);
}

.project-meta {
  display: flex;
  justify-content: flex-end;
}

.project-year {
  font-family: var(--qi-font-mono);
  font-size: var(--qi-text-xs);
  color: var(--qi-text-muted);
}

.view-all-container {
  display: flex;
  justify-content: center;
  margin-top: var(--qi-space-xl);
}

.view-all-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--qi-space-sm);
  padding: var(--qi-space-md) var(--qi-space-xl);
  background: transparent;
  border: 2px solid var(--qi-brand-emerald);
  border-radius: var(--qi-radius-full);
  font-size: var(--qi-text-base);
  font-weight: var(--qi-weight-semibold);
  color: var(--qi-brand-emerald);
  text-decoration: none;
  transition: all var(--qi-transition);
}

.view-all-btn:hover {
  background: var(--qi-brand-emerald);
  color: var(--qi-text-inverse);
  transform: translateY(-2px);
  box-shadow: var(--qi-shadow-md);
}

.view-all-btn svg {
  transition: transform var(--qi-transition);
}

.view-all-btn:hover svg {
  transform: translateX(4px);
}

@media (max-width: 768px) {
  .projects-section {
    padding: var(--qi-space-3xl) 0;
  }

  .projects-grid {
    grid-template-columns: 1fr;
    gap: var(--qi-space-lg);
  }
}

@media (min-width: 1440px) {
  .projects-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: var(--qi-space-2xl);
  }

  .project-content {
    padding: var(--qi-space-2xl);
  }

  .project-title {
    font-size: var(--qi-text-xl);
  }
}
</style>
