---
import SectionHeader from '../ui/SectionHeader.astro';
import { svgIcons } from '../../data/icons';

interface Props {
  label: string;
  title: string;
  categories: Array<{
    label: string;
    icon: string;
    tools: Array<{
      name: string;
      desc: string;
    }>;
  }>;
}

const { label, title, categories } = Astro.props;
---

<section class="section" data-reveal>
  <!-- 浮动标签装饰 -->
  <div class="toolbox-float-tags" aria-hidden="true">
    <span class="float-tag float-tag--1">PKM</span>
    <span class="float-tag float-tag--2">AI</span>
    <span class="float-tag float-tag--3">Design</span>
    <span class="float-tag float-tag--4">Code</span>
    <span class="float-tag float-tag--5">Create</span>
  </div>
  <!-- 背景点阵装饰 -->
  <div class="toolbox-grid-deco" aria-hidden="true"></div>
  <div class="container">
    <SectionHeader label={label} title={title} />
    <div class="toolbox-grid">
      {categories.map((cat) => (
        <div class="toolbox-category">
          <div class="toolbox-header">
            <span class="toolbox-icon" set:html={svgIcons[cat.icon]} />
            <h3 class="toolbox-label">{cat.label}</h3>
          </div>
          <div class="toolbox-items">
            {cat.tools.map((tool) => (
              <div class="tool-chip">
                <span class="tool-name">{tool.name}</span>
                <span class="tool-desc">{tool.desc}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
