---
import { svgIcons } from '../../data/icons';

interface Props {
  label: string;
  title: string;
  description: string;
  primaryBtn: { text: string; href: string };
  secondaryBtn: { text: string; href: string; external?: boolean };
  lang?: 'zh' | 'en';
  classList?: string;
}

const {
  label,
  title,
  description,
  primaryBtn,
  secondaryBtn,
  lang = 'zh',
  classList = '',
} = Astro.props;

const labels =
  lang === 'en'
    ? {
        followFast: 'Follow us:',
        wechat: 'WeChat',
        xhs: 'Xiaohongshu',
        douyin: 'Douyin',
      }
    : {
        followFast: '快速关注:',
        wechat: '微信公众号',
        xhs: '小红书',
        douyin: '抖音',
      };
---

<style>
  @import '../../styles/components/cta-section.css';
</style>

<section class:list={['section', 'cta-section', classList]} data-reveal>
  <div class="cta-fade" aria-hidden="true"></div>
  <div class="cta-sparkles" aria-hidden="true">
    <span class="cta-sparkle cta-sparkle--1"></span>
    <span class="cta-sparkle cta-sparkle--2"></span>
    <span class="cta-sparkle cta-sparkle--3"></span>
  </div>
  <div class="container">
    <div class="cta-content">
      <span class="cta-label">{label}</span>
      <h2 class="cta-title">{title}</h2>
      <p class="cta-desc">{description}</p>
      <div class="cta-actions">
        <a href={primaryBtn.href} class="btn btn-primary">
          <span>{primaryBtn.text}</span>
          <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"
            ><path
              d="M3 8h10m0 0L9 4m4 4L9 12"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
        </a>
        <a
          href={secondaryBtn.href}
          class="btn btn-secondary"
          target={secondaryBtn.external ? '_blank' : undefined}
          rel={secondaryBtn.external ? 'noopener noreferrer' : undefined}
        >
          {secondaryBtn.text}
        </a>
      </div>

      <div class="cta-social-fast">
        <span class="cta-social-label">{labels.followFast}</span>
        <div class="cta-social-icons">
          <button
            type="button"
            class="cta-social-icon"
            data-qr-trigger
            data-platform={labels.wechat}
            data-qr-image="/images/social/wechat-oa-qr.jpg"
            data-account={lang === 'en' ? 'Qi-Lab' : '祈研所'}
            title={labels.wechat}
          >
            <Fragment set:html={svgIcons.wechat} />
          </button>
          <button
            type="button"
            class="cta-social-icon"
            data-qr-trigger
            data-platform={labels.xhs}
            data-qr-image="/images/social/xhs-qr.jpg"
            data-account={lang === 'en' ? 'Qi_Lab' : '祈研所（Qi_Lab）'}
            title={labels.xhs}
          >
            <Fragment set:html={svgIcons.xhs} />
          </button>
          <button
            type="button"
            class="cta-social-icon"
            data-qr-trigger
            data-platform={labels.douyin}
            data-qr-image="/images/social/douyin-qr.jpg"
            data-account={lang === 'en' ? 'QiLab' : '祈研所（QiLab）'}
            title={labels.douyin}
          >
            <Fragment set:html={svgIcons.douyin} />
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
