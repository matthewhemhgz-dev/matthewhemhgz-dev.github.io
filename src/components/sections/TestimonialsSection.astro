---
import SectionHeader from '../ui/SectionHeader.astro';
import { svgIcons } from '../../data/icons';

interface Props {
  label: string;
  title: string;
  testimonials: Array<{
    quote: string;
    author: string;
    role: string;
  }>;
}

const { label, title, testimonials } = Astro.props;
---

<section class="section" data-reveal>
  <!-- 大号中文引号装饰 -->
  <span class="testimonial-deco-quote testimonial-deco-quote--open" aria-hidden="true">「</span>
  <span class="testimonial-deco-quote testimonial-deco-quote--close" aria-hidden="true">」</span>
  <!-- 顶部渐变装饰线 -->
  <div class="testimonial-top-line" aria-hidden="true"></div>
  <div class="container">
    <SectionHeader label={label} title={title} />
    <div class="testimonial-grid">
      {testimonials.map((t, i) => (
        <blockquote class:list={['testimonial-card', 'tilt-card', `testimonial-card--${i}`]}>
          <span class="testimonial-quote">&ldquo;</span>
          <p class="testimonial-text">{t.quote}</p>
          <footer class="testimonial-footer">
            <div class="testimonial-avatar" aria-hidden="true" set:html={svgIcons['user']}></div>
            <div class="testimonial-author-info">
              <span class="testimonial-author">{t.author}</span>
              <span class="testimonial-role">{t.role}</span>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
