---
import SectionHeader from '../ui/SectionHeader.astro';
import '../../styles/components/testimonials-section.css';

interface Props {
  label: string;
  title: string;
}

const { label, title } = Astro.props;

const isEn = Astro.url.pathname.startsWith('/en');

const timelineEvents = isEn
  ? [
      {
        year: '2026',
        title: 'QiLab Founded',
        description:
          'Created a personal digital archive to systematically organize knowledge, project management, and IT/AI skills.',
        icon: '📁',
      },
      {
        year: '2026',
        title: 'Knowledge Base Setup',
        description:
          "Built a knowledge graph using Obsidian based on Bloom's taxonomy, maintaining a single source of truth with Markdown + Git.",
        icon: '🧠',
      },
      {
        year: '2026',
        title: 'AI Workflow Integration',
        description:
          'Integrated Superpowers + OpenClaw AI Agents to drive development and content production pipelines.',
        icon: '🤖',
      },
      {
        year: '2026',
        title: 'Site Launched',
        description:
          'Built a high-performance static site using Astro with multi-language support and responsive design.',
        icon: '🚀',
      },
    ]
  : [
      {
        year: '2026',
        title: '祈研所成立',
        description: '创建个人数字档案室，系统化整理知识管理、项目管理、IT/AI技巧和八卦前沿',
        icon: '📁',
      },
      {
        year: '2026',
        title: '知识库搭建',
        description:
          '使用Obsidian构建基于Bloom六层认知模型的知识图谱，用Markdown + Git维护单点真理的文档体系',
        icon: '🧠',
      },
      {
        year: '2026',
        title: 'AI工作流整合',
        description: '集成Superpowers + OpenClaw AI Agent，驱动开发与内容生产流水线',
        icon: '🤖',
      },
      {
        year: '2026',
        title: '网站上线',
        description: '使用Astro构建高性能静态站点，实现多语言支持和响应式设计',
        icon: '🚀',
      },
    ];
---

<section class="section" data-reveal>
  <div class="container">
    <SectionHeader label={label} title={title} />
    <div class="timeline">
      {
        timelineEvents.map((event, index) => (
          <div
            class:list={[
              'timeline-item',
              index % 2 === 0 ? 'timeline-item--left' : 'timeline-item--right',
            ]}
          >
            <div class="timeline-year">{event.year}</div>
            <div class="timeline-content">
              <div class="timeline-icon">{event.icon}</div>
              <h3 class="timeline-title">{event.title}</h3>
              <p class="timeline-description">{event.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
