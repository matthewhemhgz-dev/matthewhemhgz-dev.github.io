---
/**
 * LazyComponent — 通用组件懒加载包装器
 * 使用 Astro 的动态导入支持实现组件按需加载
 * 
 * @param {string} resolve - 组件路径，相对于 src 目录
 * @param {object} props - 传递给懒加载组件的属性
 * @param {boolean} [fallback] - 是否显示加载状态
 */

interface Props {
  resolve: string;
  props?: Record<string, unknown>;
  fallback?: boolean;
}

const { resolve, props = {}, fallback = true } = Astro.props;
---

{#await import(`../${resolve}`)}
  {:then module}
    <script>
      // 动态导入完成后触发自定义事件
      document.dispatchEvent(new CustomEvent('lazy-component-loaded', { detail: { name: '{resolve}' } }));
    </script>
    <module.default {...props} />
  {:catch}
    {fallback && <div class="lazy-fallback" aria-live="polite">
      <div class="skeleton"></div>
    </div>}
{/await}

<style>
  .lazy-fallback {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100px;
  }
  
  .skeleton {
    width: 100%;
    height: 100px;
    background: linear-gradient(90deg, var(--qi-bg-muted) 25%, var(--qi-bg-base) 50%, var(--qi-bg-muted) 75%);
    background-size: 200% 100%;
    animation: skeleton-loading 1.5s ease-in-out infinite;
    border-radius: var(--qi-radius-md);
  }
  
  @keyframes skeleton-loading {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>