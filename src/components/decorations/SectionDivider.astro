---
/**
 * SectionDivider — 章节分隔装饰组件
 * 在 section 之间添加优雅的品牌色分隔线
 */
interface Props {
  variant?: 'dots' | 'line' | 'diamond' | 'arcs';
}

const { variant = 'dots' } = Astro.props;
---

<div class:list={['section-divider', `section-divider--${variant}`]} aria-hidden="true">
  {variant === 'dots' && (
    <svg width="360" height="24" viewBox="0 0 360 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="dots-fade-left" x1="0" y1="0" x2="140" y2="0">
          <stop offset="0%" stop-color="currentColor" stop-opacity="0" />
          <stop offset="30%" stop-color="currentColor" stop-opacity="0.3" />
          <stop offset="100%" stop-color="currentColor" stop-opacity="0.3" />
        </linearGradient>
        <linearGradient id="dots-fade-right" x1="220" y1="0" x2="360" y2="0">
          <stop offset="0%" stop-color="currentColor" stop-opacity="0.3" />
          <stop offset="70%" stop-color="currentColor" stop-opacity="0" />
        </linearGradient>
      </defs>
      <line x1="0" y1="12" x2="140" y2="12" stroke="url(#dots-fade-left)" stroke-width="0.75" />
      <circle cx="160" cy="12" r="2.5" fill="currentColor" opacity="0.35" />
      <circle cx="180" cy="12" r="3.5" fill="currentColor" opacity="0.55" />
      <circle cx="200" cy="12" r="2.5" fill="currentColor" opacity="0.35" />
      <line x1="220" y1="12" x2="360" y2="12" stroke="url(#dots-fade-right)" stroke-width="0.75" />
    </svg>
  )}

  {variant === 'line' && (
    <svg width="360" height="8" viewBox="0 0 360 8" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="line-fade" x1="0" y1="0" x2="360" y2="0">
          <stop offset="0%" stop-color="currentColor" stop-opacity="0" />
          <stop offset="20%" stop-color="currentColor" stop-opacity="0.3" />
          <stop offset="50%" stop-color="currentColor" stop-opacity="0.4" />
          <stop offset="80%" stop-color="currentColor" stop-opacity="0.3" />
          <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
        </linearGradient>
      </defs>
      <line x1="0" y1="4" x2="360" y2="4" stroke="url(#line-fade)" stroke-width="0.75" />
    </svg>
  )}

  {variant === 'diamond' && (
    <svg width="360" height="24" viewBox="0 0 360 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="diamond-fade-left" x1="0" y1="0" x2="164" y2="0">
          <stop offset="0%" stop-color="currentColor" stop-opacity="0" />
          <stop offset="30%" stop-color="currentColor" stop-opacity="0.3" />
        </linearGradient>
        <linearGradient id="diamond-fade-right" x1="188" y1="0" x2="360" y2="0">
          <stop offset="0%" stop-color="currentColor" stop-opacity="0.3" />
          <stop offset="70%" stop-color="currentColor" stop-opacity="0" />
        </linearGradient>
      </defs>
      <line x1="0" y1="12" x2="164" y2="12" stroke="url(#diamond-fade-left)" stroke-width="0.75" />
      <rect x="172" y="8" width="8" height="8" rx="1" transform="rotate(45 176 12)" stroke="currentColor" stroke-width="0.75" opacity="0.50" />
      <line x1="188" y1="12" x2="360" y2="12" stroke="url(#diamond-fade-right)" stroke-width="0.75" />
    </svg>
  )}

  {variant === 'arcs' && (
    <svg width="360" height="20" viewBox="0 0 360 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="arcs-fade" x1="0" y1="0" x2="360" y2="0">
          <stop offset="0%" stop-color="currentColor" stop-opacity="0" />
          <stop offset="20%" stop-color="currentColor" stop-opacity="0.25" />
          <stop offset="50%" stop-color="currentColor" stop-opacity="0.4" />
          <stop offset="80%" stop-color="currentColor" stop-opacity="0.25" />
          <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
        </linearGradient>
      </defs>
      <path d="M0 10 Q90 2 180 10 Q270 18 360 10" stroke="url(#arcs-fade)" stroke-width="0.75" fill="none" />
    </svg>
  )}
</div>

<style>
  .section-divider {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--qi-space-xl) 0;
    color: var(--qi-brand-emerald);
    pointer-events: none;
    user-select: none;
  }

  .section-divider svg {
    max-width: 360px;
    width: 100%;
    height: auto;
  }
</style>
