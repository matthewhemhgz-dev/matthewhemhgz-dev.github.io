---
import { ClientRouter } from 'astro:transitions';
import Navigation from '../components/global/Navigation.astro';
import ScrollProgress from '../components/global/ScrollProgress.astro';
import BackToTop from '../components/global/BackToTop.astro';
import ParticlesCanvas from '../components/global/ParticlesCanvas.astro';
import NoiseOverlay from '../components/global/NoiseOverlay.astro';
import Footer from '../components/global/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  tagline?: string;
  lang?: string;
  ogType?: string;
}

const {
  title = '祈研所 | Qi-Lab',
  description = '祈研所（Qi-Lab）— 探索技术、设计与创意的交汇之处。个人品牌网站，分享关于开发、思考与创造的一切。',
  ogImage = '/og-default.png',
  tagline = '探索技术、设计与创意的交汇之处',
  lang = 'zh-CN',
  ogType = 'website',
} = Astro.props;

const isEn = lang === 'en' || lang.startsWith('en');
const ogLocale = isEn ? 'en_US' : 'zh_CN';
const skipLinkText = isEn ? 'Skip to main content' : '跳至主要内容';
const brandName = isEn ? 'Qi-Lab' : '祈研所';
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://qi-lab.dev');

// hreflang: generate alternate URLs for zh/en
const path = Astro.url.pathname;
let zhPath = path;
let enPath = path;
if (path.startsWith('/en/')) {
  zhPath = path.replace(/^\/en/, '') || '/';
  enPath = path;
} else if (path === '/en') {
  zhPath = '/';
  enPath = '/en/';
} else {
  zhPath = path;
  enPath = `/en${path}`;
}
const baseUrl = Astro.site ?? 'https://qi-lab.dev';
const zhUrl = new URL(zhPath, baseUrl);
const enUrl = new URL(enPath, baseUrl);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon (VI Logo) -->
    <link rel="icon" type="image/svg+xml" href="/images/logo.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />

    <!-- hreflang for bilingual SEO -->
    <link rel="alternate" hreflang="zh-CN" href={zhUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={zhUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&family=Noto+Serif+SC:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{skipLinkText}</a>
    <ClientRouter />
    <NoiseOverlay />
    <ScrollProgress />
    <Navigation currentPath={Astro.url.pathname} />
    <main id="main-content">
      <slot />
    </main>
    <BackToTop />
    <Footer
      brandName={brandName}
      tagline={tagline}
      email="hello@qi-lab.dev"
      wechat="QiLab_Studio"
      copyrightYear={new Date().getFullYear()}
    />
    <ParticlesCanvas />

    <!-- Global Scripts: particles, cursor-glow, scroll-parallax, scroll-handler -->
    <script>
      import '../scripts/init.js';
    </script>
  </body>
</html>

<style is:global>
  main {
    position: relative;
    z-index: var(--qi-z-content);
    min-height: 100vh;
  }
</style>
