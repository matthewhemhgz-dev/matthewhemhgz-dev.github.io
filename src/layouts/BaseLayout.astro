---
import { ClientRouter } from 'astro:transitions';
import Navigation from '../components/global/Navigation.astro';
import ScrollProgress from '../components/global/ScrollProgress.astro';
import BackToTop from '../components/global/BackToTop.astro';
import ParticlesCanvas from '../components/global/ParticlesCanvas.astro';
import NoiseOverlay from '../components/global/NoiseOverlay.astro';
import Footer from '../components/global/Footer.astro';
import SearchModal from '../components/global/SearchModal.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  tagline?: string;
  ogType?: string;
  /** JSON-LD 结构化数据（自动注入 <script type="application/ld+json">） */
  jsonLd?: Record<string, unknown>;
}

const {
  title = '祈研所 | Qi-Lab',
  description = '祈研所（Qi-Lab）— 探索技术、设计与创意的交汇之处。个人品牌网站，分享关于开发、思考与创造的一切。',
  ogImage = '/og-default.png',
  tagline = '探索技术、设计与创意的交汇之处',
  ogType = 'website',
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://qi-lab.dev');
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#F7F3EE" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon (VI Logo) -->
    <link rel="icon" type="image/png" href="/favicon.png" sizes="any" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="zh_CN" />
    {ogType === 'article' && (
      <meta property="article:author" content="祈研所" />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Google Fonts (async load) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&family=Noto+Serif+SC:wght@400;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&family=Noto+Serif+SC:wght@400;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- JSON-LD Structured Data -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <!-- Theme init (prevent FOUC) -->
    <script is:inline>
      (function(){var t=localStorage.getItem('qi-theme');if(!t){t=matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light'}document.documentElement.classList.toggle('dark',t==='dark')})();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">跳至主要内容</a>
    <ClientRouter />
    <NoiseOverlay />
    <ScrollProgress />
    <Navigation currentPath={Astro.url.pathname} />
    <main id="main-content" transition:name="main-content" data-pagefind-body>
      <slot />
    </main>
    <BackToTop />
    <Footer
      tagline={tagline}
      email="hello@qi-lab.dev"
      wechat="QiLab_Studio"
      copyrightYear={new Date().getFullYear()}
      transition:name="site-footer"
    />
    <ParticlesCanvas />
    <SearchModal />

    <!-- Global Scripts: particles, cursor-glow, scroll-parallax, scroll-handler -->
    <script>
      import '../scripts/init.js';
    </script>
  </body>
</html>

<style is:global>
  main {
    position: relative;
    z-index: var(--qi-z-content);
    min-height: 100vh;
  }
</style>
