":[{"messageId":"removeVar","data":{"varName":"q"},"fix":{"range":[3174,3183],"text":""},"desc":"Remove unused variable 'q'."}]}],"suppressedMessages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":292,"column":17,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":292,"endColumn":20,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[9883,9886],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[9883,9886],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":368,"column":45,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":368,"endColumn":48,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[12317,12320],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[12317,12320],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":410,"column":23,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":410,"endColumn":26,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[13827,13830],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[13827,13830],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"---\r\n/**\r\n * SearchModal 鈥?Pagefind 椹卞姩鐨勬悳绱㈠脊绐梊r\n *\r\n * 浣跨敤 Pagefind JavaScript API 瀹炵幇鑷畾涔夋悳绱?UI\r\n * 鏀寔 Cmd+K / Ctrl+K 蹇嵎閿敜璧穃r\n * View Transitions 鍏煎锛坱ransition:persist锛塡r\n * 澧炲己鐗堬細鎼滅储寤鸿銆侀珮绾ц繃婊ゃ€佹悳绱㈠巻鍙瞈r\n */\r\n---\r\n\r\n<div\r\n  id=\"search-modal\"\r\n  class=\"search-modal\"\r\n  role=\"dialog\"\r\n  aria-labelledby=\"search-modal-title\"\r\n  aria-hidden=\"true\"\r\n  aria-modal=\"true\"\r\n  transition:persist\r\n>\r\n  <div class=\"search-backdrop\" id=\"search-backdrop\" tabindex=\"-1\" aria-hidden=\"true\"></div>\r\n  <div class=\"search-container\" role=\"document\">\r\n    <div class=\"search-input-wrap\">\r\n      <h2 id=\"search-modal-title\" class=\"sr-only\" data-i18n-key=\"title\"></h2>\r\n      <svg\r\n        class=\"search-icon\"\r\n        width=\"18\"\r\n        height=\"18\"\r\n        viewBox=\"0 0 18 18\"\r\n        fill=\"none\"\r\n        aria-hidden=\"true\"\r\n      >\r\n        <circle cx=\"8\" cy=\"8\" r=\"5.5\" stroke=\"currentColor\" stroke-width=\"1.5\"></circle>\r\n        <path d=\"M12 12l3.5 3.5\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"\r\n        ></path>\r\n      </svg>\r\n      <input\r\n        id=\"search-input\"\r\n        type=\"search\"\r\n        class=\"search-input\"\r\n        autocomplete=\"off\"\r\n        aria-describedby=\"search-hint\"\r\n        aria-controls=\"search-results\"\r\n        data-i18n-key=\"placeholder\"\r\n      />\r\n      <kbd class=\"search-kbd\" aria-hidden=\"true\">ESC</kbd>\r\n    </div>\r\n\r\n    <!-- 鎼滅储寤鸿 -->\r\n    <div id=\"search-suggestions\" class=\"search-suggestions\" aria-hidden=\"true\"></div>\r\n\r\n    <!-- 楂樼骇鎼滅储閫夐」 -->\r\n    <div class=\"search-filters\">\r\n      <div class=\"search-filter-group\">\r\n        <button id=\"filter-all\" class=\"search-filter-btn active\" data-filter=\"all\">\r\n          <span data-i18n-key=\"filter-all\">鍏ㄩ儴</span>\r\n        </button>\r\n        <button id=\"filter-articles\" class=\"search-filter-btn\" data-filter=\"articles\">\r\n          <span data-i18n-key=\"filter-articles\">鏂囩珷</span>\r\n        </button>\r\n        <button id=\"filter-tags\" class=\"search-filter-btn\" data-filter=\"tags\">\r\n          <span data-i18n-key=\"filter-tags\">鏍囩</span>\r\n        </button>\r\n      </div>\r\n      <div class=\"search-filter-group\">\r\n        <button id=\"sort-relevance\" class=\"search-filter-btn active\" data-sort=\"relevance\">\r\n          鐩稿叧鎬r\n        </button>\r\n        <button id=\"sort-date-desc\" class=\"search-filter-btn\" data-sort=\"date-desc\"> 鏈€鏂?</button>\r\n        <button id=\"sort-date-asc\" class=\"search-filter-btn\" data-sort=\"date-asc\"> 鏈€鏃?</button>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 鎼滅储鍘嗗彶 -->\r\n    <div id=\"search-history\" class=\"search-history\">\r\n      <h3 class=\"search-history-title\" data-i18n-key=\"search-history\">鎼滅储鍘嗗彶</h3>\r\n      <div class=\"search-history-items\"></div>\r\n      <button id=\"clear-history\" class=\"search-clear-history\" data-i18n-key=\"clear-history\">\r\n        娓呴櫎鍘嗗彶\r\n      </button>\r\n    </div>\r\n\r\n    <div id=\"search-results\" class=\"search-results\" aria-live=\"polite\" aria-atomic=\"true\">\r\n      <p id=\"search-hint\" class=\"search-hint\" data-i18n-key=\"hint\"></p>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<style>\r\n  @import '../../styles/components/search-modal.css';\r\n</style>\r\n\r\n<script>\r\n  // i18n mapping for SearchModal (runtime locale detection)\r\n  const i18n: Record<string, Record<string, string | ((q: string) => string)>> = {\r\n    zh: {\r\n      title: '鎼滅储',\r\n      placeholder: '鎼滅储鏂囩珷銆佹爣绛炬垨涓婚鈥?,\r\n      ariaLabel: '鎼滅储鏂囩珷',\r\n      hint: '杈撳叆鍏抽敭璇嶏紝寮€鍚繁搴﹂槄璇烩€?,\r\n      searching: '姝ｅ湪涓烘偍瀵昏鍐呭鈥?,\r\n      devOnly: '鎼滅储鍔熻兘浠呭湪鐢熶骇鐜锛圔uild 鍚庯級鍙敤',\r\n      noResults: (_q: string) => `鏈壘鍒颁笌 鈥?{_q}鈥?鍖归厤鐨勫唴瀹广€傛崲涓叧閿瘝璇曡瘯锛焋,\r\n      error: '娣辨劅鎶辨瓑锛屾悳绱㈣繃绋嬩腑鍑虹幇浜嗕竴鐐瑰皬鎰忓',\r\n      'filter-all': '鍏ㄩ儴',\r\n      'filter-articles': '鏂囩珷',\r\n      'filter-tags': '鏍囩',\r\n      'search-history': '鎼滅储鍘嗗彶',\r\n      'clear-history': '娓呴櫎鍘嗗彶',\r\n      'no-history': '鏆傛棤鎼滅储鍘嗗彶',\r\n      'search-suggestions': '鎼滅储寤鸿',\r\n    },\r\n    en: {\r\n      title: 'Search',\r\n      placeholder: 'Search articles, tags, or topics鈥?,\r\n      ariaLabel: 'Search articles',\r\n      hint: 'Type a keyword to explore insights鈥?,\r\n      searching: 'Looking for contents鈥?,\r\n      devOnly: 'Search is only available in production (after build)',\r\n      noResults: (q: string) => `We couldn't find anything for \"${q}\". Try another keyword?`,\r\n      error: 'Something went wrong with the search',\r\n      'filter-all': 'All',\r\n      'filter-articles': 'Articles',\r\n      'filter-tags': 'Tags',\r\n      'search-history': 'Search History',\r\n      'clear-history': 'Clear History',\r\n      'no-history': 'No search history yet',\r\n      'search-suggestions': 'Search Suggestions',\r\n    },\r\n  };\r\n\r\n  function getLang(): string {\r\n    return document.documentElement.lang.startsWith('en') ? 'en' : 'zh';\r\n  }\r\n\r\n  function t(key: string): string {\r\n    return ((i18n[getLang()] || i18n.zh)[key] as string) || key;\r\n  }\r\n\r\n  function tNoResults(q: string): string {\r\n    const fn = (i18n[getLang()] || i18n.zh).noResults;\r\n    return typeof fn === 'function' ? fn(q) : String(fn);\r\n  }\r\n\r\n  function applyI18n() {\r\n    const titleEl = document.querySelector('[data-i18n-key=\"title\"]');\r\n    const inputEl = document.getElementById('search-input') as HTMLInputElement;\r\n    const hintEl = document.querySelector('[data-i18n-key=\"hint\"]');\r\n    const filterAllEl = document.querySelector('[data-i18n-key=\"filter-all\"]');\r\n    const filterArticlesEl = document.querySelector('[data-i18n-key=\"filter-articles\"]');\r\n    const filterTagsEl = document.querySelector('[data-i18n-key=\"filter-tags\"]');\r\n    const historyTitleEl = document.querySelector('[data-i18n-key=\"search-history\"]');\r\n    const clearHistoryEl = document.querySelector('[data-i18n-key=\"clear-history\"]');\r\n\r\n    if (titleEl) titleEl.textContent = t('title');\r\n    if (inputEl) {\r\n      inputEl.placeholder = t('placeholder');\r\n      inputEl.setAttribute('aria-label', t('ariaLabel'));\r\n    }\r\n    if (hintEl) hintEl.textContent = t('hint');\r\n    if (filterAllEl) filterAllEl.textContent = t('filter-all');\r\n    if (filterArticlesEl) filterArticlesEl.textContent = t('filter-articles');\r\n    if (filterTagsEl) filterTagsEl.textContent = t('filter-tags');\r\n    if (historyTitleEl) historyTitleEl.textContent = t('search-history');\r\n    if (clearHistoryEl) clearHistoryEl.textContent = t('clear-history');\r\n  }\r\n\r\n  // 鎼滅储鍘嗗彶绠＄悊\r\n  function getSearchHistory(): string[] {\r\n    const history = localStorage.getItem('searchHistory');\r\n    return history ? JSON.parse(history) : [];\r\n  }\r\n\r\n  function addToSearchHistory(query: string) {\r\n    if (!query.trim()) return;\r\n    let history = getSearchHistory();\r\n    history = history.filter((item) => item !== query);\r\n    history.unshift(query);\r\n    history = history.slice(0, 5); // 鍙繚鐣欐渶杩?鏉r\n    localStorage.setItem('searchHistory', JSON.stringify(history));\r\n    renderSearchHistory();\r\n  }\r\n\r\n  function clearSearchHistory() {\r\n    localStorage.removeItem('searchHistory');\r\n    renderSearchHistory();\r\n  }\r\n\r\n  function renderSearchHistory() {\r\n    const historyItems = document.querySelector('.search-history-items');\r\n    const history = getSearchHistory();\r\n\r\n    if (historyItems) {\r\n      if (history.length === 0) {\r\n        historyItems.innerHTML = `<p class=\"search-history-empty\">${t('no-history')}</p>`;\r\n      } else {\r\n        historyItems.innerHTML = history\r\n          .map(\r\n            (item) => `\r\n            <button class=\"search-history-item\" data-query=\"${item}\">\r\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\" aria-hidden=\"true\">\r\n                <path d=\"M6.5 1.5v11M1.5 6.5h11\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\r\n              </svg>\r\n              ${item}\r\n            </button>\r\n          `,\r\n          )\r\n          .join('');\r\n\r\n        // 娣诲姞鍘嗗彶椤圭偣鍑讳簨浠禱r\n        document.querySelectorAll('.search-history-item').forEach((item) => {\r\n          item.addEventListener('click', () => {\r\n            const query = item.getAttribute('data-query');\r\n            if (query) {\r\n              input.value = query;\r\n              performSearch(query);\r\n            }\r\n          });\r\n        });\r\n      }\r\n    }\r\n  }\r\n\r\n  // 鎼滅储寤鸿\r\n  const searchSuggestions = [\r\n    '鐭ヨ瘑绠＄悊',\r\n    '璁捐绯荤粺',\r\n    '鍓嶇鏋舵瀯',\r\n    'Astro',\r\n    'Tailwind CSS',\r\n    '鎬ц兘浼樺寲',\r\n    'TypeScript',\r\n    'React',\r\n    'Vue',\r\n    'Node.js',\r\n    'GitHub Actions',\r\n    'PWA',\r\n    'SEO',\r\n    '鍝嶅簲寮忚璁?,\r\n    '鍙闂€?,\r\n  ];\r\n\r\n  function showSearchSuggestions(query: string) {\r\n    const suggestionsEl = document.getElementById('search-suggestions');\r\n    if (!suggestionsEl) return;\r\n\r\n    if (!query.trim()) {\r\n      suggestionsEl.setAttribute('aria-hidden', 'true');\r\n      suggestionsEl.innerHTML = '';\r\n      return;\r\n    }\r\n\r\n    const filteredSuggestions = searchSuggestions.filter((suggestion) =>\r\n      suggestion.toLowerCase().includes(query.toLowerCase()),\r\n    );\r\n\r\n    if (filteredSuggestions.length > 0) {\r\n      suggestionsEl.setAttribute('aria-hidden', 'false');\r\n      suggestionsEl.innerHTML = `\r\n        <h3 class=\"search-suggestions-title\">${t('search-suggestions')}</h3>\r\n        <div class=\"search-suggestions-list\">\r\n          ${filteredSuggestions\r\n            .map(\r\n              (suggestion) => `\r\n            <button class=\"search-suggestion-item\" data-suggestion=\"${suggestion}\">\r\n              ${suggestion}\r\n            </button>\r\n          `,\r\n            )\r\n            .join('')}\r\n        </div>\r\n      `;\r\n\r\n      // 娣诲姞寤鸿鐐瑰嚮浜嬩欢\r\n      document.querySelectorAll('.search-suggestion-item').forEach((item) => {\r\n        item.addEventListener('click', () => {\r\n          const suggestion = item.getAttribute('data-suggestion');\r\n          if (suggestion) {\r\n            input.value = suggestion;\r\n            performSearch(suggestion);\r\n            suggestionsEl.setAttribute('aria-hidden', 'true');\r\n          }\r\n        });\r\n      });\r\n    } else {\r\n      suggestionsEl.setAttribute('aria-hidden', 'true');\r\n      suggestionsEl.innerHTML = '';\r\n    }\r\n  }\r\n\r\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\r\n  let pagefind: any = null;\r\n  let searchTimeout: ReturnType<typeof setTimeout> | null = null;\r\n  let currentFilter = 'all';\r\n  let currentSort = 'relevance';\r\n\r\n  const modal = document.getElementById('search-modal');\r\n  const input = document.getElementById('search-input') as HTMLInputElement;\r\n  const results = document.getElementById('search-results');\r\n  const backdrop = document.getElementById('search-backdrop');\r\n  const suggestions = document.getElementById('search-suggestions');\r\n\r\n  async function initPagefind() {\r\n    if (pagefind) return pagefind;\r\n    try {\r\n      if (import.meta.env.DEV) return null;\r\n      // Use Function constructor to completely hide the dynamic import from Vite\r\n      const importPath = '/pagefind/pagefind.js';\r\n      const importFn = new Function('path', 'return import(path)');\r\n      pagefind = await importFn(importPath);\r\n      await pagefind.init();\r\n      return pagefind;\r\n    } catch {\r\n      return null;\r\n    }\r\n  }\r\n\r\n  function openSearch() {\r\n    if (!modal) return;\r\n    applyI18n(); // refresh labels on open in case locale changed\r\n    modal.setAttribute('aria-hidden', 'false');\r\n    input?.focus();\r\n    document.body.style.overflow = 'hidden';\r\n    renderSearchHistory();\r\n  }\r\n\r\n  function closeSearch() {\r\n    if (!modal) return;\r\n    modal.setAttribute('aria-hidden', 'true');\r\n    input!.value = '';\r\n    if (results) results.innerHTML = `<p class=\"search-hint\">${t('hint')}</p>`;\r\n    if (suggestions) {\r\n      suggestions.setAttribute('aria-hidden', 'true');\r\n      suggestions.innerHTML = '';\r\n    }\r\n    document.body.style.overflow = '';\r\n  }\r\n\r\n  async function performSearch(query: string) {\r\n    if (!results) return;\r\n\r\n    if (!query.trim()) {\r\n      results.innerHTML = `<p class=\"search-hint\">${t('hint')}</p>`;\r\n      return;\r\n    }\r\n\r\n    // 娣诲姞鍒版悳绱㈠巻鍙瞈r\n    addToSearchHistory(query);\r\n\r\n    // 闅愯棌鎼滅储寤鸿\r\n    if (suggestions) {\r\n      suggestions.setAttribute('aria-hidden', 'true');\r\n      suggestions.innerHTML = '';\r\n    }\r\n\r\n    results.innerHTML = `<p class=\"search-status\">${t('searching')}</p>`;\r\n\r\n    const pf = await initPagefind();\r\n    if (!pf) {\r\n      results.innerHTML = `<p class=\"search-status\">${t('devOnly')}</p>`;\r\n      return;\r\n    }\r\n\r\n    try {\r\n      const search = await pf.search(query);\r\n      const items = await Promise.all(\r\n        // eslint-disable-next-line @typescript-eslint/no-explicit-any\r\n        search.results.slice(0, 10).map((r: any) => r.data()),\r\n      );\r\n\r\n      if (items.length === 0) {\r\n        results.innerHTML = `<p class=\"search-status\">${tNoResults(query)}</p>`;\r\n        return;\r\n      }\r\n\r\n      // 鏍规嵁杩囨护鍣ㄧ瓫閫夌粨鏋淺r\n      let filteredItems = items;\r\n      if (currentFilter === 'articles') {\r\n        filteredItems = items.filter((item) => item.url.includes('/blog/'));\r\n      } else if (currentFilter === 'tags') {\r\n        filteredItems = items.filter((item) => item.url.includes('/tags/'));\r\n      }\r\n\r\n      // 鏍规嵁鎺掑簭鏂瑰紡鎺掑簭缁撴灉\r\n      if (currentSort === 'date-desc') {\r\n        filteredItems.sort((a, b) => {\r\n          const dateA = new Date(a.meta?.pubDate || 0);\r\n          const dateB = new Date(b.meta?.pubDate || 0);\r\n          return dateB.getTime() - dateA.getTime();\r\n        });\r\n      } else if (currentSort === 'date-asc') {\r\n        filteredItems.sort((a, b) => {\r\n          const dateA = new Date(a.meta?.pubDate || 0);\r\n          const dateB = new Date(b.meta?.pubDate || 0);\r\n          return dateA.getTime() - dateB.getTime();\r\n        });\r\n      }\r\n\r\n      if (filteredItems.length === 0) {\r\n        results.innerHTML = `<p class=\"search-status\">${tNoResults(query)}</p>`;\r\n        return;\r\n      }\r\n\r\n      results.innerHTML = `\r\n        <div class=\"search-results-header\">\r\n          <span class=\"search-results-count\">${filteredItems.length} ${t('filter-articles')}</span>\r\n        </div>\r\n        ${filteredItems\r\n          // eslint-disable-next-line @typescript-eslint/no-explicit-any\r\n          .map((item: any) => {\r\n            const url = item.url.startsWith('/') ? item.url : `/${item.url}`;\r\n            const title = item.meta?.title || item.url;\r\n            const excerpt = item.excerpt || '';\r\n            const category = item.meta?.category || '';\r\n            return `\r\n              <a href=\"${url}\" class=\"search-result-item\">\r\n                ${category ? `<div class=\"search-result-category\">${category}</div>` : ''}\r\n                <div class=\"search-result-title\">${title}</div>\r\n                ${excerpt ? `<div class=\"search-result-excerpt\">${excerpt}</div>` : ''}\r\n              </a>\r\n            `;\r\n          })\r\n          .join('')}\r\n      `;\r\n    } catch {\r\n      results.innerHTML = `<p class=\"search-status\">${t('error')}</p>`;\r\n    }\r\n  }\r\n\r\n  // Apply i18n on initial load\r\n  applyI18n();\r\n\r\n  // Event listeners\r\n  document.addEventListener('astro:page-load', () => {\r\n    // Keyboard shortcut: Cmd+K / Ctrl+K\r\n    document.addEventListener('keydown', (e) => {\r\n      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {\r\n        e.preventDefault();\r\n        const isHidden = modal?.getAttribute('aria-hidden') === 'true';\r\n        if (isHidden) openSearch();\r\n        else closeSearch();\r\n      }\r\n      if (e.key === 'Escape' && modal?.getAttribute('aria-hidden') === 'false') {\r\n        closeSearch();\r\n      }\r\n    });\r\n\r\n    // Input debounce for search and suggestions\r\n    input?.addEventListener('input', () => {\r\n      if (searchTimeout) clearTimeout(searchTimeout);\r\n\r\n      // 鏄剧ず鎼滅储寤鸿\r\n      showSearchSuggestions(input.value);\r\n\r\n      // 寤惰繜鎵ц鎼滅储\r\n      searchTimeout = setTimeout(() => performSearch(input.value), 300);\r\n    });\r\n\r\n    // Backdrop click to close\r\n    backdrop?.addEventListener('click', closeSearch);\r\n\r\n    // Focus trap for modal\r\n    if (modal) {\r\n      modal.addEventListener('keydown', (e) => {\r\n        if (e.key === 'Tab') {\r\n          const focusableElements = modal.querySelectorAll('input, button, a');\r\n          const firstElement = focusableElements[0];\r\n          const lastElement = focusableElements[focusableElements.length - 1];\r\n\r\n          if (e.shiftKey) {\r\n            // Shift + Tab\r\n            if (document.activeElement === firstElement) {\r\n              e.preventDefault();\r\n              (lastElement as HTMLElement)?.focus();\r\n            }\r\n          } else {\r\n            // Tab\r\n            if (document.activeElement === lastElement) {\r\n              e.preventDefault();\r\n              (firstElement as HTMLElement)?.focus();\r\n            }\r\n          }\r\n        }\r\n      });\r\n    }\r\n\r\n    // 杩囨护鍣ㄥ拰鎺掑簭鎸夐挳鐐瑰嚮浜嬩欢\r\n    document.querySelectorAll('.search-filter-btn').forEach((btn) => {\r\n      btn.addEventListener('click', () => {\r\n        const filter = btn.getAttribute('data-filter');\r\n        const sort = btn.getAttribute('data-sort');\r\n\r\n        if (filter) {\r\n          // 绉婚櫎鍚岀粍鎵€鏈夋縺娲荤姸鎬乗r\n          btn\r\n            .closest('.search-filter-group')\r\n            ?.querySelectorAll('.search-filter-btn')\r\n            .forEach((b) => b.classList.remove('active'));\r\n          // 娣诲姞褰撳墠婵€娲荤姸鎬乗r\n          btn.classList.add('active');\r\n          // 鏇存柊褰撳墠杩囨护鍣╘r\n          currentFilter = filter;\r\n        }\r\n\r\n        if (sort) {\r\n          // 绉婚櫎鍚岀粍鎵€鏈夋縺娲荤姸鎬乗r\n          btn\r\n            .closest('.search-filter-group')\r\n            ?.querySelectorAll('.search-filter-btn')\r\n            .forEach((b) => b.classList.remove('active'));\r\n          // 娣诲姞褰撳墠婵€娲荤姸鎬乗r\n          btn.classList.add('active');\r\n          // 鏇存柊褰撳墠鎺掑簭\r\n          currentSort = sort;\r\n        }\r\n\r\n        // 閲嶆柊鎵ц鎼滅储\r\n        if (input.value.trim()) {\r\n          performSearch(input.value);\r\n        }\r\n      });\r\n    });\r\n\r\n    // 娓呴櫎鍘嗗彶鎸夐挳鐐瑰嚮浜嬩欢\r\n    const clearHistoryBtn = document.getElementById('clear-history');\r\n    clearHistoryBtn?.addEventListener('click', clearSearchHistory);\r\n  });\r\n</script>\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\Project\\GithubPage_PerBrand\\src\\components\\global\\ThemeToggle.astro","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\Project\\GithubPage_PerBrand\\src\\components\\sections\\AboutSection.astro","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\Project\\GithubPag